<Window x:Class="MassageSaas.Cs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MassageSaas.Cs.ViewModels"
        Title="{Binding WindowTitle, FallbackValue=按摩店收银系统}"
        Height="780" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">
    <Window.InputBindings>
        <KeyBinding Key="F2" Command="{Binding FocusMembersCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCurrentCommand}" />
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewSaleCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding QuickCheckoutCommand}" />
        <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding QuickCheckoutCommand}" />
        <KeyBinding Key="D1" Modifiers="Alt" Command="{Binding NavByIndexCommand}" CommandParameter="0" />
        <KeyBinding Key="D2" Modifiers="Alt" Command="{Binding NavByIndexCommand}" CommandParameter="1" />
        <KeyBinding Key="D3" Modifiers="Alt" Command="{Binding NavByIndexCommand}" CommandParameter="2" />
        <KeyBinding Key="D4" Modifiers="Alt" Command="{Binding NavByIndexCommand}" CommandParameter="3" />
        <KeyBinding Key="D5" Modifiers="Alt" Command="{Binding NavByIndexCommand}" CommandParameter="4" />
        <KeyBinding Key="D6" Modifiers="Alt" Command="{Binding NavByIndexCommand}" CommandParameter="5" />
        <KeyBinding Key="D7" Modifiers="Alt" Command="{Binding NavByIndexCommand}" CommandParameter="6" />
        <KeyBinding Key="D8" Modifiers="Alt" Command="{Binding NavByIndexCommand}" CommandParameter="7" />
        <KeyBinding Key="D9" Modifiers="Alt" Command="{Binding NavByIndexCommand}" CommandParameter="8" />
    </Window.InputBindings>
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#BFCBD9" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="20,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2C3E50" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#264653" />
                    <Setter Property="Foreground" Value="#FFD04B" />
                    <Setter Property="FontWeight" Value="Bold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="#1F2D3D">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#172230" Padding="16,18">
                <StackPanel>
                    <TextBlock Text="{Binding Context.ActiveStore.Name, FallbackValue=按摩店}"
                               FontSize="15" FontWeight="Bold" Foreground="White"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding CurrentUserDisplay}"
                               FontSize="11" Foreground="#9AA8BC" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding NavItems}" Margin="0,8,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource NavButton}"
                                Content="{Binding Title}"
                                AutomationProperties.Name="{Binding Title}"
                                Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Grid.Row="2" Style="{StaticResource NavButton}"
                    Content="退出登录"
                    Foreground="#E76F51"
                    Command="{Binding LogoutCommand}"
                    AutomationProperties.Name="退出登录" />
        </Grid>

        <!-- Main -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="White" Padding="20,12"
                    BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left"
                               Text="{Binding SelectedNavItem.Title, FallbackValue=主页}"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#FEF3C7" CornerRadius="3" Padding="8,4" Margin="0,0,12,0"
                                Visibility="{Binding SubscriptionWarning, Converter={StaticResource NullToCollapsed}, FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding SubscriptionWarning}" Foreground="#92400E" FontSize="12" />
                        </Border>

                        <ComboBox ItemsSource="{Binding Context.Stores}"
                                  SelectedItem="{Binding Context.ActiveStore, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  Width="180" Height="32"
                                  SelectionChanged="StoreCombo_SelectionChanged"
                                  AutomationProperties.Name="切换门店"
                                  Visibility="{Binding Context.Stores.Count, Converter={StaticResource CountToVisible}, FallbackValue=Collapsed}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content -->
            <ContentControl Grid.Row="1" Content="{Binding Navigation.CurrentViewModel}"
                            Margin="16" />
        </Grid>
    </Grid>
</Window>
