<UserControl x:Class="MassageSaas.Cs.Views.VouchersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBox Width="170" Height="30" Margin="0,0,8,0"
                             Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="按券码、标题或平台搜索">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="查询" Padding="12,6" Height="30" Margin="0,0,8,0"
                            Command="{Binding SearchCommand}"
                            AutomationProperties.Name="按当前关键字查询" />
                    <TextBlock Text="类型" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox SelectedIndex="{Binding KindFilter, Mode=TwoWay}" Width="100" Height="30" Margin="0,0,8,0"
                              AutomationProperties.Name="按类型筛选">
                        <ComboBoxItem Content="全部类型" />
                        <ComboBoxItem Content="店内券" />
                        <ComboBoxItem Content="团购券" />
                    </ComboBox>
                    <TextBlock Text="状态" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox SelectedIndex="{Binding StatusFilter, Mode=TwoWay}" Width="110" Height="30"
                              AutomationProperties.Name="按状态筛选">
                        <ComboBoxItem Content="全部" />
                        <ComboBoxItem Content="未核销" />
                        <ComboBoxItem Content="已核销" />
                        <ComboBoxItem Content="已过期" />
                        <ComboBoxItem Content="已作废" />
                    </ComboBox>
                    <Button Content="录入券" Padding="12,6" Margin="12,0,0,0" Background="#2D6A4F" Foreground="White" BorderThickness="0" Command="{Binding CreateCommand}" />
                    <Button Content="批量生成" Padding="12,6" Margin="8,0,0,0" Command="{Binding BatchCreateCommand}"
                            AutomationProperties.Name="批量生成同规格优惠券"
                            AutomationProperties.HelpText="一次生成多张同规格券，服务端自动出码" />
                    <Button Content="批量作废" Padding="12,6" Margin="8,0,0,0" Command="{Binding BulkCancelCommand}"
                            AutomationProperties.Name="批量作废勾选的券"
                            AutomationProperties.HelpText="只作废勾选中状态为生效中的券" />
                    <Button Content="批量删除" Padding="12,6" Margin="8,0,0,0"
                            Background="#D9534F" Foreground="White" BorderThickness="0"
                            Command="{Binding BulkDeleteCommand}"
                            AutomationProperties.Name="批量删除勾选的已作废券"
                            AutomationProperties.HelpText="物理删除，仅对已作废券生效，不可恢复" />
                    <Button Content="刷新" Padding="12,6" Margin="8,0,0,0" Command="{Binding ReloadCommand}" />
                </StackPanel>
            </DockPanel>

            <DataGrid Grid.Row="1" Margin="0,0,0,8" ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#FAFAFA">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="选择" Width="50" CanUserResize="False" CanUserReorder="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center"
                                          IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                          AutomationProperties.Name="勾选此券参与批量操作" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="券码" Binding="{Binding Code}" Width="140" />
                    <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="160" />
                    <DataGridTextColumn Header="类型" Binding="{Binding Kind}" Width="90" />
                    <DataGridTextColumn Header="平台" Binding="{Binding Platform}" Width="90" />
                    <DataGridTextColumn Header="面值" Binding="{Binding FaceValue, StringFormat='¥{0:F2}'}" Width="90" />
                    <DataGridTextColumn Header="最低消费" Binding="{Binding MinOrderAmount, StringFormat='¥{0:F2}'}" Width="100" />
                    <DataGridTextColumn Header="折扣%" Binding="{Binding DiscountPercent}" Width="70" />
                    <DataGridTextColumn Header="有效期至" Binding="{Binding ExpiresAt, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110" />
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80" />
                    <DataGridTemplateColumn Header="操作" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Margin="2" Padding="6,2" Content="作废" Background="#D9534F" Foreground="White" BorderThickness="0"
                                        Command="{Binding DataContext.CancelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <DockPanel Grid.Row="2" Margin="0,4,0,0">
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#666"
                           Text="{Binding PageDisplay}"
                           AutomationProperties.Name="分页状态" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="每页" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#666" />
                    <ComboBox SelectedItem="{Binding PageSize, Mode=TwoWay}"
                              ItemsSource="{Binding PageSizeOptions}"
                              Width="70" Height="28"
                              AutomationProperties.Name="每页条数" />
                    <Button Content="上一页" Padding="10,4" Margin="8,0,0,0"
                            Command="{Binding PrevPageAsyncCommand}"
                            IsEnabled="{Binding CanGoPrev}"
                            AutomationProperties.Name="上一页" />
                    <Button Content="下一页" Padding="10,4" Margin="6,0,0,0"
                            Command="{Binding NextPageAsyncCommand}"
                            IsEnabled="{Binding CanGoNext}"
                            AutomationProperties.Name="下一页" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
