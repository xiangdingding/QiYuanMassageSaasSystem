<UserControl x:Class="MassageSaas.Cs.Views.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  工具条：显示已停用 + 新建项目（对齐 BS）  -->
            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <CheckBox DockPanel.Dock="Left"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="显示已停用"
                          Content="显示已停用"
                          IsChecked="{Binding IncludeInactive}" />
                <Button DockPanel.Dock="Right"
                        HorizontalAlignment="Right"
                        Padding="16,0"
                        AutomationProperties.Name="新建项目"
                        Command="{Binding CreateCommand}"
                        Content="新建项目"
                        Style="{StaticResource PrimaryBtn}" />
            </DockPanel>

            <DataGrid Grid.Row="1"
                      AlternatingRowBackground="#FAFAFA"
                      AutoGenerateColumns="False"
                      AutomationProperties.Name="服务项目列表"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      ItemsSource="{Binding Rows}">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="60" Binding="{Binding Sort}" Header="排序" />
                    <DataGridTextColumn Width="100" Binding="{Binding Code}" Header="编码" />
                    <DataGridTextColumn Width="*" MinWidth="220" Binding="{Binding Name}" Header="名称" />
                    <DataGridTextColumn Width="90" Binding="{Binding DurationMinutes, StringFormat='{}{0} 分钟'}" Header="时长" />
                    <DataGridTextColumn Width="100" Binding="{Binding Price, StringFormat='¥{0:F2}'}" Header="原价" />
                    <DataGridTextColumn Width="100" Binding="{Binding MemberPrice, StringFormat='¥{0:F2}'}" Header="会员价" />
                    <DataGridTextColumn Width="70" Binding="{Binding IsActive, Converter={StaticResource BoolLabel}, ConverterParameter='启用|停用'}" Header="状态" />
                    <DataGridTemplateColumn Width="180" Header="操作">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button AutomationProperties.Name="编辑服务项目"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Content="编辑"
                                            Style="{StaticResource RowGhost}" />
                                    <Button AutomationProperties.Name="停用或启用服务项目"
                                            Command="{Binding DataContext.ToggleActiveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding IsActive, Converter={StaticResource BoolLabel}, ConverterParameter='停用|启用'}"
                                            Style="{StaticResource RowGhost}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
