<Window x:Class="MassageSaas.Cs.Views.RoomFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls"
        Title="新建房间"
        Height="500" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <!--  左侧标签：右对齐、垂直居中、不换行（对齐 BS 端 el-form label-width）  -->
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#374151" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="20">
        <Border DockPanel.Dock="Bottom" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="20,0" Margin="0,0,8,0"
                        Style="{StaticResource GhostBtn}" Click="Cancel_Click"
                        AutomationProperties.Name="取消" />
                <Button Content="保存" Padding="20,0"
                        Style="{StaticResource PrimaryBtn}" Click="Save_Click"
                        AutomationProperties.Name="保存" />
            </StackPanel>
        </Border>

        <StackPanel>
            <!--  各行两列：标签 110 + 字段 *（对齐 BS 端 el-form）  -->

            <!--  房间号  -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource FormLabel}">
                    <Run Foreground="#D9534F" Text="* " /><Run Text="房间号" />
                </TextBlock>
                <TextBox x:Name="RoomNoBox" Grid.Column="1" MaxLength="32"
                         Style="{StaticResource FieldText}" Tag="如 01 / VIP-1"
                         AutomationProperties.Name="房间号" />
            </Grid>

            <!--  容客（人）  -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource FormLabel}">
                    <Run Foreground="#D9534F" Text="* " /><Run Text="容客（人）" />
                </TextBlock>
                <ctrl:NumericUpDown x:Name="CapacityBox" Grid.Column="1" HorizontalAlignment="Left"
                                    Width="150" Value="1" Minimum="1" Maximum="20" Step="1" Decimals="0"
                                    AutomationProperties.Name="容客人数" />
            </Grid>

            <!--  类型（可编辑、可清空）  -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="类型" Style="{StaticResource FormLabel}" />
                <ComboBox x:Name="TypeBox" Grid.Column="1"
                          Style="{StaticResource FieldComboEditable}"
                          AutomationProperties.Name="房间类型">
                    <ComboBoxItem Content="标准间" />
                    <ComboBoxItem Content="VIP" />
                    <ComboBoxItem Content="情侣间" />
                </ComboBox>
            </Grid>

            <!--  计时房（开关 + 说明）  -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="计时房" Style="{StaticResource FormLabel}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ToggleButton x:Name="TimedBox" VerticalAlignment="Center"
                                  Style="{StaticResource SwitchToggle}"
                                  AutomationProperties.Name="计时房"
                                  AutomationProperties.HelpText="按停留时长计费，而非按服务项目" />
                    <TextBlock Text="按停留时长计费，而非按服务项目" Foreground="#999" FontSize="12"
                               VerticalAlignment="Center" Margin="10,0,0,0" />
                </StackPanel>
            </Grid>

            <!--  小时单价（仅计时房）  -->
            <Grid x:Name="HourlyRow" Margin="0,0,0,14"
                  Visibility="{Binding IsChecked, ElementName=TimedBox, Converter={StaticResource BoolToVisible}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource FormLabel}">
                    <Run Foreground="#D9534F" Text="* " /><Run Text="小时单价" />
                </TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ctrl:NumericUpDown x:Name="HourlyRateBox" Width="170"
                                        Value="0" Minimum="0" Maximum="100000" Step="10" Decimals="2"
                                        AutomationProperties.Name="小时单价" />
                    <TextBlock Text="元/时" Foreground="#999" FontSize="12"
                               VerticalAlignment="Center" Margin="10,0,0,0" />
                </StackPanel>
            </Grid>

            <!--  备注  -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="备注" Style="{StaticResource FormLabel}" VerticalAlignment="Top" Margin="0,7,12,0" />
                <TextBox x:Name="RemarkBox" Grid.Column="1" MaxLength="500" Height="64"
                         Style="{StaticResource FieldTextMultiline}"
                         AutomationProperties.Name="备注" />
            </Grid>

            <!--  启用（仅编辑时）  -->
            <Grid x:Name="ActiveRow" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="启用" Style="{StaticResource FormLabel}" />
                <ToggleButton x:Name="ActiveBox" Grid.Column="1" HorizontalAlignment="Left" IsChecked="True"
                              Style="{StaticResource SwitchToggle}"
                              AutomationProperties.Name="启用" />
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
