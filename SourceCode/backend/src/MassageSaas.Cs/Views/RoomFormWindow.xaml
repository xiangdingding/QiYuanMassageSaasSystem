<Window x:Class="MassageSaas.Cs.Views.RoomFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="房间"
        Height="380" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="房间号" Margin="0,0,0,4" />
        <TextBox Grid.Row="1" x:Name="RoomNoBox" Padding="6" Margin="0,0,0,12" />

        <TextBlock Grid.Row="2" Text="容客（人）" Margin="0,0,0,4" />
        <TextBox Grid.Row="3" x:Name="CapacityBox" Padding="6" Margin="0,0,0,12" Text="1" />

        <TextBlock Grid.Row="4" Text="类型（可选）" Margin="0,0,0,4" />
        <ComboBox Grid.Row="5" x:Name="TypeBox" Padding="6" Margin="0,0,0,12" IsEditable="True">
            <ComboBoxItem Content="标准间" />
            <ComboBoxItem Content="VIP" />
            <ComboBoxItem Content="情侣间" />
        </ComboBox>

        <TextBlock Grid.Row="6" Text="备注" Margin="0,0,0,4" />
        <TextBox Grid.Row="7" x:Name="RemarkBox" Padding="6" Margin="0,0,0,12" />

        <CheckBox Grid.Row="8" x:Name="ActiveBox" Content="启用" IsChecked="True" />

        <Border Grid.Row="10" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="保存" Padding="16,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
