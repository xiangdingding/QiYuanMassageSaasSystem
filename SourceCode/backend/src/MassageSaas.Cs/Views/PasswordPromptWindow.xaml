<Window x:Class="MassageSaas.Cs.Views.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置密码"
        Height="320" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock x:Name="HintBlock" Margin="0,0,0,12" FontWeight="SemiBold" TextWrapping="Wrap" />

        <TextBlock Text="新密码（至少 6 位）" Foreground="#606266" Margin="0,0,0,4" />
        <PasswordBox x:Name="Pwd1" Margin="0,0,0,10" Style="{StaticResource FieldPassword}" AutomationProperties.Name="新密码" />

        <TextBlock Text="确认新密码" Foreground="#606266" Margin="0,0,0,4" />
        <PasswordBox x:Name="Pwd2" Margin="0,0,0,8" Style="{StaticResource FieldPassword}" AutomationProperties.Name="确认新密码" />

        <TextBlock x:Name="ErrBlock" Foreground="#D9534F" Margin="0,0,0,4" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="取消" Padding="20,0" Margin="0,0,8,0" AutomationProperties.Name="取消" Click="Cancel_Click" Style="{StaticResource GhostBtn}" />
            <Button Content="确定" Padding="20,0" AutomationProperties.Name="确定" Click="Ok_Click" Style="{StaticResource PrimaryBtn}" />
        </StackPanel>
    </StackPanel>
</Window>
