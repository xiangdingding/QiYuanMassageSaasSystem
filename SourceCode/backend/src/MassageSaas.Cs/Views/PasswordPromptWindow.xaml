<Window x:Class="MassageSaas.Cs.Views.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置密码"
        Height="220" Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock x:Name="HintBlock" Margin="0,0,0,8" />
        <PasswordBox x:Name="Pwd1" Padding="6" Margin="0,0,0,8" />
        <PasswordBox x:Name="Pwd2" Padding="6" Margin="0,0,0,8" />
        <TextBlock x:Name="ErrBlock" Foreground="#D9534F" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="确定" Padding="16,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Click="Ok_Click" />
        </StackPanel>
    </StackPanel>
</Window>
