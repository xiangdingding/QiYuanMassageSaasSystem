<Window x:Class="MassageSaas.Cs.Views.MemberHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="会员流水"
        Height="560" Width="820"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="16">
        <TextBlock x:Name="HeaderText" DockPanel.Dock="Top" FontWeight="Bold" FontSize="15" Margin="0,0,0,10" />
        <TabControl>
            <TabItem Header="资金流水">
                <DataGrid x:Name="RechargeGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                          AutomationProperties.Name="资金流水">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="类型" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border HorizontalAlignment="Left" CornerRadius="3" Padding="6,1" Background="#F4F4F5">
                                        <TextBlock FontSize="12"
                                                   Foreground="{Binding Kind, Converter={StaticResource RechargeKindBrush}}"
                                                   Text="{Binding Kind, Converter={StaticResource EnumLabel}}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="金额" Binding="{Binding Amount, StringFormat='¥{0:F2}'}" Width="100" />
                        <DataGridTextColumn Header="赠送" Binding="{Binding BonusAmount, StringFormat='¥{0:F2}'}" Width="90" />
                        <DataGridTextColumn Header="后余额" Binding="{Binding BalanceAfter, StringFormat='¥{0:F2}'}" Width="100" />
                        <DataGridTextColumn Header="支付" Binding="{Binding PayMethod, Converter={StaticResource EnumLabel}}" Width="80" />
                        <DataGridTextColumn Header="对手会员" Binding="{Binding CounterpartyMemberName}" Width="120" />
                        <DataGridTextColumn Header="操作人" Binding="{Binding OperatorName}" Width="100" />
                        <DataGridTextColumn Header="时间" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="消费记录">
                <DataGrid x:Name="ConsumeGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                          AutomationProperties.Name="消费记录">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="订单号" Binding="{Binding OrderNo}" Width="180" />
                        <DataGridTextColumn Header="合计" Binding="{Binding Total, StringFormat='¥{0:F2}'}" Width="100" />
                        <DataGridTextColumn Header="实收" Binding="{Binding PaidAmount, StringFormat='¥{0:F2}'}" Width="100" />
                        <DataGridTextColumn Header="支付" Binding="{Binding PayMethod, Converter={StaticResource EnumLabel}}" Width="80" />
                        <DataGridTextColumn Header="状态" Binding="{Binding Status, Converter={StaticResource EnumLabel}}" Width="90" />
                        <DataGridTextColumn Header="时间" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
