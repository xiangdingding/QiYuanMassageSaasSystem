<Window x:Class="MassageSaas.Cs.Views.ReviewCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="代客录入评价"
        Height="640" Width="660"
        MinHeight="520" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 选技师 + 日期 + 查询 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="技师" VerticalAlignment="Center" Margin="0,0,6,0" />
            <ComboBox x:Name="TechBox" Width="220" Height="30"
                      DisplayMemberPath="Display" SelectedValuePath="Id"
                      AutomationProperties.Name="选择服务技师" />
            <TextBlock Text="日期" VerticalAlignment="Center" Margin="14,0,6,0" />
            <DatePicker x:Name="DateBox" Width="140" Height="30"
                        AutomationProperties.Name="服务日期" />
            <Button Content="查询订单" Margin="14,0,0,0" Padding="12,4" Click="Query_Click"
                    AutomationProperties.Name="按技师和日期查询已完成服务"
                    AutomationProperties.HelpText="列出该技师当日已完成的服务项供选择" />
        </StackPanel>

        <!-- 已完成服务项：单选一行 -->
        <DataGrid Grid.Row="1" x:Name="ItemsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False" SelectionMode="Single"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#FAFAFA" Margin="0,0,0,10"
                  AutomationProperties.Name="已完成服务项列表，选中一行作为评价对象">
            <DataGrid.Columns>
                <DataGridTextColumn Header="订单号" Binding="{Binding OrderNo}" Width="150" />
                <DataGridTextColumn Header="服务" Binding="{Binding ServiceName}" Width="120" />
                <DataGridTextColumn Header="完成时间" Binding="{Binding CompletedAt, StringFormat='{}{0:MM-dd HH:mm}'}" Width="110" />
                <DataGridTextColumn Header="会员" Binding="{Binding MemberName}" Width="110" />
                <DataGridCheckBoxColumn Header="已评价" Binding="{Binding HasReview}" Width="70" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- 评分 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="评分" VerticalAlignment="Center" Margin="0,0,6,0" />
            <ComboBox x:Name="RatingBox" Width="110" Height="30"
                      AutomationProperties.Name="评分星级，一到五星">
                <ComboBoxItem Content="5 星" Tag="5" />
                <ComboBoxItem Content="4 星" Tag="4" />
                <ComboBoxItem Content="3 星" Tag="3" />
                <ComboBoxItem Content="2 星" Tag="2" />
                <ComboBoxItem Content="1 星" Tag="1" />
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="标签（逗号分隔，如：手法专业,态度好）" Margin="0,0,0,4" />
            <TextBox x:Name="TagsBox" Padding="6" MaxLength="200"
                     AutomationProperties.Name="评价标签" />
        </StackPanel>
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="评论（可空）" Margin="0,0,0,4" />
            <TextBox x:Name="CommentBox" Padding="6" Height="72"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" MaxLength="500"
                     AutomationProperties.Name="评论内容" />
        </StackPanel>

        <Border Grid.Row="5" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click" />
                <Button Content="提交评价" Padding="16,6" Background="#2D6A4F" Foreground="White"
                        BorderThickness="0" Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
