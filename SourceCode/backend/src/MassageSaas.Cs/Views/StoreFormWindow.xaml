<Window x:Class="MassageSaas.Cs.Views.StoreFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="门店"
        Height="540" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#606266" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="20">
        <Border DockPanel.Dock="Bottom" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="20,0" Margin="0,0,8,0" AutomationProperties.Name="取消" Click="Cancel_Click" Style="{StaticResource GhostBtn}" />
                <Button Content="保存" Padding="20,0" AutomationProperties.Name="保存" Click="Save_Click" Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </Border>

        <StackPanel>
            <TextBlock Text="名称" Style="{StaticResource FL}" />
            <TextBox x:Name="NameBox" Margin="0,0,0,12" Style="{StaticResource FieldText}" AutomationProperties.Name="门店名称" />

            <TextBlock Text="地址" Style="{StaticResource FL}" />
            <TextBox x:Name="AddressBox" Margin="0,0,0,12" Style="{StaticResource FieldText}" AutomationProperties.Name="门店地址" />

            <TextBlock Text="电话" Style="{StaticResource FL}" />
            <TextBox x:Name="PhoneBox" Margin="0,0,0,12" Style="{StaticResource FieldText}" AutomationProperties.Name="门店电话" />

            <!--  所属总店：仅新建分店时显示，下拉选总店  -->
            <StackPanel x:Name="ParentPanel">
                <TextBlock Text="所属总店" Style="{StaticResource FL}" />
                <ComboBox x:Name="ParentBox" Margin="0,0,0,12"
                          Style="{StaticResource FilterCombo}" SelectedValuePath="Id"
                          AutomationProperties.Name="所属总店">
                    <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!--  状态：仅编辑时显示  -->
            <StackPanel x:Name="StatusPanel">
                <TextBlock Text="状态（开为营业中，关为停业）" Style="{StaticResource FL}" />
                <ToggleButton x:Name="ActiveBox" Content="营业中" IsChecked="True" Margin="0,0,0,12"
                              Style="{StaticResource SwitchToggle}" AutomationProperties.Name="状态" />
            </StackPanel>

            <TextBlock Text="营业日切日时间 (HH:mm，北京时间)" Style="{StaticResource FL}" />
            <TextBox x:Name="CutoffBox" Text="00:00" Style="{StaticResource FieldText}" AutomationProperties.Name="营业日切日时间" />
            <TextBlock Text="0:00=自然日切日。营业到凌晨的门店建议设置在停业之后，如 06:00。"
                       Foreground="#909399" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>
    </DockPanel>
</Window>
