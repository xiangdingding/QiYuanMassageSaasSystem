<Window x:Class="MassageSaas.Cs.Views.StoreFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="门店"
        Height="500" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="名称" Margin="0,0,0,4" />
        <TextBox Grid.Row="1" x:Name="NameBox" Padding="6" Margin="0,0,0,12" />

        <TextBlock Grid.Row="2" Text="地址" Margin="0,0,0,4" />
        <TextBox Grid.Row="3" x:Name="AddressBox" Padding="6" Margin="0,0,0,12" />

        <TextBlock Grid.Row="4" Text="电话" Margin="0,0,0,4" />
        <TextBox Grid.Row="5" x:Name="PhoneBox" Padding="6" Margin="0,0,0,12" />

        <TextBlock Grid.Row="6" Text="所属总店 ID（仅新建分店时填写）" Margin="0,0,0,4" />
        <TextBox Grid.Row="7" x:Name="ParentBox" Padding="6" Margin="0,0,0,12" />

        <CheckBox Grid.Row="8" x:Name="ActiveBox" Content="启用" IsChecked="True" />

        <StackPanel Grid.Row="9" Margin="0,12,0,0">
            <TextBlock Text="营业日切日时间 (HH:mm，北京时间)" Margin="0,0,0,4" />
            <TextBox x:Name="CutoffBox" Padding="6" Text="00:00" />
            <TextBlock Text="0:00=自然日切日。营业到凌晨的门店建议设置在停业之后，如 06:00。"
                       Foreground="#666" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="10" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="保存" Padding="16,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
