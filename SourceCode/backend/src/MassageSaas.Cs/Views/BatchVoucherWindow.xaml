<Window x:Class="MassageSaas.Cs.Views.BatchVoucherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls"
        Title="批量生成优惠券"
        Width="540"
        Height="720"
        MinHeight="560"
        MinWidth="500"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="Cap" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="Row" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  表单区  -->
        <ScrollViewer Grid.Row="0" x:Name="FormScroll" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FormPanel">
                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="类型" /></TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <RadioButton x:Name="KindStore" AutomationProperties.Name="店内券"
                                     BorderThickness="1,1,1,1" Content="店内券" GroupName="BatchKind"
                                     IsChecked="True" Style="{StaticResource SegRadio}" Tag="6,0,0,6" />
                        <RadioButton x:Name="KindGroup" AutomationProperties.Name="团购券"
                                     Content="团购券" GroupName="BatchKind"
                                     Style="{StaticResource SegRadio}" Tag="0,6,6,0" />
                    </StackPanel>
                </Grid>

                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="数量" /></TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ctrl:NumericUpDown x:Name="CountBox" Width="150" HorizontalAlignment="Left"
                                            AutomationProperties.Name="生成数量，1 到 500"
                                            Decimals="0" Maximum="500" Minimum="1" Step="10" Value="100" />
                        <TextBlock Style="{StaticResource Hint}" Text="1-500 张" />
                    </StackPanel>
                </Grid>

                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="标题" /></TextBlock>
                    <TextBox x:Name="TitleBox" Grid.Column="1" MaxLength="200"
                             AutomationProperties.Name="标题" Style="{StaticResource FieldText}"
                             Tag="如：团购 100 元抵扣券" />
                </Grid>

                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="抵扣方式" /></TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <RadioButton x:Name="ModeFaceRadio" AutomationProperties.Name="按满减面值抵扣"
                                     BorderThickness="1,1,1,1" Content="满减面值" GroupName="BatchMode"
                                     IsChecked="True" Style="{StaticResource SegRadio}" Tag="6,0,0,6" />
                        <RadioButton x:Name="ModePercentRadio" AutomationProperties.Name="按折扣率抵扣"
                                     Content="折扣率" GroupName="BatchMode"
                                     Style="{StaticResource SegRadio}" Tag="0,6,6,0" />
                        <TextBlock Style="{StaticResource Hint}" Text="二选一" />
                    </StackPanel>
                </Grid>

                <Grid Style="{StaticResource Row}" Visibility="{Binding ElementName=ModeFaceRadio, Path=IsChecked, Converter={StaticResource BoolToVisible}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="面值" /></TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ctrl:NumericUpDown x:Name="FaceBox" Width="150" HorizontalAlignment="Left"
                                            AutomationProperties.Name="面值"
                                            Decimals="2" Maximum="999999" Minimum="0" Step="10" Value="100" />
                        <TextBlock Style="{StaticResource Hint}" Text="元，每张抵扣此金额" />
                    </StackPanel>
                </Grid>

                <Grid Style="{StaticResource Row}" Visibility="{Binding ElementName=ModePercentRadio, Path=IsChecked, Converter={StaticResource BoolToVisible}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="折扣率" /></TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ctrl:NumericUpDown x:Name="DiscountBox" Width="150" HorizontalAlignment="Left"
                                            AutomationProperties.Name="折扣率"
                                            Decimals="2" Maximum="0.99" Minimum="0.1" Step="0.05" Value="0.9" />
                        <TextBlock Style="{StaticResource Hint}" Text="0.9 表示 9 折" />
                    </StackPanel>
                </Grid>

                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Cap}" Text="最低订单额" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ctrl:NumericUpDown x:Name="MinBox" Width="150" HorizontalAlignment="Left"
                                            AutomationProperties.Name="最低订单额"
                                            Decimals="2" Maximum="999999" Minimum="0" Step="10" Value="100" />
                        <TextBlock Style="{StaticResource Hint}" Text="元，订单需达到才能使用" />
                    </StackPanel>
                </Grid>

                <Grid Style="{StaticResource Row}" Visibility="{Binding ElementName=KindGroup, Path=IsChecked, Converter={StaticResource BoolToVisible}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Cap}" Text="平台" />
                    <TextBox x:Name="PlatformBox" Grid.Column="1" MaxLength="64"
                             AutomationProperties.Name="来源平台"
                             Style="{StaticResource FieldText}"
                             Tag="Meituan / Dianping / Douyin" />
                </Grid>

                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Cap}" Text="生效起" />
                    <DatePicker x:Name="FromBox" Grid.Column="1" AutomationProperties.Name="生效日期" />
                    <TextBlock Grid.Column="2" Margin="12,0,8,0" VerticalAlignment="Center" Foreground="#666" Text="到期" />
                    <DatePicker x:Name="ExpiryBox" Grid.Column="3" AutomationProperties.Name="到期日期" />
                </Grid>

                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Margin="0,7,10,0" VerticalAlignment="Top" Style="{StaticResource Cap}" Text="备注" />
                    <TextBox x:Name="RemarkBox" Grid.Column="1" Height="52" MaxLength="500"
                             AutomationProperties.Name="备注" Style="{StaticResource FieldTextMultiline}" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!--  结果区  -->
        <Border Grid.Row="0" x:Name="ResultPanel"
                Background="#F6FBF7"
                BorderBrush="#D4E9D8"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock x:Name="ResultHeader" DockPanel.Dock="Left"
                               VerticalAlignment="Center" FontSize="13" Foreground="#2D6A4F" />
                    <Button DockPanel.Dock="Right" Padding="14,0"
                            AutomationProperties.Name="复制全部生成的券码到剪贴板"
                            Click="Copy_Click" Content="复制全部" Style="{StaticResource PrimaryBtn}" />
                </DockPanel>
                <TextBox Grid.Row="1" x:Name="CodesBox"
                         AcceptsReturn="True"
                         AutomationProperties.Name="生成的券码列表，每行一个"
                         FontFamily="Consolas, Courier New"
                         FontSize="12"
                         HorizontalScrollBarVisibility="Auto"
                         IsReadOnly="True"
                         MinHeight="280"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,0" Padding="0,12,0,0"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Margin="0,0,8,0" Padding="20,0"
                        AutomationProperties.Name="关闭"
                        Click="Close_Click" Content="关闭" Style="{StaticResource GhostBtn}" />
                <Button x:Name="GenerateButton" Padding="20,0"
                        AutomationProperties.Name="生成"
                        Click="Generate_Click" Content="生成" Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
