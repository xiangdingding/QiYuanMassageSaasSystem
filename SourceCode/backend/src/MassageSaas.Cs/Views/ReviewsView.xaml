<UserControl x:Class="MassageSaas.Cs.Views.ReviewsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls">
    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock DockPanel.Dock="Left" Text="服务评价" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="评价" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox SelectedIndex="{Binding RatingFilter, Mode=TwoWay}" Width="120" Height="30"
                              AutomationProperties.Name="按满意度筛选">
                        <ComboBoxItem Content="全部" />
                        <ComboBoxItem Content="非常满意" />
                        <ComboBoxItem Content="满意" />
                        <ComboBoxItem Content="一般" />
                        <ComboBoxItem Content="不满意" />
                        <ComboBoxItem Content="非常不满意" />
                    </ComboBox>
                    <TextBlock Text="天数" VerticalAlignment="Center" Margin="12,0,6,0" />
                    <TextBox Text="{Binding Days, UpdateSourceTrigger=PropertyChanged}" Width="56" Height="30"
                             AutomationProperties.Name="统计天数" />
                    <Button Content="代客录入" Padding="12,6" Margin="12,0,0,0"
                            Background="#2D6A4F" Foreground="White" BorderThickness="0"
                            Command="{Binding CreateCommand}"
                            AutomationProperties.Name="代客录入服务评价"
                            AutomationProperties.HelpText="选技师和日期，挑出已完成的服务项打分" />
                    <Button Content="刷新" Padding="12,6" Margin="8,0,0,0" Command="{Binding ReloadCommand}" />
                </StackPanel>
            </DockPanel>

            <!-- 技师均分汇总 -->
            <Border Grid.Row="1" Background="#F0F7F4" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                <DataGrid ItemsSource="{Binding Summary}" AutoGenerateColumns="False" MaxHeight="160"
                          CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                          GridLinesVisibility="All" Background="Transparent">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="技师" Binding="{Binding TechnicianName}" Width="*" MinWidth="200" />
                        <DataGridTextColumn Header="评价数" Binding="{Binding ReviewCount}" Width="100" />
                        <DataGridTextColumn Header="平均分" Binding="{Binding AverageRating, StringFormat='{}{0:F2}'}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <DataGrid Grid.Row="2" ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="All"
                      AlternatingRowBackground="#FAFAFA">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="时间" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="150" />
                    <DataGridTextColumn Header="技师" Binding="{Binding TechnicianName}" Width="140" />
                    <DataGridTextColumn Header="评分" Binding="{Binding Rating, StringFormat='{}{0} 星'}" Width="80" />
                    <DataGridTextColumn Header="服务评价" Binding="{Binding Rating, Converter={StaticResource RatingToText}}" Width="100" />
                    <DataGridTextColumn Header="会员" Binding="{Binding MemberName}" Width="120" />
                    <DataGridTextColumn Header="标签" Binding="{Binding Tags}" Width="160" />
                    <DataGridTextColumn Header="评价内容" Binding="{Binding Comment}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- 分页（评分明细，BS 端订单流水同款样式） -->
            <ctrl:PaginationBar Grid.Row="3" Margin="0,8,0,0"
                                Total="{Binding Total}"
                                Page="{Binding Page, Mode=TwoWay}"
                                PageSize="{Binding PageSize, Mode=TwoWay}"
                                PageChangedCommand="{Binding ReloadCommand}" />
        </Grid>
    </Border>
</UserControl>
