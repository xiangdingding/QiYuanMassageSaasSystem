<Window x:Class="MassageSaas.Cs.Views.SalaryProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls"
        Title="薪资档案"
        Height="540" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="UserLabel" FontWeight="SemiBold" Margin="0,0,0,12" />

        <TextBlock Grid.Row="1" Text="月底薪" Margin="0,0,0,4" Foreground="#606266" />
        <ctrl:NumericUpDown Grid.Row="2" x:Name="BaseBox" Width="200" HorizontalAlignment="Left" Margin="0,0,0,12"
                            Decimals="2" Minimum="0" Maximum="1000000" Step="100" AutomationProperties.Name="月底薪" />

        <TextBlock Grid.Row="3" Text="加班时薪" Margin="0,0,0,4" Foreground="#606266" />
        <ctrl:NumericUpDown Grid.Row="4" x:Name="OtRateBox" Width="200" HorizontalAlignment="Left" Margin="0,0,0,12"
                            Decimals="2" Minimum="0" Maximum="10000" Step="5" AutomationProperties.Name="加班时薪" />

        <TextBlock Grid.Row="5" Text="满勤奖额度" Margin="0,0,0,4" Foreground="#606266" />
        <ctrl:NumericUpDown Grid.Row="6" x:Name="BonusBox" Width="200" HorizontalAlignment="Left" Margin="0,0,0,12"
                            Decimals="2" Minimum="0" Maximum="100000" Step="50" AutomationProperties.Name="满勤奖额度" />

        <TextBlock Grid.Row="7" Text="满勤所需出勤天数（0 = 按当月自然天数）" Margin="0,0,0,4" Foreground="#606266" />
        <ctrl:NumericUpDown Grid.Row="8" x:Name="DaysBox" Width="200" HorizontalAlignment="Left" Margin="0,0,0,12"
                            Decimals="0" Minimum="0" Maximum="31" Step="1" AutomationProperties.Name="满勤所需出勤天数" />

        <TextBlock Grid.Row="9" Text="备注" Margin="0,0,0,4" Foreground="#606266" />
        <TextBox Grid.Row="10" x:Name="RemarkBox" Height="56" VerticalAlignment="Top" Style="{StaticResource FieldTextMultiline}" AutomationProperties.Name="备注" />

        <Border Grid.Row="11" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="20,0" Margin="0,0,8,0" AutomationProperties.Name="取消" Click="Cancel_Click" Style="{StaticResource GhostBtn}" />
                <Button Content="保存" Padding="20,0" AutomationProperties.Name="保存" Click="Save_Click" Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
