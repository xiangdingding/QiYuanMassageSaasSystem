<Window x:Class="MassageSaas.Cs.Views.SalaryProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="薪资档案"
        Height="480" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="UserLabel" FontWeight="SemiBold" Margin="0,0,0,12" />

        <TextBlock Grid.Row="1" Text="月底薪" Margin="0,0,0,4" />
        <TextBox Grid.Row="2" x:Name="BaseBox" Padding="6" Margin="0,0,0,12" Text="0" />

        <TextBlock Grid.Row="3" Text="加班时薪" Margin="0,0,0,4" />
        <TextBox Grid.Row="4" x:Name="OtRateBox" Padding="6" Margin="0,0,0,12" Text="0" />

        <TextBlock Grid.Row="5" Text="满勤奖额度" Margin="0,0,0,4" />
        <TextBox Grid.Row="6" x:Name="BonusBox" Padding="6" Margin="0,0,0,12" Text="0" />

        <TextBlock Grid.Row="7" Text="满勤所需出勤天数（0 = 按当月自然天数）" Margin="0,0,0,4" />
        <TextBox Grid.Row="8" x:Name="DaysBox" Padding="6" Margin="0,0,0,12" Text="0" />

        <TextBlock Grid.Row="9" Text="备注" Margin="0,0,0,4" />
        <TextBox Grid.Row="10" x:Name="RemarkBox" Padding="6" Height="56" TextWrapping="Wrap" AcceptsReturn="True" VerticalAlignment="Top" />

        <Border Grid.Row="11" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="保存" Padding="16,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
