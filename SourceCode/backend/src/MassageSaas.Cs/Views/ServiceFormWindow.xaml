<Window x:Class="MassageSaas.Cs.Views.ServiceFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls"
        Title="服务项目"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="Cap" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="Row" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="20">
        <Border Margin="0,12,0,0"
                Padding="0,12,0,0"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Margin="0,0,8,0"
                        Padding="20,0"
                        AutomationProperties.Name="取消"
                        Click="Cancel_Click"
                        Content="取消"
                        Style="{StaticResource GhostBtn}" />
                <Button Padding="20,0"
                        AutomationProperties.Name="保存"
                        Click="Save_Click"
                        Content="保存"
                        Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </Border>

        <StackPanel>
            <!--  编码  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="编码" /></TextBlock>
                <TextBox x:Name="CodeBox" Grid.Column="1" MaxLength="32"
                         AutomationProperties.Name="编码" Style="{StaticResource FieldText}" />
            </Grid>

            <!--  名称  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="名称" /></TextBlock>
                <TextBox x:Name="NameBox" Grid.Column="1" MaxLength="64"
                         AutomationProperties.Name="名称" Style="{StaticResource FieldText}" />
            </Grid>

            <!--  时长  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="时长(分钟)" /></TextBlock>
                <ctrl:NumericUpDown x:Name="DurationBox" Grid.Column="1"
                                    Width="150" HorizontalAlignment="Left"
                                    AutomationProperties.Name="时长（分钟）"
                                    Decimals="0" Maximum="600" Minimum="1" Step="1" Value="60" />
            </Grid>

            <!--  原价  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="原价" /></TextBlock>
                <ctrl:NumericUpDown x:Name="PriceBox" Grid.Column="1"
                                    Width="150" HorizontalAlignment="Left"
                                    AutomationProperties.Name="原价"
                                    Decimals="2" Maximum="999999" Minimum="0" Step="10" Value="0" />
            </Grid>

            <!--  会员价  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="会员价" /></TextBlock>
                <ctrl:NumericUpDown x:Name="MemberPriceBox" Grid.Column="1"
                                    Width="150" HorizontalAlignment="Left"
                                    AutomationProperties.Name="会员价"
                                    Decimals="2" Maximum="999999" Minimum="0" Step="10" Value="0" />
            </Grid>

            <!--  说明  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Margin="0,7,10,0" VerticalAlignment="Top" Style="{StaticResource Cap}" Text="说明" />
                <TextBox x:Name="DescBox" Grid.Column="1" Height="52" MaxLength="200"
                         AutomationProperties.Name="说明" Style="{StaticResource FieldTextMultiline}" />
            </Grid>

            <!--  启用  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}" Text="启用" />
                <ToggleButton x:Name="ActiveBox" Grid.Column="1"
                              VerticalAlignment="Center"
                              AutomationProperties.Name="启用该服务项目"
                              IsChecked="True"
                              Style="{StaticResource SwitchToggle}" />
            </Grid>

            <!--  排序  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}" Text="排序" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ctrl:NumericUpDown x:Name="SortBox"
                                        Width="150" HorizontalAlignment="Left"
                                        AutomationProperties.Name="排序"
                                        Decimals="0" Maximum="999" Minimum="0" Step="1" Value="0" />
                    <TextBlock Style="{StaticResource Hint}" Text="值越小越靠前" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
