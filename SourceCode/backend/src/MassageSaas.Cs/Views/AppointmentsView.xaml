<UserControl x:Class="MassageSaas.Cs.Views.AppointmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls">
    <UserControl.Resources>
        <!-- 圆角下拉框：白底描边、悬停/展开绿边、右侧灰色小箭头 -->
        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="Toggle" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="White" BorderBrush="#D1D5DB"
                                                BorderThickness="1" CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="26" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="10,0,0,0" VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="#9CA3AF" StrokeThickness="1.4"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide">
                                <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6"
                                        Margin="0,4,0,0" SnapsToDevicePixels="True"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                    <ScrollViewer MaxHeight="260">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 圆角搜索框：带占位提示（用 Tag 设置），聚焦时绿边 -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                                <TextBlock x:Name="ph" Text="{TemplateBinding Tag}" Foreground="#9CA3AF"
                                           Margin="11,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                           Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="ph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主操作按钮（查询 / 登记）：绿底圆角 -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="#2D6A4F" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#245A41" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#9CC3B0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次操作按钮（重置）：白底描边圆角，悬停绿边 -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="#D1D5DB"
                                BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F3F4F6" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 行内操作按钮（小号圆角，对齐 BS 列表按钮） -->
        <Style x:Key="RowPrimary" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2D6A4F" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#245A41" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RowGhost" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="#D1D5DB"
                                BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F3F4F6" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RowDanger" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#D9534F" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#C9302C" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                <!-- 右：主操作 -->
                <Button DockPanel.Dock="Right" Content="登记电话预约" Padding="16,0"
                        Style="{StaticResource PrimaryBtn}" Command="{Binding RegisterCommand}"
                        AutomationProperties.Name="登记电话预约" />
                <!-- 左：筛选条件 -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="状态" VerticalAlignment="Center" Foreground="#6B7280" FontSize="13" Margin="0,0,6,0" />
                    <ComboBox Width="120" Style="{StaticResource FilterCombo}"
                              SelectedValuePath="Tag" SelectedValue="{Binding StatusFilter}"
                              AutomationProperties.Name="按状态筛选">
                        <ComboBoxItem Content="全部" Tag="" />
                        <ComboBoxItem Content="待确认" Tag="Pending" />
                        <ComboBoxItem Content="已确认" Tag="Confirmed" />
                        <ComboBoxItem Content="已到店" Tag="Arrived" />
                        <ComboBoxItem Content="已完成" Tag="Completed" />
                        <ComboBoxItem Content="已取消" Tag="Cancelled" />
                        <ComboBoxItem Content="未到店" Tag="NoShow" />
                    </ComboBox>
                    <TextBox Width="220" Margin="10,0,0,0" Style="{StaticResource SearchBox}"
                             Tag="会员姓名 / 电话"
                             Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="搜索"
                             AutomationProperties.HelpText="按会员姓名或电话搜索，回车查询">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <TextBlock Text="从" VerticalAlignment="Center" Foreground="#6B7280" FontSize="13" Margin="12,0,6,0" />
                    <DatePicker Width="170" Height="34" VerticalContentAlignment="Center"
                                SelectedDate="{Binding FromDate}" AutomationProperties.Name="开始日期"
                                PreviewMouseLeftButtonUp="DatePicker_PreviewMouseUp" />
                    <TextBlock Text="至" VerticalAlignment="Center" Foreground="#6B7280" FontSize="13" Margin="8,0,6,0" />
                    <DatePicker Width="170" Height="34" VerticalContentAlignment="Center"
                                SelectedDate="{Binding ToDate}" AutomationProperties.Name="结束日期"
                                PreviewMouseLeftButtonUp="DatePicker_PreviewMouseUp" />
                    <Button Content="查询" Padding="16,0" Margin="12,0,0,0"
                            Style="{StaticResource PrimaryBtn}" Command="{Binding SearchCommand}"
                            AutomationProperties.Name="查询" />
                    <Button Content="重置" Padding="16,0" Margin="8,0,0,0"
                            Style="{StaticResource GhostBtn}" Command="{Binding ResetQueryCommand}"
                            AutomationProperties.Name="重置筛选" />
                </StackPanel>
            </DockPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                      RowHeight="48" FontSize="13" GridLinesVisibility="All"
                      VerticalGridLinesBrush="#ECEFF2" HorizontalGridLinesBrush="#ECEFF2"
                      AutomationProperties.Name="预约列表">
                <!-- 列头扁平加高样式已在 App.xaml 全局隐式声明，所有 DataGrid 自动套用 -->
                <!-- 单元格垂直居中样式已在 App.xaml 全局声明，所有 DataGrid 自动套用 -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="AutomationProperties.Name">
                            <Setter.Value>
                                <MultiBinding StringFormat="{}{0:yyyy-MM-dd HH:mm:ss} 到店，{1}，{2}，{3} 人，{4}">
                                    <Binding Path="ExpectedArriveAt" />
                                    <Binding Path="CustomerName" />
                                    <Binding Path="CustomerPhone" />
                                    <Binding Path="PartySize" />
                                    <Binding Path="StatusLabel" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="到店时间" Binding="{Binding ExpectedArriveAt, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="160" />
                    <DataGridTextColumn Header="姓名" Binding="{Binding CustomerName}" Width="120" />
                    <DataGridTextColumn Header="电话" Binding="{Binding CustomerPhone}" Width="130" />
                    <DataGridTextColumn Header="人数" Binding="{Binding PartySize}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="Margin" Value="0,0,8,0" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="服务" Binding="{Binding ServiceName}" Width="160" />
                    <DataGridTextColumn Header="指定技师" Binding="{Binding PreferredTechnicianName}" Width="140" />
                    <DataGridTextColumn Header="状态" Binding="{Binding StatusLabel}" Width="80" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="*" MinWidth="180" />
                    <DataGridTemplateColumn Header="操作" Width="300">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="确认" Style="{StaticResource RowPrimary}"
                                            Visibility="{Binding CanConfirm, Converter={StaticResource BoolToVisible}}"
                                            Command="{Binding DataContext.ConfirmCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" AutomationProperties.Name="确认预约" />
                                    <Button Content="修改" Style="{StaticResource RowGhost}"
                                            Visibility="{Binding CanEdit, Converter={StaticResource BoolToVisible}}"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" AutomationProperties.Name="修改预约" />
                                    <Button Content="到店" Style="{StaticResource RowPrimary}"
                                            Visibility="{Binding CanArrive, Converter={StaticResource BoolToVisible}}"
                                            Command="{Binding DataContext.ArriveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" AutomationProperties.Name="标记到店" />
                                    <Button Content="取消" Style="{StaticResource RowDanger}"
                                            Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisible}}"
                                            Command="{Binding DataContext.CancelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" AutomationProperties.Name="取消预约" />
                                    <Button Content="再次预约" Style="{StaticResource RowPrimary}"
                                            Visibility="{Binding CanRebook, Converter={StaticResource BoolToVisible}}"
                                            Command="{Binding DataContext.RebookCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" AutomationProperties.Name="再次预约" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 分页（BS 端订单流水同款样式） -->
            <ctrl:PaginationBar Grid.Row="2" Margin="0,8,0,0"
                                Total="{Binding Total}"
                                Page="{Binding Page, Mode=TwoWay}"
                                PageSize="{Binding PageSize, Mode=TwoWay}"
                                PageChangedCommand="{Binding ReloadCommand}" />
        </Grid>
    </Border>
</UserControl>
