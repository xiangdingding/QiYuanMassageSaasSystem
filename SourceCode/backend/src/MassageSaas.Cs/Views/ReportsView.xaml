<UserControl x:Class="MassageSaas.Cs.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls">
    <UserControl.Resources>
        <!--  指标卡（对齐 BS .metric 卡片）：白底圆角描边，居中文字  -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#EBEEF5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style x:Key="MLabel" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#909399" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="MValue" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#2D6A4F" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
        <Style x:Key="MSub" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#909399" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </UserControl.Resources>

    <TabControl>

        <!--  日报（对齐 BS：指标卡 + 按支付方式表）  -->
        <TabItem Header="日报">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <DatePicker Width="200"
                                        AutomationProperties.Name="日报日期"
                                        SelectedDate="{Binding Date}" />
                            <Button Margin="8,0,0,0"
                                    Padding="16,0"
                                    AutomationProperties.Name="查询日报"
                                    Command="{Binding ReloadCommand}"
                                    Content="查询"
                                    Style="{StaticResource PrimaryBtn}" />
                        </StackPanel>

                        <StackPanel Margin="0,16,0,0" Visibility="{Binding Daily, Converter={StaticResource NullToCollapsed}}">
                            <!--  四张指标卡：营业额 / 退款 / 充值入账 / 净收入  -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Margin="0,0,6,0"
                                        Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MLabel}" Text="营业额" />
                                        <TextBlock Style="{StaticResource MValue}"><Run Text="¥" /><Run Text="{Binding Daily.Revenue, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                                        <TextBlock Style="{StaticResource MSub}"><Run Text="订单 " /><Run Text="{Binding Daily.OrderCount, Mode=OneWay}" /><Run Text=" 单" /></TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1"
                                        Margin="6,0,6,0"
                                        Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MLabel}" Text="退款" />
                                        <TextBlock Style="{StaticResource MValue}"><Run Text="¥" /><Run Text="{Binding Daily.RefundAmount, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                                        <TextBlock Style="{StaticResource MSub}"><Run Text="退款 " /><Run Text="{Binding Daily.RefundCount, Mode=OneWay}" /><Run Text=" 单" /></TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2"
                                        Margin="6,0,6,0"
                                        Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MLabel}" Text="充值入账" />
                                        <TextBlock Style="{StaticResource MValue}"><Run Text="¥" /><Run Text="{Binding Daily.MemberRechargeAmount, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                                        <TextBlock Style="{StaticResource MSub}"><Run Text="充值 " /><Run Text="{Binding Daily.MemberRechargeCount, Mode=OneWay}" /><Run Text=" 笔" /></TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3"
                                        Margin="6,0,0,0"
                                        Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MLabel}" Text="净收入" />
                                        <TextBlock Style="{StaticResource MValue}"><Run Text="¥" /><Run Text="{Binding DailyNetIncome, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                                        <TextBlock Style="{StaticResource MSub}" Text="营业额 - 退款" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!--  按支付方式  -->
                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    Background="White"
                                    BorderBrush="#EBEEF5"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,8"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Text="按支付方式" />
                                    <DataGrid AutoGenerateColumns="False"
                                              AutomationProperties.Name="按支付方式明细"
                                              CanUserAddRows="False"
                                              HeadersVisibility="Column"
                                              IsReadOnly="True"
                                              ItemsSource="{Binding DailyPayRows}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Width="*"
                                                                Binding="{Binding Label}"
                                                                Header="支付方式" />
                                            <DataGridTextColumn Width="160"
                                                                Binding="{Binding Amount, StringFormat='¥{0:F2}'}"
                                                                Header="金额" />
                                            <DataGridTextColumn Width="120"
                                                                Binding="{Binding PercentText}"
                                                                Header="占比" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </TabItem>

        <!--  技师业绩  -->
        <TabItem Header="技师业绩">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,12"
                                Orientation="Horizontal">
                        <DatePicker Width="160"
                                    AutomationProperties.Name="起始日期"
                                    SelectedDate="{Binding FromDate}" />
                        <TextBlock VerticalAlignment="Center" Text=" ~ " />
                        <DatePicker Width="160"
                                    AutomationProperties.Name="结束日期"
                                    SelectedDate="{Binding ToDate}" />
                        <Button Margin="8,0,0,0"
                                Padding="16,0"
                                AutomationProperties.Name="查询技师业绩"
                                Command="{Binding ReloadCommand}"
                                Content="查询"
                                Style="{StaticResource PrimaryBtn}" />
                    </StackPanel>
                    <DataGrid Grid.Row="1"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              AutomationProperties.Name="技师业绩列表"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Performance}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="60"
                                                Binding="{Binding EmployeeNo}"
                                                Header="工号" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="140"
                                                Binding="{Binding TechnicianName}"
                                                Header="技师" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding OrderItemCount}"
                                                Header="服务次数" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding TotalServiceAmount, StringFormat='¥{0:F2}'}"
                                                Header="服务金额" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding TotalCommission, StringFormat='¥{0:F2}'}"
                                                Header="提成" />
                            <DataGridTextColumn Width="90"
                                                Binding="{Binding TotalDurationMinutes}"
                                                Header="时长(分钟)" />
                            <DataGridTextColumn Width="90"
                                                Binding="{Binding DesignationCount}"
                                                Header="点钟次数" />
                            <DataGridTextColumn Width="90"
                                                Binding="{Binding RotationCount}"
                                                Header="轮钟次数" />
                            <DataGridTextColumn Width="90"
                                                Binding="{Binding DesignationRate, StringFormat='{}{0:P1}', TargetNullValue='—'}"
                                                Header="指定率" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

        <!--  月报  -->
        <TabItem Header="月报">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,12"
                                Orientation="Horizontal">
                        <DatePicker Width="200"
                                    AutomationProperties.Name="月报月份，选择该月任意一天"
                                    SelectedDate="{Binding MonthlyMonth}" />
                        <Button Margin="8,0,0,0"
                                Padding="16,0"
                                AutomationProperties.Name="查询月报"
                                Command="{Binding LoadMonthlyCommand}"
                                Content="查询"
                                Style="{StaticResource PrimaryBtn}" />
                    </StackPanel>
                    <Border Grid.Row="1"
                            Margin="0,0,0,12"
                            Padding="12"
                            Background="#F8FAFC"
                            CornerRadius="4">
                        <TextBlock DataContext="{Binding Monthly}" FontSize="14">
                            <Run Text="{Binding Year, Mode=OneWay}" /><Run Text="-" /><Run Text="{Binding Month, Mode=OneWay}" />
                            <Run Text="  营业额 ¥" /><Run Text="{Binding Revenue, StringFormat='F2', Mode=OneWay}" />
                            <Run Text="  订单 " /><Run Text="{Binding OrderCount, Mode=OneWay}" />
                            <Run Text="  钟数 " /><Run Text="{Binding RoundsCount, Mode=OneWay}" />
                            <Run Text="  充值 ¥" /><Run Text="{Binding RechargeAmount, StringFormat='F2', Mode=OneWay}" />
                            <Run Text="  客单价 ¥" /><Run Text="{Binding AverageOrder, StringFormat='F2', Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                    <DataGrid Grid.Row="2"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              AutomationProperties.Name="月报每日明细"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Monthly.Daily}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="*"
                                                MinWidth="140"
                                                Binding="{Binding Day, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                Header="日期" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding OrderCount}"
                                                Header="订单" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding Revenue, StringFormat='¥{0:F2}'}"
                                                Header="营业额" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding Rounds}"
                                                Header="钟数" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

        <!--  年报  -->
        <TabItem Header="年报">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,12"
                                Orientation="Horizontal">
                        <DatePicker Width="200"
                                    AutomationProperties.Name="年报年份，选择该年任意一天"
                                    SelectedDate="{Binding YearlyYear}" />
                        <Button Margin="8,0,0,0"
                                Padding="16,0"
                                AutomationProperties.Name="查询年报"
                                Command="{Binding LoadYearlyCommand}"
                                Content="查询"
                                Style="{StaticResource PrimaryBtn}" />
                    </StackPanel>
                    <Border Grid.Row="1"
                            Margin="0,0,0,12"
                            Padding="12"
                            Background="#F8FAFC"
                            CornerRadius="4">
                        <TextBlock DataContext="{Binding Yearly}" FontSize="14">
                            <Run Text="{Binding Year, Mode=OneWay}" /><Run Text=" 年" />
                            <Run Text="  营业额 ¥" /><Run Text="{Binding Revenue, StringFormat='F2', Mode=OneWay}" />
                            <Run Text="  订单 " /><Run Text="{Binding OrderCount, Mode=OneWay}" />
                            <Run Text="  钟数 " /><Run Text="{Binding RoundsCount, Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                    <DataGrid Grid.Row="2"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              AutomationProperties.Name="年报每月明细"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Yearly.Monthly}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="*"
                                                MinWidth="140"
                                                Binding="{Binding Day, StringFormat='{}{0:yyyy-MM}'}"
                                                Header="月份" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding OrderCount}"
                                                Header="订单" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding Revenue, StringFormat='¥{0:F2}'}"
                                                Header="营业额" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding Rounds}"
                                                Header="钟数" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

        <!--  服务热度  -->
        <TabItem Header="服务热度">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,12"
                                Orientation="Horizontal">
                        <DatePicker Width="160"
                                    AutomationProperties.Name="起始日期"
                                    SelectedDate="{Binding RangeFrom}" />
                        <TextBlock VerticalAlignment="Center" Text=" ~ " />
                        <DatePicker Width="160"
                                    AutomationProperties.Name="结束日期"
                                    SelectedDate="{Binding RangeTo}" />
                        <Button Margin="8,0,0,0"
                                Padding="16,0"
                                AutomationProperties.Name="查询服务热度"
                                Command="{Binding LoadPopularityCommand}"
                                Content="查询"
                                Style="{StaticResource PrimaryBtn}" />
                    </StackPanel>
                    <DataGrid Grid.Row="1"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              AutomationProperties.Name="服务热度列表"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Popularity}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="*"
                                                MinWidth="200"
                                                Binding="{Binding ServiceName}"
                                                Header="服务" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding OrderItemCount}"
                                                Header="下单次数" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding RoundsCount}"
                                                Header="钟数合计" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding Revenue, StringFormat='¥{0:F2}'}"
                                                Header="营业额" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

        <!--  客流  -->
        <TabItem Header="客流">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,12"
                                Orientation="Horizontal">
                        <DatePicker Width="160"
                                    AutomationProperties.Name="起始日期"
                                    SelectedDate="{Binding RangeFrom}" />
                        <TextBlock VerticalAlignment="Center" Text=" ~ " />
                        <DatePicker Width="160"
                                    AutomationProperties.Name="结束日期"
                                    SelectedDate="{Binding RangeTo}" />
                        <Button Margin="8,0,0,0"
                                Padding="16,0"
                                AutomationProperties.Name="查询客流"
                                Command="{Binding LoadFlowCommand}"
                                Content="查询"
                                Style="{StaticResource PrimaryBtn}" />
                    </StackPanel>
                    <DataGrid Grid.Row="1"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              AutomationProperties.Name="客流列表"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding CustomerFlow}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="*"
                                                MinWidth="160"
                                                Binding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                Header="日期" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding OrderCount}"
                                                Header="订单数" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding UniqueMembers}"
                                                Header="唯一会员" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

        <!--  会员分析  -->
        <TabItem Header="会员分析">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <StackPanel>
                    <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                        <Button Padding="16,0"
                                AutomationProperties.Name="刷新会员分析"
                                Command="{Binding LoadMemberAnalysisCommand}"
                                Content="刷新"
                                Style="{StaticResource PrimaryBtn}" />
                    </StackPanel>
                    <StackPanel DataContext="{Binding MemberAnalysis}" Visibility="{Binding Converter={StaticResource NullToCollapsed}}">
                        <!--  第一行：会员总数 / 活跃 / 沉睡 / 流失  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MLabel}" Text="会员总数" />
                                    <TextBlock Style="{StaticResource MValue}" Text="{Binding TotalMembers, Mode=OneWay}" />
                                    <TextBlock Style="{StaticResource MSub}"><Run Text="本月新增 " /><Run Text="{Binding NewMembersThisMonth, Mode=OneWay}" /></TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1"
                                    Margin="6,0,6,0"
                                    Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MLabel}" Text="活跃 · 30 天内消费" />
                                    <TextBlock Style="{StaticResource MValue}" Text="{Binding ActiveMembers, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2"
                                    Margin="6,0,6,0"
                                    Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MLabel}" Text="沉睡 · 31-90 天" />
                                    <TextBlock Style="{StaticResource MValue}" Text="{Binding DormantMembers, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3"
                                    Margin="6,0,0,0"
                                    Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MLabel}" Text="流失 · 超 90 天" />
                                    <TextBlock Style="{StaticResource MValue}" Text="{Binding LostMembers, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!--  第二行：从未消费 / 复购会员 / 复购率  -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MLabel}" Text="从未消费" />
                                    <TextBlock Style="{StaticResource MValue}" Text="{Binding NeverConsumed, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1"
                                    Margin="6,0,6,0"
                                    Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MLabel}" Text="复购会员 · 累计 ≥2 单" />
                                    <TextBlock Style="{StaticResource MValue}" Text="{Binding RepeatMembers, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2"
                                    Margin="6,0,0,0"
                                    Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MLabel}" Text="复购率" />
                                    <TextBlock Style="{StaticResource MValue}"><Run Text="{Binding RepeatRate, Mode=OneWay}" /><Run Text="%" /></TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </TabItem>

        <!--  服务趋势  -->
        <TabItem Header="服务趋势">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,12"
                                Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" Text="趋势月数：" />
                        <ctrl:NumericUpDown Width="120"
                                            AutomationProperties.Name="趋势月数"
                                            Decimals="0"
                                            Maximum="36"
                                            Minimum="1"
                                            Step="1"
                                            Value="{Binding TrendMonths, Mode=TwoWay}" />
                        <Button Margin="8,0,0,0"
                                Padding="16,0"
                                AutomationProperties.Name="查询服务趋势"
                                Command="{Binding LoadServiceTrendCommand}"
                                Content="查询"
                                Style="{StaticResource PrimaryBtn}" />
                    </StackPanel>
                    <DataGrid Grid.Row="1"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              AutomationProperties.Name="服务趋势列表"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding ServiceTrendRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="160"
                                                Binding="{Binding ServiceName}"
                                                Header="服务" />
                            <DataGridTextColumn Width="90"
                                                Binding="{Binding TotalRounds}"
                                                Header="总钟数" />
                            <DataGridTextColumn Width="*"
                                                Binding="{Binding MonthsText}"
                                                Header="逐月钟数" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

        <!--  技师质量  -->
        <TabItem Header="技师质量">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,12"
                                Orientation="Horizontal">
                        <DatePicker Width="160"
                                    AutomationProperties.Name="起始日期"
                                    SelectedDate="{Binding RangeFrom}" />
                        <TextBlock VerticalAlignment="Center" Text=" ~ " />
                        <DatePicker Width="160"
                                    AutomationProperties.Name="结束日期"
                                    SelectedDate="{Binding RangeTo}" />
                        <Button Margin="8,0,0,0"
                                Padding="16,0"
                                AutomationProperties.Name="查询技师质量"
                                Command="{Binding LoadQualityCommand}"
                                Content="查询"
                                Style="{StaticResource PrimaryBtn}" />
                    </StackPanel>
                    <DataGrid Grid.Row="1"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              AutomationProperties.Name="技师质量列表"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Quality}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="70"
                                                Binding="{Binding EmployeeNo}"
                                                Header="工号" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="140"
                                                Binding="{Binding TechnicianName}"
                                                Header="技师" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding RoundCount}"
                                                Header="钟数" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding ComplaintCount}"
                                                Header="投诉数" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding ComplaintRate, StringFormat='{}{0}%'}"
                                                Header="投诉率">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Foreground" Value="{Binding ComplaintRate, Converter={StaticResource ComplaintRateToBrush}}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

        <!--  收益导出（收益报表 / 收益明细 Excel，可按年/月/区间）  -->
        <TabItem Header="收益导出">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <StackPanel MaxWidth="640" HorizontalAlignment="Left">
                    <TextBlock Margin="0,0,0,4"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="收益导出" />
                    <TextBlock Margin="0,0,0,12"
                               Foreground="#909399"
                               Text="导出当前门店的收益报表（汇总）与收益明细（逐笔），支持按年 / 按月 / 自定义日期区间。" />

                    <!--  周期口径  -->
                    <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                        <TextBlock Width="80"
                                   VerticalAlignment="Center"
                                   Text="统计周期" />
                        <ComboBox Width="160"
                                  AutomationProperties.Name="统计周期口径"
                                  SelectedValue="{Binding ExportMode}"
                                  SelectedValuePath="Tag"
                                  Style="{StaticResource FilterCombo}">
                            <ComboBoxItem Content="按月" Tag="month" />
                            <ComboBoxItem Content="按年" Tag="year" />
                            <ComboBoxItem Content="日期区间" Tag="range" />
                        </ComboBox>
                    </StackPanel>

                    <!--  按月  -->
                    <StackPanel Margin="0,0,0,12"
                                Orientation="Horizontal"
                                Visibility="{Binding IsMonthMode, Converter={StaticResource BoolToVisible}}">
                        <TextBlock Width="80"
                                   VerticalAlignment="Center"
                                   Text="选择月份" />
                        <DatePicker Width="200"
                                    AutomationProperties.Name="导出月份（取所选日期所在月）"
                                    SelectedDate="{Binding ExportMonth}"
                                    Style="{StaticResource FilterDatePicker}" />
                        <TextBlock Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#909399"
                                   Text="取该日所在整月" />
                    </StackPanel>

                    <!--  按年  -->
                    <StackPanel Margin="0,0,0,12"
                                Orientation="Horizontal"
                                Visibility="{Binding IsYearMode, Converter={StaticResource BoolToVisible}}">
                        <TextBlock Width="80"
                                   VerticalAlignment="Center"
                                   Text="选择年份" />
                        <DatePicker Width="200"
                                    AutomationProperties.Name="导出年份（取所选日期所在年）"
                                    SelectedDate="{Binding ExportYear}"
                                    Style="{StaticResource FilterDatePicker}" />
                        <TextBlock Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#909399"
                                   Text="取该日所在整年" />
                    </StackPanel>

                    <!--  日期区间  -->
                    <StackPanel Margin="0,0,0,12"
                                Orientation="Horizontal"
                                Visibility="{Binding IsRangeMode, Converter={StaticResource BoolToVisible}}">
                        <TextBlock Width="80"
                                   VerticalAlignment="Center"
                                   Text="日期区间" />
                        <DatePicker Width="160"
                                    AutomationProperties.Name="导出起始日期"
                                    SelectedDate="{Binding ExportFrom}"
                                    Style="{StaticResource FilterDatePicker}" />
                        <TextBlock VerticalAlignment="Center" Text=" ~ " />
                        <DatePicker Width="160"
                                    AutomationProperties.Name="导出结束日期"
                                    SelectedDate="{Binding ExportTo}"
                                    Style="{StaticResource FilterDatePicker}" />
                    </StackPanel>

                    <!--  导出按钮  -->
                    <StackPanel Margin="80,8,0,0" Orientation="Horizontal">
                        <Button Padding="16,0"
                                AutomationProperties.Name="导出收益报表"
                                Command="{Binding ExportRevenueReportCommand}"
                                Content="导出收益报表"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource BoolInverse}}"
                                Style="{StaticResource PrimaryBtn}" />
                        <Button Margin="12,0,0,0"
                                Padding="16,0"
                                AutomationProperties.Name="导出收益明细"
                                Command="{Binding ExportRevenueDetailCommand}"
                                Content="导出收益明细"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource BoolInverse}}"
                                Style="{StaticResource GhostBtn}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </TabItem>

    </TabControl>
</UserControl>
