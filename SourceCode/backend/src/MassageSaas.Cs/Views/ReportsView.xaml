<UserControl x:Class="MassageSaas.Cs.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TabControl Background="Transparent" BorderThickness="0">

        <!--  日报  -->
        <TabItem Header="日报">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock VerticalAlignment="Center"
                                   DockPanel.Dock="Left"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="日报" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="日期：" />
                            <DatePicker Width="150" SelectedDate="{Binding Date}" />
                            <Button Margin="8,0,0,0"
                                    Padding="12,6"
                                    Command="{Binding ReloadCommand}"
                                    Content="查询" />
                        </StackPanel>
                    </DockPanel>
                    <Border Padding="12"
                            Background="#F8FAFC"
                            CornerRadius="4">
                        <StackPanel DataContext="{Binding Daily}">
                            <TextBlock Margin="0,0,0,4"
                                       FontSize="14"
                                       FontWeight="SemiBold">
                                <Run Text="当日订单：" /><Run Text="{Binding OrderCount, Mode=OneWay}" />
                                <Run Text="    营业额：¥" /><Run Text="{Binding Revenue, StringFormat='F2', Mode=OneWay}" />
                            </TextBlock>
                            <UniformGrid Columns="5">
                                <TextBlock><Run Text="现金 ¥" /><Run Text="{Binding CashAmount, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                                <TextBlock><Run Text="会员 ¥" /><Run Text="{Binding MemberCardAmount, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                                <TextBlock><Run Text="微信 ¥" /><Run Text="{Binding WechatAmount, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                                <TextBlock><Run Text="支付宝 ¥" /><Run Text="{Binding AlipayAmount, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                                <TextBlock><Run Text="银行卡 ¥" /><Run Text="{Binding BankCardAmount, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                            </UniformGrid>
                            <TextBlock Margin="0,4,0,0">
                                <Run Text="退款 " /><Run Text="{Binding RefundCount, Mode=OneWay}" />
                                <Run Text="单 ¥" /><Run Text="{Binding RefundAmount, StringFormat='F2', Mode=OneWay}" />
                                <Run Text="    充值 " /><Run Text="{Binding MemberRechargeCount, Mode=OneWay}" />
                                <Run Text="单 ¥" /><Run Text="{Binding MemberRechargeAmount, StringFormat='F2', Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </TabItem>

        <!--  技师业绩  -->
        <TabItem Header="技师业绩">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock VerticalAlignment="Center"
                                   DockPanel.Dock="Left"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="技师业绩" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <DatePicker Width="130" SelectedDate="{Binding FromDate}" />
                            <TextBlock VerticalAlignment="Center" Text=" ~ " />
                            <DatePicker Width="130" SelectedDate="{Binding ToDate}" />
                            <Button Margin="8,0,0,0"
                                    Padding="12,6"
                                    Command="{Binding ReloadCommand}"
                                    Content="查询" />
                        </StackPanel>
                    </DockPanel>
                    <DataGrid Grid.Row="1"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Performance}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="60"
                                                Binding="{Binding EmployeeNo}"
                                                Header="工号" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding TechnicianName}"
                                                Header="技师" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding OrderItemCount}"
                                                Header="服务次数" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding TotalServiceAmount, StringFormat='¥{0:F2}'}"
                                                Header="服务金额" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding TotalCommission, StringFormat='¥{0:F2}'}"
                                                Header="提成" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding TotalDurationMinutes}"
                                                Header="时长(分钟)" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

        <!--  月报  -->
        <TabItem Header="月报">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock VerticalAlignment="Center"
                                   DockPanel.Dock="Left"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="月报" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="选择该月任意一天：" />
                            <DatePicker Width="150" SelectedDate="{Binding MonthlyMonth}" />
                            <Button Margin="8,0,0,0"
                                    Padding="12,6"
                                    Command="{Binding LoadMonthlyCommand}"
                                    Content="查询" />
                        </StackPanel>
                    </DockPanel>
                    <Border Grid.Row="1"
                            Margin="0,0,0,12"
                            Padding="12"
                            Background="#F8FAFC"
                            CornerRadius="4">
                        <TextBlock DataContext="{Binding Monthly}" FontSize="14">
                            <Run Text="{Binding Year, Mode=OneWay}" /><Run Text="-" /><Run Text="{Binding Month, Mode=OneWay}" />
                            <Run Text="  营业额 ¥" /><Run Text="{Binding Revenue, StringFormat='F2', Mode=OneWay}" />
                            <Run Text="  订单 " /><Run Text="{Binding OrderCount, Mode=OneWay}" />
                            <Run Text="  钟数 " /><Run Text="{Binding RoundsCount, Mode=OneWay}" />
                            <Run Text="  充值 ¥" /><Run Text="{Binding RechargeAmount, StringFormat='F2', Mode=OneWay}" />
                            <Run Text="  客单价 ¥" /><Run Text="{Binding AverageOrder, StringFormat='F2', Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                    <DataGrid Grid.Row="2"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Monthly.Daily}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding Day, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                Header="日期" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding OrderCount}"
                                                Header="订单" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding Revenue, StringFormat='¥{0:F2}'}"
                                                Header="营业额" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding Rounds}"
                                                Header="钟数" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

        <!--  年报  -->
        <TabItem Header="年报">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock VerticalAlignment="Center"
                                   DockPanel.Dock="Left"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="年报" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="选择该年任意一天：" />
                            <DatePicker Width="150" SelectedDate="{Binding YearlyYear}" />
                            <Button Margin="8,0,0,0"
                                    Padding="12,6"
                                    Command="{Binding LoadYearlyCommand}"
                                    Content="查询" />
                        </StackPanel>
                    </DockPanel>
                    <Border Grid.Row="1"
                            Margin="0,0,0,12"
                            Padding="12"
                            Background="#F8FAFC"
                            CornerRadius="4">
                        <TextBlock DataContext="{Binding Yearly}" FontSize="14">
                            <Run Text="{Binding Year, Mode=OneWay}" /><Run Text=" 年" />
                            <Run Text="  营业额 ¥" /><Run Text="{Binding Revenue, StringFormat='F2', Mode=OneWay}" />
                            <Run Text="  订单 " /><Run Text="{Binding OrderCount, Mode=OneWay}" />
                            <Run Text="  钟数 " /><Run Text="{Binding RoundsCount, Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                    <DataGrid Grid.Row="2"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Yearly.Monthly}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding Day, StringFormat='{}{0:yyyy-MM}'}"
                                                Header="月份" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding OrderCount}"
                                                Header="订单" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding Revenue, StringFormat='¥{0:F2}'}"
                                                Header="营业额" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding Rounds}"
                                                Header="钟数" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

        <!--  服务热度  -->
        <TabItem Header="服务热度">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock VerticalAlignment="Center"
                                   DockPanel.Dock="Left"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="服务热度" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <DatePicker Width="130" SelectedDate="{Binding RangeFrom}" />
                            <TextBlock VerticalAlignment="Center" Text=" ~ " />
                            <DatePicker Width="130" SelectedDate="{Binding RangeTo}" />
                            <Button Margin="8,0,0,0"
                                    Padding="12,6"
                                    Command="{Binding LoadPopularityCommand}"
                                    Content="查询" />
                        </StackPanel>
                    </DockPanel>
                    <DataGrid Grid.Row="1"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Popularity}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="200"
                                                Binding="{Binding ServiceName}"
                                                Header="服务" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding OrderItemCount}"
                                                Header="下单次数" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding RoundsCount}"
                                                Header="钟数合计" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding Revenue, StringFormat='¥{0:F2}'}"
                                                Header="营业额" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

        <!--  客流  -->
        <TabItem Header="客流">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock VerticalAlignment="Center"
                                   DockPanel.Dock="Left"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="客流" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <DatePicker Width="130" SelectedDate="{Binding RangeFrom}" />
                            <TextBlock VerticalAlignment="Center" Text=" ~ " />
                            <DatePicker Width="130" SelectedDate="{Binding RangeTo}" />
                            <Button Margin="8,0,0,0"
                                    Padding="12,6"
                                    Command="{Binding LoadFlowCommand}"
                                    Content="查询" />
                        </StackPanel>
                    </DockPanel>
                    <DataGrid Grid.Row="1"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding CustomerFlow}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="160"
                                                Binding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                Header="日期" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding OrderCount}"
                                                Header="订单数" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding UniqueMembers}"
                                                Header="唯一会员" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

        <!--  会员分析  -->
        <TabItem Header="会员分析">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock VerticalAlignment="Center"
                                   DockPanel.Dock="Left"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="会员分析" />
                        <Button Padding="12,6"
                                Command="{Binding LoadMemberAnalysisCommand}"
                                Content="刷新"
                                DockPanel.Dock="Right" />
                    </DockPanel>
                    <Border Padding="16"
                            Background="#F8FAFC"
                            CornerRadius="4">
                        <StackPanel DataContext="{Binding MemberAnalysis}">
                            <TextBlock Margin="0,0,0,8"
                                       FontSize="14"
                                       FontWeight="SemiBold">
                                <Run Text="会员总数 " /><Run Text="{Binding TotalMembers, Mode=OneWay}" />
                                <Run Text="    本月新增 " /><Run Text="{Binding NewMembersThisMonth, Mode=OneWay}" />
                            </TextBlock>
                            <UniformGrid Margin="0,0,0,8" Columns="4">
                                <TextBlock><Run Text="活跃(30天内) " /><Run Text="{Binding ActiveMembers, Mode=OneWay}" /></TextBlock>
                                <TextBlock><Run Text="沉睡(31-90天) " /><Run Text="{Binding DormantMembers, Mode=OneWay}" /></TextBlock>
                                <TextBlock><Run Text="流失(90天+) " /><Run Text="{Binding LostMembers, Mode=OneWay}" /></TextBlock>
                                <TextBlock><Run Text="从未消费 " /><Run Text="{Binding NeverConsumed, Mode=OneWay}" /></TextBlock>
                            </UniformGrid>
                            <TextBlock>
                                <Run Text="复购会员 " /><Run Text="{Binding RepeatMembers, Mode=OneWay}" />
                                <Run Text="    复购率 " /><Run Text="{Binding RepeatRate, Mode=OneWay}" /><Run Text="%" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </TabItem>

        <!--  服务趋势  -->
        <TabItem Header="服务趋势">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock VerticalAlignment="Center"
                                   DockPanel.Dock="Left"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="服务热度趋势" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="趋势月数：" />
                            <TextBox Width="56"
                                     Height="30"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding TrendMonths, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="8,0,0,0"
                                    Padding="12,6"
                                    Command="{Binding LoadServiceTrendCommand}"
                                    Content="查询" />
                        </StackPanel>
                    </DockPanel>
                    <DataGrid Grid.Row="1"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding ServiceTrendRows}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="160"
                                                Binding="{Binding ServiceName}"
                                                Header="服务" />
                            <DataGridTextColumn Width="90"
                                                Binding="{Binding TotalRounds}"
                                                Header="总钟数" />
                            <DataGridTextColumn Width="*"
                                                Binding="{Binding MonthsText}"
                                                Header="逐月钟数" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

        <!--  技师质量  -->
        <TabItem Header="技师质量">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock VerticalAlignment="Center"
                                   DockPanel.Dock="Left"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="技师质量（投诉率）" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <DatePicker Width="130" SelectedDate="{Binding RangeFrom}" />
                            <TextBlock VerticalAlignment="Center" Text=" ~ " />
                            <DatePicker Width="130" SelectedDate="{Binding RangeTo}" />
                            <Button Margin="8,0,0,0"
                                    Padding="12,6"
                                    Command="{Binding LoadQualityCommand}"
                                    Content="查询" />
                        </StackPanel>
                    </DockPanel>
                    <DataGrid Grid.Row="1"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Quality}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="70"
                                                Binding="{Binding EmployeeNo}"
                                                Header="工号" />
                            <DataGridTextColumn Width="140"
                                                Binding="{Binding TechnicianName}"
                                                Header="技师" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding RoundCount}"
                                                Header="钟数" />
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding ComplaintCount}"
                                                Header="投诉数" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding ComplaintRate}"
                                                Header="投诉率%" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>

    </TabControl>
</UserControl>
