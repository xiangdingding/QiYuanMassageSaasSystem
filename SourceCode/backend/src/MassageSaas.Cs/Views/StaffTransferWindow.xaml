<Window x:Class="MassageSaas.Cs.Views.StaffTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="跨店调动"
        Height="600" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <DockPanel Margin="20">
        <Border DockPanel.Dock="Bottom" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="确认调动" Padding="16,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Click="Confirm_Click" />
            </StackPanel>
        </Border>

        <StackPanel>
            <TextBlock x:Name="HeaderText" FontWeight="Bold" FontSize="15" Margin="0,0,0,12" />

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="当前门店" VerticalAlignment="Center" Foreground="#666" />
                <TextBlock Grid.Column="1" x:Name="CurrentStoreText" VerticalAlignment="Center" FontWeight="SemiBold" />
            </Grid>

            <TextBlock Text="调入门店" Margin="0,0,0,4" Foreground="#666" />
            <ComboBox x:Name="ToStoreBox" Height="34" Margin="0,0,0,10" VerticalContentAlignment="Center"
                      SelectedValuePath="Id" DisplayMemberPath="Name" AutomationProperties.Name="调入门店" />

            <TextBlock Text="调动类型" Margin="0,0,0,4" Foreground="#666" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton x:Name="KindPermanent" Content="永久调动" GroupName="Kind" IsChecked="True"
                             Checked="Kind_Changed" Margin="0,0,16,0" />
                <RadioButton x:Name="KindTemporary" Content="临时借调" GroupName="Kind" Checked="Kind_Changed" />
            </StackPanel>

            <StackPanel x:Name="ReturnPanel" Visibility="Collapsed" Margin="0,0,0,10">
                <TextBlock Text="预计归还日期" Margin="0,0,0,4" Foreground="#666" />
                <DatePicker x:Name="ReturnDatePicker" Width="200" HorizontalAlignment="Left" AutomationProperties.Name="预计归还日期" />
            </StackPanel>

            <TextBlock Text="原因" Margin="0,0,0,4" Foreground="#666" />
            <TextBox x:Name="ReasonBox" AutomationProperties.Name="调动原因" Height="44" Padding="6" Margin="0,0,0,10"
                     AcceptsReturn="True" TextWrapping="Wrap" MaxLength="500" />

            <Border Background="#FDF6EC" BorderBrush="#F5DAB1" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,12">
                <TextBlock Text="调动后该员工的叫号队列会迁到新店并置为下班，需在新店重新上钟。"
                           Foreground="#B88230" FontSize="12" TextWrapping="Wrap" />
            </Border>

            <TextBlock Text="调动历史" FontWeight="SemiBold" Margin="0,0,0,6"
                       Visibility="{Binding ElementName=HistoryGrid, Path=HasItems, Converter={StaticResource BoolToVisible}}" />
            <DataGrid x:Name="HistoryGrid" Height="150" AutoGenerateColumns="False" CanUserAddRows="False" RowHeight="34"
                      IsReadOnly="True" HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                      Visibility="{Binding ElementName=HistoryGrid, Path=HasItems, Converter={StaticResource BoolToVisible}}"
                      AutomationProperties.Name="调动历史">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="方向" Binding="{Binding Direction}" Width="*" />
                    <DataGridTextColumn Header="类型" Binding="{Binding KindLabel}" Width="70" />
                    <DataGridTextColumn Header="状态" Binding="{Binding StatusLabel}" Width="80" />
                    <DataGridTemplateColumn Header="操作" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="归还" Padding="8,2"
                                        Visibility="{Binding CanReturn, Converter={StaticResource BoolToVisible}}"
                                        Click="Return_Click" Tag="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </DockPanel>
</Window>
