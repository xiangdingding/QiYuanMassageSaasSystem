<Window x:Class="MassageSaas.Cs.Views.StaffTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="跨店调动"
        Width="580"
        Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="TfLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#606266" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="20">
        <Border Margin="0,12,0,0"
                Padding="0,12,0,0"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Margin="0,0,8,0"
                        Padding="20,0"
                        AutomationProperties.Name="取消"
                        Click="Cancel_Click"
                        Content="取消"
                        Style="{StaticResource GhostBtn}" />
                <Button Padding="20,0"
                        AutomationProperties.Name="确认调动"
                        Click="Confirm_Click"
                        Content="确认调动"
                        Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,4,0">
                <TextBlock x:Name="HeaderText"
                           Margin="0,0,0,12"
                           FontSize="15"
                           FontWeight="Bold" />

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="#606266"
                               Text="当前门店" />
                    <TextBlock x:Name="CurrentStoreText"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </Grid>

                <TextBlock Style="{StaticResource TfLabel}" Text="调入门店" />
                <ComboBox x:Name="ToStoreBox"
                          Margin="0,0,0,12"
                          AutomationProperties.Name="调入门店"
                          SelectedValuePath="Id"
                          Style="{StaticResource FilterCombo}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Style="{StaticResource TfLabel}" Text="调动类型" />
                <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                    <RadioButton x:Name="KindPermanent"
                                 AutomationProperties.Name="永久调动"
                                 BorderThickness="1,1,1,1"
                                 Checked="Kind_Changed"
                                 Content="永久调动"
                                 GroupName="Kind"
                                 IsChecked="True"
                                 Style="{StaticResource SegRadio}"
                                 Tag="4,0,0,4" />
                    <RadioButton x:Name="KindTemporary"
                                 AutomationProperties.Name="临时借调"
                                 Checked="Kind_Changed"
                                 Content="临时借调"
                                 GroupName="Kind"
                                 Style="{StaticResource SegRadio}"
                                 Tag="0,4,4,0" />
                </StackPanel>

                <StackPanel x:Name="ReturnPanel"
                            Margin="0,0,0,12"
                            Visibility="Collapsed">
                    <TextBlock Style="{StaticResource TfLabel}" Text="预计归还日期" />
                    <DatePicker x:Name="ReturnDatePicker"
                                Width="220"
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="预计归还日期"
                                SelectedDateFormat="Short"
                                Style="{StaticResource FilterDatePicker}" />
                </StackPanel>

                <TextBlock Style="{StaticResource TfLabel}" Text="原因" />
                <TextBox x:Name="ReasonBox"
                         Height="60"
                         Margin="0,0,0,12"
                         AutomationProperties.Name="调动原因"
                         MaxLength="500"
                         Style="{StaticResource FieldTextMultiline}" />

                <Border Margin="0,0,0,14"
                        Padding="10"
                        Background="#FDF6EC"
                        BorderBrush="#F5DAB1"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock FontSize="12"
                               Foreground="#B88230"
                               Text="调动后该员工的叫号队列会迁到新店并置为下班，需在新店重新上钟。"
                               TextWrapping="Wrap" />
                </Border>

                <TextBlock Margin="0,0,0,6"
                           FontWeight="SemiBold"
                           Text="调动历史"
                           Visibility="{Binding ElementName=HistoryGrid, Path=HasItems, Converter={StaticResource BoolToVisible}}" />
                <DataGrid x:Name="HistoryGrid"
                          Height="170"
                          AlternatingRowBackground="#FAFAFA"
                          AutoGenerateColumns="False"
                          AutomationProperties.Name="调动历史"
                          CanUserAddRows="False"
                          GridLinesVisibility="All"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          RowHeight="34"
                          Visibility="{Binding ElementName=HistoryGrid, Path=HasItems, Converter={StaticResource BoolToVisible}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="*"
                                            Binding="{Binding Direction}"
                                            Header="方向" />
                        <DataGridTextColumn Width="70"
                                            Binding="{Binding KindLabel}"
                                            Header="类型" />
                        <DataGridTextColumn Width="80"
                                            Binding="{Binding StatusLabel}"
                                            Header="状态" />
                        <DataGridTemplateColumn Width="90" Header="操作">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button AutomationProperties.Name="归还借调"
                                            Click="Return_Click"
                                            Content="归还"
                                            Style="{StaticResource RowPrimary}"
                                            Tag="{Binding}"
                                            Visibility="{Binding CanReturn, Converter={StaticResource BoolToVisible}}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
