<Window x:Class="MassageSaas.Cs.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="个人设置"
        Height="640" Width="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/AuthStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Margin="14" CornerRadius="12" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.18" Color="#000000" />
        </Border.Effect>

        <DockPanel>
            <!-- 标题栏 -->
            <Border DockPanel.Dock="Top" Height="52" CornerRadius="12,12,0,0" Background="White"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="24,0">
                    <TextBlock Text="个人设置" FontSize="17" FontWeight="Bold" Foreground="#1F2933"
                               VerticalAlignment="Center" />
                    <Button Style="{StaticResource WindowCloseButton}" Content="✕"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="Close_Click" ToolTip="关闭" AutomationProperties.Name="关闭窗口" />
                </Grid>
            </Border>

            <Border DockPanel.Dock="Bottom" Margin="24,0,24,18">
                <TextBlock x:Name="ErrorText" Foreground="#D9534F" FontSize="13" TextWrapping="Wrap" />
            </Border>

            <StackPanel Margin="24,4,24,8">
                <!-- 基本资料 -->
                <Border CornerRadius="10" Background="White" BorderBrush="#ECEEF1" BorderThickness="1"
                        Padding="18,16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="基本资料" FontSize="14" FontWeight="Bold" Foreground="#1F2933" Margin="0,0,0,14" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="登录账号" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="UsernameBox" Style="{StaticResource RoundedTextBox}"
                                         IsReadOnly="True" Background="#F5F7FA" Focusable="False"
                                         AutomationProperties.Name="登录账号" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="角色" Style="{StaticResource FieldLabel}" />
                                <TextBox x:Name="RoleBox" Style="{StaticResource RoundedTextBox}"
                                         IsReadOnly="True" Background="#F5F7FA" Focusable="False"
                                         AutomationProperties.Name="角色" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="姓名" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="RealNameBox" Style="{StaticResource RoundedTextBox}" MaxLength="32"
                                 Margin="0,0,0,12" AutomationProperties.Name="姓名"
                                 AutomationProperties.HelpText="您的真实姓名（可选）" />

                        <TextBlock Text="手机号" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="PhoneBox" Style="{StaticResource RoundedTextBox}" MaxLength="11"
                                 AutomationProperties.Name="手机号"
                                 AutomationProperties.HelpText="11 位手机号，用于登录" />

                        <Button x:Name="SaveProfileButton" Content="保存资料" Style="{StaticResource PrimaryButton}"
                                Width="120" HorizontalAlignment="Right" Margin="0,14,0,0"
                                Click="SaveProfile_Click" AutomationProperties.Name="保存资料" />
                    </StackPanel>
                </Border>

                <!-- 修改密码 -->
                <Border CornerRadius="10" Background="White" BorderBrush="#ECEEF1" BorderThickness="1"
                        Padding="18,16">
                    <StackPanel>
                        <TextBlock Text="修改密码" FontSize="14" FontWeight="Bold" Foreground="#1F2933" Margin="0,0,0,14" />

                        <TextBlock Text="原密码" Style="{StaticResource FieldLabel}" />
                        <PasswordBox x:Name="OldPwdBox" Style="{StaticResource RoundedPasswordBox}"
                                     Margin="0,0,0,12" AutomationProperties.Name="原密码" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="新密码（至少 6 位）" Style="{StaticResource FieldLabel}" />
                                <PasswordBox x:Name="NewPwdBox" Style="{StaticResource RoundedPasswordBox}"
                                             AutomationProperties.Name="新密码" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="确认新密码" Style="{StaticResource FieldLabel}" />
                                <PasswordBox x:Name="ConfirmPwdBox" Style="{StaticResource RoundedPasswordBox}"
                                             AutomationProperties.Name="确认新密码" />
                            </StackPanel>
                        </Grid>

                        <Button x:Name="SavePwdButton" Content="修改密码" Style="{StaticResource PrimaryButton}"
                                Width="120" HorizontalAlignment="Right" Margin="0,14,0,0"
                                Click="SavePassword_Click" AutomationProperties.Name="修改密码" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
