<UserControl x:Class="MassageSaas.Cs.Views.QueueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="技师排队看板" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Border Background="#E6F4EA" CornerRadius="3" Padding="8,3" Margin="0,0,6,0">
                        <TextBlock Foreground="#2D6A4F" FontSize="13"><Run Text="在岗 " /><Run Text="{Binding OnDutyCount, Mode=OneWay}" /></TextBlock>
                    </Border>
                    <Border Background="#FEF3C7" CornerRadius="3" Padding="8,3" Margin="0,0,6,0">
                        <TextBlock Foreground="#92400E" FontSize="13"><Run Text="休息 " /><Run Text="{Binding RestingCount, Mode=OneWay}" /></TextBlock>
                    </Border>
                    <Border Background="#F0F2F5" CornerRadius="3" Padding="8,3">
                        <TextBlock Foreground="#6B7280" FontSize="13"><Run Text="下班 " /><Run Text="{Binding OffDutyCount, Mode=OneWay}" /></TextBlock>
                    </Border>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Padding="16,0" Margin="0,0,8,0"
                            AutomationProperties.Name="叫下一个技师"
                            Command="{Binding CallNextCommand}"
                            Content="叫号"
                            Style="{StaticResource PrimaryBtn}"
                            Visibility="{Binding CanManage, Converter={StaticResource BoolToVisible}}" />
                    <Button Padding="16,0" Margin="0,0,8,0"
                            AutomationProperties.Name="刷新"
                            Command="{Binding ReloadCommand}"
                            Content="刷新"
                            Style="{StaticResource GhostBtn}" />
                    <Button Padding="16,0"
                            AutomationProperties.Name="重置今日排队"
                            Command="{Binding ResetDayCommand}"
                            Content="重置今日"
                            Style="{StaticResource GhostBtn}"
                            Visibility="{Binding CanManage, Converter={StaticResource BoolToVisible}}" />
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1" Background="#ECF5FF" CornerRadius="3" Padding="10" Margin="0,0,0,8"
                    Visibility="{Binding LastCalled, Converter={StaticResource NullToCollapsed}}">
                <TextBlock Text="{Binding LastCalled}" FontSize="14" Foreground="#1F5599" FontWeight="SemiBold" />
            </Border>

            <DataGrid Grid.Row="2" ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="All"
                      AlternatingRowBackground="#FAFAFA"
                      AutomationProperties.Name="技师排队列表">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="AutomationProperties.Name">
                            <Setter.Value>
                                <MultiBinding StringFormat="工号 {0}，{1}，{2}，今日 {3} 钟，排队号 {4}">
                                    <Binding Path="EmployeeNo" FallbackValue="无" />
                                    <Binding Path="TechnicianName" />
                                    <Binding Path="State" Converter="{StaticResource EnumLabel}" />
                                    <Binding Path="TodayRoundCount" />
                                    <Binding Path="QueuePosition" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="工号" Binding="{Binding EmployeeNo}" Width="60" />
                    <DataGridTextColumn Header="姓名" Binding="{Binding TechnicianName}" Width="*" MinWidth="120" />
                    <DataGridTextColumn Header="状态" Binding="{Binding State, Converter={StaticResource EnumLabel}}" Width="80" />
                    <DataGridTextColumn Header="排队号" Binding="{Binding QueuePosition}" Width="60" />
                    <DataGridTextColumn Header="今日轮次" Binding="{Binding TodayRoundCount}" Width="80" />
                    <DataGridTextColumn Header="进入时间" Binding="{Binding EnteredAt, StringFormat='HH:mm'}" Width="80" />
                    <DataGridTextColumn Header="最近叫号" Binding="{Binding LastCalledAt, StringFormat='HH:mm'}" Width="80" />
                    <DataGridTemplateColumn Header="操作" Width="320">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button AutomationProperties.Name="上钟"
                                            Click="OnDuty_Click" Content="上钟" Tag="{Binding}"
                                            Style="{StaticResource RowPrimary}"
                                            Visibility="{Binding DataContext.CanManage, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisible}}" />
                                    <Button AutomationProperties.Name="休息"
                                            Click="Resting_Click" Content="休息" Tag="{Binding}"
                                            Style="{StaticResource RowGhost}"
                                            Visibility="{Binding DataContext.CanManage, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisible}}" />
                                    <Button AutomationProperties.Name="下班"
                                            Click="OffDuty_Click" Content="下班" Tag="{Binding}"
                                            Style="{StaticResource RowDanger}"
                                            Visibility="{Binding DataContext.CanManage, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisible}}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
