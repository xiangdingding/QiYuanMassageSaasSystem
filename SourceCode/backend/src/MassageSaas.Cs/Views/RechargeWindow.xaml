<Window x:Class="MassageSaas.Cs.Views.RechargeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="会员充值"
        Height="620" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <!--  左侧标签：右对齐、垂直居中（对齐 BS el-form label-width）  -->
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#606266" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#909399" />
        </Style>
        <Style x:Key="Strong" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#303133" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="20">
        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0" Padding="0,12,0,0"
                BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="20,0" Margin="0,0,8,0"
                        Style="{StaticResource GhostBtn}" Click="Cancel_Click"
                        AutomationProperties.Name="取消" />
                <Button x:Name="ConfirmButton" Content="确认充值" Padding="20,0"
                        Style="{StaticResource PrimaryBtn}" Click="Confirm_Click"
                        AutomationProperties.Name="确认充值" />
            </StackPanel>
        </Border>

        <StackPanel>
            <TextBlock x:Name="HeaderText" FontWeight="Bold" FontSize="16" Margin="0,0,0,4" />
            <Border BorderBrush="#EBEEF5" BorderThickness="0,0,0,1" Margin="0,0,0,12" Padding="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="当前余额" Style="{StaticResource FL}" />
                    <TextBlock Grid.Column="1" x:Name="BalanceText" VerticalAlignment="Center" FontSize="14" Foreground="#303133" />
                </Grid>
            </Border>

            <!--  会员类型规则（typed 卡才显示）  -->
            <Border x:Name="RulesBox" Background="#F4F4F5" CornerRadius="4" Padding="10,8" Margin="0,0,0,14" Visibility="Collapsed">
                <DockPanel>
                    <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16" Foreground="#909399"
                                             VerticalAlignment="Top" Margin="0,1,8,0" DockPanel.Dock="Left" />
                    <StackPanel>
                        <TextBlock x:Name="RulesTitle" FontSize="13" Foreground="#303133" />
                        <TextBlock x:Name="RulesText" FontSize="12" Foreground="#909399" TextWrapping="Wrap" Margin="0,3,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!--  充值金额面板（充值卡 / 无模板旧卡）  -->
            <StackPanel x:Name="StoredPanel" Visibility="Collapsed">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="充值金额" Style="{StaticResource FL}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ctrl:NumericUpDown x:Name="AmountBox" Width="160"
                                            Minimum="0" Maximum="1000000" Step="100" Decimals="2"
                                            AutomationProperties.Name="充值金额" />
                        <TextBlock x:Name="AmountHint" Style="{StaticResource Hint}" />
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="赠送金额" Style="{StaticResource FL}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ctrl:NumericUpDown x:Name="BonusBox" Width="160"
                                            Minimum="0" Maximum="1000000" Step="50" Decimals="2"
                                            AutomationProperties.Name="赠送金额" />
                        <TextBlock x:Name="BonusHint" Style="{StaticResource Hint}" />
                    </StackPanel>
                </Grid>
                <Grid x:Name="PaidRow" Margin="0,0,0,12" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="实收金额" Style="{StaticResource FL}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock x:Name="PaidValue" Style="{StaticResource Strong}" />
                        <TextBlock x:Name="PaidHint" Style="{StaticResource Hint}" />
                    </StackPanel>
                </Grid>
                <Grid x:Name="CreditRow" Margin="0,0,0,12" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="实充金额" Style="{StaticResource FL}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock x:Name="CreditValue" Style="{StaticResource Strong}" />
                        <TextBlock x:Name="CreditHint" Style="{StaticResource Hint}" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!--  充值次数面板（计次卡）  -->
            <StackPanel x:Name="CountPanel" Visibility="Collapsed">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="充值次数" Style="{StaticResource FL}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ctrl:NumericUpDown x:Name="CountBox" Width="160"
                                            Minimum="1" Maximum="100000" Step="1" Decimals="0"
                                            AutomationProperties.Name="充值次数" />
                        <TextBlock x:Name="CountHint" Style="{StaticResource Hint}" />
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="实充次数" Style="{StaticResource FL}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock x:Name="CountCreditValue" Style="{StaticResource Strong}" />
                        <TextBlock x:Name="CountCreditHint" Style="{StaticResource Hint}" />
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="充值金额" Style="{StaticResource FL}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock x:Name="CountFaceValue" Style="{StaticResource Strong}" />
                        <TextBlock x:Name="CountFaceHint" Style="{StaticResource Hint}" />
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="实收金额" Style="{StaticResource FL}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock x:Name="CountPaidValue" Style="{StaticResource Strong}" />
                        <TextBlock x:Name="CountPaidHint" Style="{StaticResource Hint}" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!--  支付方式  -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="支付方式" Style="{StaticResource FL}" />
                <StackPanel Grid.Column="1" x:Name="PayPanel" Orientation="Horizontal" Height="34" HorizontalAlignment="Left">
                    <RadioButton Content="微信" CommandParameter="Wechat" GroupName="Pay" IsChecked="True"
                                 BorderThickness="1,1,1,1" Tag="6,0,0,6" Style="{StaticResource SegRadio}" />
                    <RadioButton Content="支付宝" CommandParameter="Alipay" GroupName="Pay" Tag="0" Style="{StaticResource SegRadio}" />
                    <RadioButton Content="银行卡" CommandParameter="BankCard" GroupName="Pay" Tag="0" Style="{StaticResource SegRadio}" />
                    <RadioButton Content="现金" CommandParameter="Cash" GroupName="Pay" Tag="0" Style="{StaticResource SegRadio}" />
                    <RadioButton Content="其它" CommandParameter="Other" GroupName="Pay" Tag="0,6,6,0" Style="{StaticResource SegRadio}" />
                </StackPanel>
            </Grid>

            <!--  备注  -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="备注" Style="{StaticResource FL}" VerticalAlignment="Top" Margin="0,7,12,0" />
                <TextBox Grid.Column="1" x:Name="RemarkBox" Height="56" MaxLength="500"
                         Style="{StaticResource FieldTextMultiline}"
                         AutomationProperties.Name="备注" />
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
