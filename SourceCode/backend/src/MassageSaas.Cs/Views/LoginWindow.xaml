<Window x:Class="MassageSaas.Cs.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="按摩店收银系统 - 登录"
        Height="380" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="按摩店收银系统"
                   FontSize="22" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="#2D6A4F" />
        <TextBlock Grid.Row="1"
                   Text="店主 / 店长 / 收银 / 技师 通用登录"
                   FontSize="12"
                   Foreground="#666"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,12" />

        <CheckBox Grid.Row="1"
                  x:Name="A11yToggle"
                  Content="启用无障碍模式（放大字号、加粗焦点、读屏优化）"
                  HorizontalAlignment="Center"
                  Margin="0,40,0,12"
                  FontSize="13"
                  Checked="A11yToggle_Changed"
                  Unchecked="A11yToggle_Changed"
                  AutomationProperties.Name="无障碍模式开关"
                  AutomationProperties.HelpText="勾选后立即应用，并在下次启动时记住该选择" />

        <TextBox Grid.Row="2"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 FontSize="14" Padding="8" Margin="0,0,0,12"
                 AutomationProperties.Name="账号"
                 AutomationProperties.HelpText="请输入登录账号" />

        <PasswordBox Grid.Row="3"
                     Name="PasswordBox"
                     FontSize="14" Padding="8" Margin="0,0,0,12"
                     AutomationProperties.Name="密码"
                     AutomationProperties.HelpText="请输入登录密码"
                     PasswordChanged="PasswordBox_PasswordChanged"
                     KeyDown="PasswordBox_KeyDown" />

        <Button Grid.Row="4"
                Content="登 录"
                FontSize="15"
                Padding="0,10"
                Background="#2D6A4F"
                Foreground="White"
                BorderThickness="0"
                Command="{Binding LoginCommand}"
                AutomationProperties.Name="登录按钮" />

        <TextBlock Grid.Row="6"
                   Text="{Binding ErrorMessage}"
                   Foreground="#D9534F"
                   FontSize="13"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center" />
    </Grid>
</Window>
