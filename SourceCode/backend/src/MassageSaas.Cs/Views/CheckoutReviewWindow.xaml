<Window x:Class="MassageSaas.Cs.Views.CheckoutReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="结算评价"
        Height="440" Width="520"
        MinHeight="320" MinWidth="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,10" TextWrapping="Wrap"
                   Text="为本单各项服务评价（默认满意，可逐项调整；点完成即提交）" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="RowsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                       TextWrapping="Wrap" Margin="0,0,12,0" />
                            <ComboBox Grid.Column="1" Width="140" Height="30"
                                      ItemsSource="{Binding Options}"
                                      SelectedValuePath="Value" DisplayMemberPath="Label"
                                      SelectedValue="{Binding Rating, Mode=TwoWay}"
                                      AutomationProperties.Name="{Binding Label}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="完成" Padding="20,6" IsDefault="True"
                        Background="#2D6A4F" Foreground="White" BorderThickness="0"
                        Click="Submit_Click"
                        AutomationProperties.Name="完成并提交评价" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
