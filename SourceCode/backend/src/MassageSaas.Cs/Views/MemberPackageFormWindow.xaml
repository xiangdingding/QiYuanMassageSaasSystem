<Window x:Class="MassageSaas.Cs.Views.MemberPackageFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="会员套餐发卡"
        Height="620" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="会员" Margin="0,0,0,4" />
        <ComboBox Grid.Row="1" x:Name="MemberBox" Height="32" Margin="0,0,0,10"
                  DisplayMemberPath="Display" AutomationProperties.Name="选择会员" />

        <TextBlock Grid.Row="2" Text="套餐类型" Margin="0,0,0,4" />
        <ComboBox Grid.Row="3" x:Name="KindBox" Height="32" Margin="0,0,0,10"
                  SelectionChanged="KindBox_SelectionChanged">
            <ComboBoxItem Content="计次卡（按次数）" Tag="Counter" />
            <ComboBoxItem Content="期限卡（月/季/年）" Tag="Period" />
        </ComboBox>

        <TextBlock Grid.Row="4" Text="绑定服务（可不限）" Margin="0,0,0,4" />
        <ComboBox Grid.Row="5" x:Name="ServiceBox" Height="32" Margin="0,0,0,10"
                  DisplayMemberPath="Display" AutomationProperties.Name="绑定服务" />

        <TextBlock Grid.Row="6" Text="套餐名称" Margin="0,0,0,4" />
        <TextBox Grid.Row="7" x:Name="TitleBox" Padding="6" Margin="0,0,0,10" />

        <TextBlock Grid.Row="8" Text="实付金额" Margin="0,0,0,4" />
        <TextBox Grid.Row="9" x:Name="PaidBox" Padding="6" Margin="0,0,0,10" Text="0" />

        <TextBlock Grid.Row="10" x:Name="CountLabel" Text="总次数（计次卡）" Margin="0,0,0,4" />
        <TextBox Grid.Row="11" x:Name="CountBox" Padding="6" Margin="0,0,0,10" Text="10" />

        <Grid Grid.Row="12" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="生效日期（可空）" Margin="0,0,0,4" />
                <DatePicker x:Name="FromBox" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock x:Name="ExpiryLabel" Text="到期日期（期限卡必填）" Margin="0,0,0,4" />
                <DatePicker x:Name="ExpiryBox" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="14" Text="备注" Margin="0,0,0,4" />
        <TextBox Grid.Row="15" x:Name="RemarkBox" Padding="6" Height="50" TextWrapping="Wrap" AcceptsReturn="True" />

        <Border Grid.Row="17" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="发卡" Padding="16,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
