<Window x:Class="MassageSaas.Cs.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="发现新版本"
        Width="460"
        Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="White">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  头部  -->
        <Border Grid.Row="0" Background="#2D6A4F" Padding="20,18">
            <StackPanel>
                <TextBlock Text="发现新版本" FontSize="20" FontWeight="Bold" Foreground="White" />
                <TextBlock x:Name="VersionLine"
                           Margin="0,6,0,0"
                           FontSize="13"
                           Foreground="#D8F3E5"
                           AutomationProperties.Name="版本信息" />
            </StackPanel>
        </Border>

        <!--  更新日志  -->
        <Grid Grid.Row="1" Margin="20,16,20,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="更新内容" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8" />
            <Border Grid.Row="1" BorderBrush="#E4E9F2" BorderThickness="1" CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,10">
                    <TextBlock x:Name="ChangelogText"
                               TextWrapping="Wrap"
                               FontSize="13"
                               LineHeight="22"
                               Foreground="#444"
                               AutomationProperties.Name="更新内容" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!--  底部：进度 + 按钮  -->
        <StackPanel Grid.Row="2" Margin="20,4,20,18">
            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,12">
                <ProgressBar x:Name="DownloadProgress"
                             Height="10"
                             Minimum="0"
                             Maximum="100"
                             AutomationProperties.Name="下载进度" />
                <TextBlock x:Name="ProgressText"
                           Margin="0,6,0,0"
                           FontSize="12"
                           Foreground="#666"
                           AutomationProperties.Name="下载进度文字" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="LaterButton"
                        Content="稍后再说"
                        Width="100"
                        Height="38"
                        Margin="0,0,10,0"
                        AutomationProperties.Name="稍后再说"
                        Click="Later_Click" />
                <Button x:Name="ExitButton"
                        Content="退出程序"
                        Width="100"
                        Height="38"
                        Margin="0,0,10,0"
                        Visibility="Collapsed"
                        AutomationProperties.Name="退出程序"
                        Click="Exit_Click" />
                <Button x:Name="UpdateButton"
                        Content="立即更新"
                        Width="120"
                        Height="38"
                        Background="#2D6A4F"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        AutomationProperties.Name="立即更新"
                        Click="Update_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
