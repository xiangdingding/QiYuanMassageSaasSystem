<Window x:Class="MassageSaas.Cs.Views.MemberTypeFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="会员类型"
        Height="640" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="20">
        <Border DockPanel.Dock="Bottom" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="保存" Padding="16,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Click="Save_Click" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="类型（创建后不可修改）" Margin="0,0,0,4" Foreground="#666" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="KindStored" Content="充值卡" GroupName="Kind" IsChecked="True"
                                 Checked="Kind_Changed" Margin="0,0,16,0" />
                    <RadioButton x:Name="KindCount" Content="计次卡" GroupName="Kind" Checked="Kind_Changed" />
                </StackPanel>

                <TextBlock Text="编码（租户内唯一，自由命名）" Margin="0,0,0,4" Foreground="#666" />
                <TextBox x:Name="CodeBox" AutomationProperties.Name="编码" Height="34" Padding="8,0" Margin="0,0,0,10" MaxLength="32" VerticalContentAlignment="Center" />

                <TextBlock Text="名称" Margin="0,0,0,4" Foreground="#666" />
                <TextBox x:Name="NameBox" AutomationProperties.Name="名称" Height="34" Padding="8,0" Margin="0,0,0,10" MaxLength="64" VerticalContentAlignment="Center" />

                <!-- 计次卡专属 -->
                <StackPanel x:Name="CountPanel" Visibility="Collapsed">
                    <TextBlock Text="绑定服务" Margin="0,0,0,4" Foreground="#666" />
                    <ComboBox x:Name="ServiceBox" AutomationProperties.Name="绑定服务" Height="34" Padding="8,0" Margin="0,0,0,10"
                              VerticalContentAlignment="Center" SelectedValuePath="Id">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding Name, Mode=OneWay}" />
                                    <Run Text="（" /><Run Text="{Binding DurationMinutes, Mode=OneWay}" /><Run Text=" 分钟 · ¥" />
                                    <Run Text="{Binding Price, StringFormat='F0', Mode=OneWay}" /><Run Text="）" />
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="最低购买次数" Margin="0,0,0,4" Foreground="#666" />
                    <TextBox x:Name="MinPurchaseBox" AutomationProperties.Name="最低购买次数" Height="34" Padding="8,0" Margin="0,0,0,10" Text="10" VerticalContentAlignment="Center" />
                    <TextBlock Text="赠送次数（开卡/续费一次性赠送）" Margin="0,0,0,4" Foreground="#666" />
                    <TextBox x:Name="BonusCountBox" AutomationProperties.Name="赠送次数" Height="34" Padding="8,0" Margin="0,0,0,10" Text="0" VerticalContentAlignment="Center" />
                </StackPanel>

                <!-- 充值卡专属 -->
                <StackPanel x:Name="StoredPanel">
                    <TextBlock Text="最低充值金额" Margin="0,0,0,4" Foreground="#666" />
                    <TextBox x:Name="MinRechargeBox" AutomationProperties.Name="最低充值金额" Height="34" Padding="8,0" Margin="0,0,0,10" Text="1000" VerticalContentAlignment="Center" />
                    <TextBlock Text="赠送金额（开卡/续费一次性赠送，无则留空）" Margin="0,0,0,4" Foreground="#666" />
                    <TextBox x:Name="BonusAmountBox" AutomationProperties.Name="赠送金额" Height="34" Padding="8,0" Margin="0,0,0,10" VerticalContentAlignment="Center" />
                </StackPanel>

                <TextBlock Text="折扣（0.85 = 8.5 折，1 = 原价）" Margin="0,0,0,4" Foreground="#666" />
                <TextBox x:Name="DiscountBox" AutomationProperties.Name="折扣" Height="34" Padding="8,0" Margin="0,0,0,10" Text="1" VerticalContentAlignment="Center" />

                <TextBlock Text="有效天数（0 / 留空 = 永不过期）" Margin="0,0,0,4" Foreground="#666" />
                <TextBox x:Name="ValidDaysBox" AutomationProperties.Name="有效天数" Height="34" Padding="8,0" Margin="0,0,0,10" Text="365" VerticalContentAlignment="Center" />

                <TextBlock Text="排序（数字越小越靠前）" Margin="0,0,0,4" Foreground="#666" />
                <TextBox x:Name="SortBox" AutomationProperties.Name="排序" Height="34" Padding="8,0" Margin="0,0,0,10" Text="0" VerticalContentAlignment="Center" />

                <CheckBox x:Name="ActiveBox" Content="启用" IsChecked="True" Margin="0,0,0,10" />

                <TextBlock Text="备注" Margin="0,0,0,4" Foreground="#666" />
                <TextBox x:Name="RemarkBox" AutomationProperties.Name="备注" Height="46" Padding="6" AcceptsReturn="True" TextWrapping="Wrap" MaxLength="200" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
