<Window x:Class="MassageSaas.Cs.Views.MemberTypeFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls"
        Title="会员类型"
        Width="560"
        Height="660"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!--  字段标签（描述在左）：左对齐、定宽列，与各输入控件并排  -->
        <Style x:Key="Cap" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <!--  行内灰色小字提示（对齐 BS .muted）  -->
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <!--  每行：左标签定宽列 + 右输入列  -->
        <Style x:Key="Row" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="20">
        <Border Margin="0,12,0,0"
                Padding="0,12,0,0"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Margin="0,0,8,0"
                        Padding="20,0"
                        AutomationProperties.Name="取消"
                        Click="Cancel_Click"
                        Content="取消"
                        Style="{StaticResource GhostBtn}" />
                <Button Padding="20,0"
                        AutomationProperties.Name="保存"
                        Click="Save_Click"
                        Content="保存"
                        Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  类型（创建后不可修改）  -->
                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="类型" /></TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <RadioButton x:Name="KindStored"
                                     AutomationProperties.Name="充值卡"
                                     BorderThickness="1,1,1,1"
                                     Checked="Kind_Changed"
                                     Content="充值卡"
                                     GroupName="Kind"
                                     IsChecked="True"
                                     Style="{StaticResource SegRadio}"
                                     Tag="0,0,0,6" />
                        <RadioButton x:Name="KindCount"
                                     AutomationProperties.Name="计次卡"
                                     Checked="Kind_Changed"
                                     Content="计次卡"
                                     GroupName="Kind"
                                     Style="{StaticResource SegRadio}"
                                     Tag="0,6,6,0" />
                        <TextBlock Style="{StaticResource Hint}" Text="类型一经创建不可修改" />
                    </StackPanel>
                </Grid>

                <!--  编码  -->
                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="编码" /></TextBlock>
                    <TextBox x:Name="CodeBox"
                             Grid.Column="1"
                             AutomationProperties.Name="编码"
                             MaxLength="32"
                             Style="{StaticResource FieldText}"
                             Tag="租户内唯一，自由命名（如 V1 / GOLD / 901 / 金卡）" />
                </Grid>

                <!--  名称  -->
                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="名称" /></TextBlock>
                    <TextBox x:Name="NameBox"
                             Grid.Column="1"
                             AutomationProperties.Name="名称"
                             MaxLength="64"
                             Style="{StaticResource FieldText}"
                             Tag="如 黄金卡 / 100 次足疗卡" />
                </Grid>

                <!--  计次卡专属  -->
                <StackPanel x:Name="CountPanel" Visibility="Collapsed">
                    <Grid Style="{StaticResource Row}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource Cap}"
                                   Text="绑定服务" />
                        <ComboBox x:Name="ServiceBox"
                                  Grid.Column="1"
                                  AutomationProperties.Name="绑定服务，选择计次卡对应的服务项目"
                                  SelectedValuePath="Id"
                                  Style="{StaticResource FilterCombo}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <Run Text="{Binding Name, Mode=OneWay}" />
                                        <Run Text="（" /><Run Text="{Binding DurationMinutes, Mode=OneWay}" /><Run Text=" 分钟 · ¥" />
                                        <Run Text="{Binding Price, StringFormat='F0', Mode=OneWay}" /><Run Text="）" />
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                    <Grid Style="{StaticResource Row}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource Cap}"
                                   Text="最低购买次数" />
                        <ctrl:NumericUpDown x:Name="MinPurchaseBox"
                                            Grid.Column="1"
                                            Width="150"
                                            HorizontalAlignment="Left"
                                            AutomationProperties.Name="最低购买次数"
                                            Decimals="0"
                                            Maximum="9999"
                                            Minimum="1"
                                            Step="1"
                                            Value="10" />
                    </Grid>
                    <Grid Style="{StaticResource Row}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource Cap}"
                                   Text="赠送次数" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ctrl:NumericUpDown x:Name="BonusCountBox"
                                                Width="150"
                                                HorizontalAlignment="Left"
                                                AutomationProperties.Name="赠送次数"
                                                Decimals="0"
                                                Maximum="9999"
                                                Minimum="0"
                                                Step="1"
                                                Value="0" />
                            <TextBlock Style="{StaticResource Hint}" Text="开卡 / 续费时一次性赠送" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!--  充值卡专属  -->
                <StackPanel x:Name="StoredPanel">
                    <Grid Style="{StaticResource Row}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource Cap}"
                                   Text="最低充值金额" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ctrl:NumericUpDown x:Name="MinRechargeBox"
                                                Width="150"
                                                HorizontalAlignment="Left"
                                                AutomationProperties.Name="最低充值金额"
                                                Decimals="2"
                                                Maximum="9999999"
                                                Minimum="0.01"
                                                Step="100"
                                                Value="1000" />
                        </StackPanel>
                    </Grid>
                    <Grid Style="{StaticResource Row}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Style="{StaticResource Cap}"
                                   Text="赠送金额" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ctrl:NumericUpDown x:Name="BonusAmountBox"
                                                Width="150"
                                                HorizontalAlignment="Left"
                                                AutomationProperties.Name="赠送金额"
                                                Decimals="2"
                                                Maximum="9999999"
                                                Minimum="0"
                                                Step="50"
                                                Value="0" />
                            <TextBlock Style="{StaticResource Hint}" Text="开卡 / 续费时一次性赠送" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!--  折扣  -->
                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="折扣" /></TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ctrl:NumericUpDown x:Name="DiscountBox"
                                            Width="150"
                                            HorizontalAlignment="Left"
                                            AutomationProperties.Name="折扣"
                                            Decimals="2"
                                            Maximum="1"
                                            Minimum="0.1"
                                            Step="0.05"
                                            Value="1" />
                        <TextBlock Style="{StaticResource Hint}" Text="0.85 = 8.5 折" />
                    </StackPanel>
                </Grid>

                <!--  有效天数  -->
                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource Cap}"
                               Text="有效天数" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ctrl:NumericUpDown x:Name="ValidDaysBox"
                                            Width="150"
                                            HorizontalAlignment="Left"
                                            AutomationProperties.Name="有效天数"
                                            Decimals="0"
                                            Maximum="3650"
                                            Minimum="0"
                                            Step="1"
                                            Value="365" />
                        <TextBlock Style="{StaticResource Hint}" Text="0 / 留空 = 永不过期" />
                    </StackPanel>
                </Grid>

                <!--  启用  -->
                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource Cap}"
                               Text="启用" />
                    <ToggleButton x:Name="ActiveBox"
                                  Grid.Column="1"
                                  VerticalAlignment="Center"
                                  AutomationProperties.Name="启用该会员类型"
                                  IsChecked="True"
                                  Style="{StaticResource SwitchToggle}" />
                </Grid>

                <!--  备注  -->
                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Margin="0,7,10,0"
                               VerticalAlignment="Top"
                               Style="{StaticResource Cap}"
                               Text="备注" />
                    <TextBox x:Name="RemarkBox"
                             Grid.Column="1"
                             Height="46"
                             AutomationProperties.Name="备注"
                             MaxLength="200"
                             Style="{StaticResource FieldTextMultiline}" />
                </Grid>

                <!--  排序  -->
                <Grid Style="{StaticResource Row}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Style="{StaticResource Cap}"
                               Text="排序" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ctrl:NumericUpDown x:Name="SortBox"
                                            Width="150"
                                            HorizontalAlignment="Left"
                                            AutomationProperties.Name="排序"
                                            Decimals="0"
                                            Maximum="999"
                                            Minimum="0"
                                            Step="1"
                                            Value="0" />
                        <TextBlock Style="{StaticResource Hint}" Text="数字越小越靠前" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
