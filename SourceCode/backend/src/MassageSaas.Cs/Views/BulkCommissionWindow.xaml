<Window x:Class="MassageSaas.Cs.Views.BulkCommissionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量设置提成规则"
        Height="680" Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <DockPanel Margin="20">
        <Border DockPanel.Dock="Bottom" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <DockPanel>
                <TextBlock x:Name="PairCountText" DockPanel.Dock="Left" VerticalAlignment="Center"
                           Foreground="#2D6A4F" Text="将处理 0 个 (服务 × 技师) 组合" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                    <Button x:Name="ApplyButton" Content="应用" Padding="16,6" Background="#2D6A4F" Foreground="White"
                            BorderThickness="0" Click="Apply_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左：服务 + 技师多选 -->
            <DockPanel Grid.Column="0">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                    <TextBlock Text="服务项目（多选）" Foreground="#666" VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="全选" Padding="8,2" Click="SelectAllServices_Click" />
                        <Button Content="清空" Padding="8,2" Margin="6,0,0,0" Click="ClearServices_Click" />
                    </StackPanel>
                </DockPanel>
                <ListBox x:Name="ServiceList" DockPanel.Dock="Top" Height="230" SelectionMode="Extended"
                         SelectionChanged="Selection_Changed" AutomationProperties.Name="服务项目多选">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding Code, Mode=OneWay}" Foreground="#999" />
                                <Run Text="  " />
                                <Run Text="{Binding Name, Mode=OneWay}" />
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <DockPanel DockPanel.Dock="Top" Margin="0,12,0,4">
                    <TextBlock Text="技师（多选）" Foreground="#666" VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="全选" Padding="8,2" Click="SelectAllTechs_Click" />
                        <Button Content="清空" Padding="8,2" Margin="6,0,0,0" Click="ClearTechs_Click" />
                    </StackPanel>
                </DockPanel>
                <ListBox x:Name="TechList" Height="230" SelectionMode="Extended"
                         SelectionChanged="Selection_Changed" AutomationProperties.Name="技师多选">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding EmployeeNo, FallbackValue='-', Mode=OneWay}" Foreground="#999" />
                                <Run Text=" · " />
                                <Run Text="{Binding RealName, TargetNullValue='', Mode=OneWay}" />
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- 右：规则参数 -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="规则类型" Foreground="#666" Margin="0,0,0,4" />
                <ComboBox x:Name="RuleTypeBox" AutomationProperties.Name="规则类型" Height="32" Margin="0,0,0,12" VerticalContentAlignment="Center"
                          SelectionChanged="RuleType_Changed">
                    <ComboBoxItem Content="FixedAmount" IsSelected="True" />
                    <ComboBoxItem Content="Percentage" />
                    <ComboBoxItem Content="Tiered" />
                    <ComboBoxItem Content="Timed" />
                </ComboBox>

                <!-- 双值：轮钟/点钟（FixedAmount / Percentage） -->
                <StackPanel x:Name="DualPanel">
                    <TextBlock Text="按上钟方式（轮钟 / 点钟）" Foreground="#666" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="轮钟" VerticalAlignment="Center" Foreground="#666" />
                        <TextBox Grid.Column="1" x:Name="RotationBox" AutomationProperties.Name="轮钟数值" Height="32" Padding="6,0" VerticalContentAlignment="Center" />
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="点钟" VerticalAlignment="Center" Foreground="#666" />
                        <TextBox Grid.Column="1" x:Name="DesignationBox" AutomationProperties.Name="点钟数值" Height="32" Padding="6,0" VerticalContentAlignment="Center" />
                    </Grid>
                </StackPanel>

                <!-- 单值：Timed（元/小时） -->
                <StackPanel x:Name="SinglePanel" Visibility="Collapsed">
                    <TextBlock Text="元 / 小时（按时计费）" Foreground="#666" Margin="0,0,0,4" />
                    <TextBox x:Name="AmountBox" AutomationProperties.Name="元每小时" Height="32" Padding="6,0" Margin="0,0,0,12" Text="0" VerticalContentAlignment="Center" />
                </StackPanel>

                <!-- 阶梯档位：Tiered -->
                <StackPanel x:Name="TierPanel" Visibility="Collapsed">
                    <TextBlock Text="阶梯档位（从第几次起 / 数值）" Foreground="#666" Margin="0,0,0,4" />
                    <DataGrid x:Name="TiersGrid" AutomationProperties.Name="阶梯档位" Height="150" AutoGenerateColumns="False" CanUserAddRows="False"
                              HeadersVisibility="Column" RowHeight="34">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="从第几次起" Binding="{Binding FromQty}" Width="*" />
                            <DataGridTextColumn Header="数值" Binding="{Binding Amount}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,12">
                        <Button Content="+ 添加档位" Padding="8,3" Click="AddTier_Click" />
                        <Button Content="删除选中" Padding="8,3" Margin="6,0,0,0" Click="RemoveTier_Click" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="优先级（数字越大越先匹配）" Foreground="#666" Margin="0,0,0,4" />
                <TextBox x:Name="PriorityBox" AutomationProperties.Name="优先级" Height="32" Padding="6,0" Margin="0,0,0,12" Text="0" VerticalContentAlignment="Center" />

                <CheckBox x:Name="OverwriteBox" Content="覆盖已有的“通用”规则（不勾则跳过已存在的组合）" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
