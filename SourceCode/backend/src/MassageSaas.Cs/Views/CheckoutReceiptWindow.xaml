<Window x:Class="MassageSaas.Cs.Views.CheckoutReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="结账成功"
        Width="560" SizeToContent="Height" MaxHeight="860" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2D6A4F" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#245A41" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#9CC3B0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 成功标题 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="✓" FontSize="22" FontWeight="Bold" Foreground="#2D6A4F" VerticalAlignment="Center" />
            <TextBlock Text="结账成功" FontSize="20" FontWeight="Bold" Foreground="#1F2937"
                       VerticalAlignment="Center" Margin="8,0,0,0" />
        </StackPanel>

        <!-- 订单摘要 -->
        <Border Grid.Row="1" Background="#F7FAF8" CornerRadius="6" Padding="14,12" Margin="0,0,0,12">
            <StackPanel x:Name="SummaryPanel">
                <TextBlock x:Name="OrderNoText" FontSize="14" Margin="0,0,0,4" />
                <TextBlock x:Name="TotalText" FontSize="14" Margin="0,0,0,4" />
                <TextBlock x:Name="PaidText" FontSize="15" FontWeight="Bold" Foreground="#D9534F" Margin="0,0,0,4" />
                <TextBlock x:Name="PunchText" FontSize="13" Foreground="#2D6A4F" Margin="0,0,0,4" Visibility="Collapsed" />
                <TextBlock x:Name="ChangeText" FontSize="13" Foreground="#444" Margin="0,0,0,4" Visibility="Collapsed" />
                <TextBlock x:Name="DiscountText" FontSize="13" Foreground="#888" Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <!-- 消费明细 -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="消费明细" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6" />
            <DataGrid x:Name="ItemsGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                      CanUserDeleteRows="False" HeadersVisibility="Column" GridLinesVisibility="All"
                      RowHeaderWidth="0" AlternatingRowBackground="#FAFAFA" FontSize="13"
                      IsReadOnly="True" MaxHeight="220" AutomationProperties.Name="消费明细">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="项目" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ServiceName}" VerticalAlignment="Center"
                                           Margin="6,0" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="技师" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                                    <TextBlock Text="{Binding TechnicianName}" VerticalAlignment="Center" />
                                    <Border Background="#EEF2F7" CornerRadius="3" Padding="4,1" Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding ShowAssignTag, Converter={StaticResource BoolToVisible}}">
                                        <TextBlock Text="{Binding AssignTag}" FontSize="11" Foreground="#666" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="次数" Binding="{Binding QuantityText}" Width="64">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right" />
                                <Setter Property="Margin" Value="0,0,8,0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="金额" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding AmountText}" VerticalAlignment="Center" />
                                    <Border Background="#E6F4EA" CornerRadius="3" Padding="4,1" Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsPunch, Converter={StaticResource BoolToVisible}}">
                                        <TextBlock Text="次卡" FontSize="11" Foreground="#2D6A4F" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <!-- 服务评价：独立一块（对齐 BS），逐项满意度，默认满意，点完成提交 -->
        <Border Grid.Row="3" x:Name="ReviewPanel" Background="#F1F7F4" CornerRadius="6" Padding="12,10" Margin="0,12,0,0">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Left" Text="服务评价" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock DockPanel.Dock="Left" Margin="10,0,0,0" VerticalAlignment="Bottom"
                               Foreground="#888" FontSize="12" Text="默认满意，可逐项调整；点&quot;完成&quot;自动提交" />
                </DockPanel>
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ReviewItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,3">
                                    <ComboBox DockPanel.Dock="Right" Width="118" Height="30" VerticalAlignment="Center"
                                              ItemsSource="{Binding Options}" SelectedValuePath="Value" DisplayMemberPath="Label"
                                              SelectedValue="{Binding Rating, Mode=TwoWay}"
                                              AutomationProperties.Name="{Binding SatisfactionAutomationName}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="13" Foreground="#444"
                                               Text="{Binding ReviewLabel}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- 计时房费明细 -->
        <StackPanel Grid.Row="4" x:Name="RoomChargePanel" Margin="0,12,0,0" Visibility="Collapsed">
            <TextBlock Text="计时房费" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6" />
            <DataGrid x:Name="RoomGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                      CanUserDeleteRows="False" HeadersVisibility="Column" GridLinesVisibility="All"
                      RowHeaderWidth="0" MaxHeight="140" FontSize="13" IsReadOnly="True"
                      AutomationProperties.Name="计时房费明细">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="计时房" Binding="{Binding RoomNo}" Width="80" />
                    <DataGridTextColumn Header="时长" Binding="{Binding MinutesText}" Width="*" />
                    <DataGridTextColumn Header="单价" Binding="{Binding RateText}" Width="110" />
                    <DataGridTextColumn Header="金额" Binding="{Binding AmountText}" Width="110" />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <!-- 底栏 -->
        <Border Grid.Row="5" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,14,0,0" Margin="0,14,0,0">
            <Button Content="完成" Padding="34,8" HorizontalAlignment="Right" IsDefault="True"
                    Style="{StaticResource PrimaryButton}" Click="Finish_Click"
                    AutomationProperties.Name="完成并提交评价" />
        </Border>
    </Grid>
</Window>
