<Window x:Class="MassageSaas.Cs.Views.MemberTransferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="转赠"
        Width="560"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <!-- 字段标签：与开卡 / 退卡窗一致 -->
        <Style x:Key="Cap" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <!-- 确认转赠：警示橙，沿用主按钮形状（与退卡窗 WarnBtn 一致） -->
        <Style x:Key="WarnBtn" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="#E6A23C" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#CF8E2E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="20">
        <Border Margin="0,12,0,0"
                Padding="0,12,0,0"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Margin="0,0,8,0"
                        Padding="20,0"
                        AutomationProperties.Name="取消"
                        Click="Cancel_Click"
                        Content="取消"
                        Style="{StaticResource GhostBtn}" />
                <Button Padding="20,0"
                        AutomationProperties.Name="确认转赠"
                        Click="Confirm_Click"
                        Content="确认转赠"
                        Style="{StaticResource WarnBtn}" />
            </StackPanel>
        </Border>

        <StackPanel>
            <TextBlock x:Name="HeaderText" Margin="0,0,0,12" FontSize="15" FontWeight="Bold" />

            <DockPanel Margin="0,0,0,12">
                <TextBlock Width="80" VerticalAlignment="Center" Foreground="#666" Text="当前余额" />
                <TextBlock x:Name="BalanceText" VerticalAlignment="Center"
                           FontSize="16" FontWeight="Bold" Foreground="#D9534F" />
                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                           FontSize="12" Foreground="#999" Text="将一并转走" />
            </DockPanel>

            <TextBlock Style="{StaticResource Cap}" Text="转赠对象" />
            <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                <RadioButton x:Name="ModeExisting"
                             AutomationProperties.Name="转给已有会员"
                             BorderThickness="1,1,1,1"
                             Checked="Mode_Changed"
                             Content="已有会员"
                             GroupName="Mode"
                             IsChecked="True"
                             Style="{StaticResource SegRadio}"
                             Tag="6,0,0,6" />
                <RadioButton x:Name="ModeNew"
                             AutomationProperties.Name="新建会员作为目标"
                             Checked="Mode_Changed"
                             Content="新建会员"
                             GroupName="Mode"
                             Style="{StaticResource SegRadio}"
                             Tag="0,6,6,0" />
            </StackPanel>

            <!--  已有会员：搜索 + 候选单选  -->
            <StackPanel x:Name="ExistingPanel">
                <TextBlock Style="{StaticResource Cap}" Text="查找目标会员" />
                <DockPanel Margin="0,0,0,6">
                    <Button DockPanel.Dock="Right"
                            Margin="8,0,0,0"
                            Padding="16,0"
                            AutomationProperties.Name="查找"
                            Click="Search_Click"
                            Content="查找"
                            Style="{StaticResource PrimaryBtn}" />
                    <TextBox x:Name="QueryBox"
                             AutomationProperties.Name="目标会员卡号或手机号"
                             Style="{StaticResource SearchBox}"
                             Tag="卡号 / 手机号">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" />
                        </TextBox.InputBindings>
                    </TextBox>
                </DockPanel>
                <ListBox x:Name="CandidateList"
                         Height="160"
                         BorderBrush="#D1D5DB"
                         AutomationProperties.Name="候选目标会员">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run FontWeight="SemiBold" Text="{Binding CardNo, Mode=OneWay}" />
                                <Run Text="（" /><Run Text="{Binding Name, TargetNullValue='未填', Mode=OneWay}" />
                                <Run Text=" / " /><Run Text="{Binding Phone, Mode=OneWay}" /><Run Text="）" />
                                <Run Text="  余额 ¥" /><Run Foreground="#D9534F" Text="{Binding Balance, StringFormat='F2', Mode=OneWay}" />
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!--  新建会员  -->
            <StackPanel x:Name="NewPanel" Visibility="Collapsed">
                <TextBlock Style="{StaticResource Cap}" Text="新会员卡号" />
                <TextBox x:Name="NewCardNoBox" Margin="0,0,0,8"
                         AutomationProperties.Name="新会员卡号"
                         Style="{StaticResource FieldText}" />
                <TextBlock Style="{StaticResource Cap}" Text="手机号" />
                <TextBox x:Name="NewPhoneBox" Margin="0,0,0,8"
                         AutomationProperties.Name="手机号"
                         Style="{StaticResource FieldText}" />
                <TextBlock Style="{StaticResource Cap}" Text="姓名（可选）" />
                <TextBox x:Name="NewNameBox" Margin="0,0,0,8"
                         AutomationProperties.Name="姓名"
                         Style="{StaticResource FieldText}" />
            </StackPanel>

            <TextBlock Margin="0,8,0,4" Style="{StaticResource Cap}" Text="原因" />
            <TextBox x:Name="ReasonBox"
                     Height="56"
                     Margin="0,0,0,12"
                     AutomationProperties.Name="转赠原因"
                     MaxLength="200"
                     Style="{StaticResource FieldTextMultiline}" />

            <Border Padding="10,8"
                    Background="#FDF6EC"
                    BorderBrush="#F5DAB1"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBlock FontSize="12"
                           Foreground="#B88230"
                           Text="转赠后原卡余额清零并关闭，目标卡余额累加（不计入对方累计充值，不会因此升级）。"
                           TextWrapping="Wrap" />
            </Border>
        </StackPanel>
    </DockPanel>
</Window>
