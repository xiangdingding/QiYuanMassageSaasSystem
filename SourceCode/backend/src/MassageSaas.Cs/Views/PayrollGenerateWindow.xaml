<Window x:Class="MassageSaas.Cs.Views.PayrollGenerateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="生成工资单"
        Height="320" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="按所选月份汇总底薪、提成、加班、满勤、奖扣，生成工资单草稿。"
                   TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,12" />

        <TextBlock Grid.Row="1" Text="年份" Margin="0,0,0,4" />
        <TextBox Grid.Row="2" x:Name="YearBox" Padding="6" Margin="0,0,0,12" />

        <TextBlock Grid.Row="3" Text="月份（1-12）" Margin="0,0,0,4" />
        <TextBox Grid.Row="4" x:Name="MonthBox" Padding="6" Margin="0,0,0,12" />

        <TextBlock Grid.Row="5" Text="备注（可空）" Margin="0,0,0,4" />
        <TextBox Grid.Row="6" x:Name="RemarkBox" Padding="6" Height="48" TextWrapping="Wrap" AcceptsReturn="True" VerticalAlignment="Top" />

        <Border Grid.Row="7" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="生成" Padding="16,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
