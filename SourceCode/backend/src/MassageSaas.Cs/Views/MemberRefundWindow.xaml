<Window x:Class="MassageSaas.Cs.Views.MemberRefundWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="退卡"
        Height="420" Width="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="20">
        <Border DockPanel.Dock="Bottom" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="确认退卡" Padding="16,6" Background="#E6A23C" Foreground="White" BorderThickness="0" Click="Confirm_Click" />
            </StackPanel>
        </Border>

        <StackPanel>
            <TextBlock x:Name="HeaderText" FontWeight="Bold" FontSize="15" Margin="0,0,0,10" />

            <DockPanel Margin="0,0,0,10">
                <TextBlock Text="当前余额" Width="80" VerticalAlignment="Center" Foreground="#666" />
                <TextBlock x:Name="BalanceText" Foreground="#D9534F" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
            </DockPanel>

            <TextBlock Text="退款金额" Margin="0,0,0,4" Foreground="#666" />
            <DockPanel Margin="0,0,0,10">
                <Button DockPanel.Dock="Right" Content="全退" Padding="10,0" Margin="6,0,0,0" Click="RefundAll_Click" />
                <TextBox x:Name="AmountBox" Height="34" Padding="8,0" VerticalContentAlignment="Center"
                         AutomationProperties.Name="退款金额" />
            </DockPanel>

            <TextBlock Text="退款方式" Margin="0,0,0,4" Foreground="#666" />
            <WrapPanel x:Name="MethodPanel" Margin="0,0,0,10">
                <RadioButton Content="微信" Tag="Wechat" GroupName="RM" IsChecked="True" Margin="0,0,12,0" />
                <RadioButton Content="支付宝" Tag="Alipay" GroupName="RM" Margin="0,0,12,0" />
                <RadioButton Content="银行卡" Tag="BankCard" GroupName="RM" Margin="0,0,12,0" />
                <RadioButton Content="现金" Tag="Cash" GroupName="RM" Margin="0,0,12,0" />
                <RadioButton Content="其它" Tag="Other" GroupName="RM" />
            </WrapPanel>

            <TextBlock Text="原因" Margin="0,0,0,4" Foreground="#666" />
            <TextBox x:Name="ReasonBox" Height="46" Padding="6" Margin="0,0,0,10"
                     AcceptsReturn="True" TextWrapping="Wrap" MaxLength="200" AutomationProperties.Name="退卡原因" />

            <Border Background="#FDF6EC" BorderBrush="#F5DAB1" BorderThickness="1" CornerRadius="3" Padding="8">
                <TextBlock Text="退卡后会员卡将被关闭，不能再充值或消费。请确认与客户达成一致再操作。"
                           Foreground="#B88230" FontSize="12" TextWrapping="Wrap" />
            </Border>
        </StackPanel>
    </DockPanel>
</Window>
