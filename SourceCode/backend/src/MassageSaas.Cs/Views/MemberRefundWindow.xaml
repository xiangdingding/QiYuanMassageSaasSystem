<Window x:Class="MassageSaas.Cs.Views.MemberRefundWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="退卡"
        Width="560"
        Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <!-- 字段标签：与开卡窗一致 -->
        <Style x:Key="Cap" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <!-- 确认退卡：警示橙，沿用主按钮形状（圆角/高度/半粗体） -->
        <Style x:Key="WarnBtn" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="#E6A23C" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#CF8E2E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="20">
        <Border Margin="0,12,0,0"
                Padding="0,12,0,0"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Margin="0,0,8,0"
                        Padding="20,0"
                        AutomationProperties.Name="取消"
                        Click="Cancel_Click"
                        Content="取消"
                        Style="{StaticResource GhostBtn}" />
                <Button Padding="20,0"
                        AutomationProperties.Name="确认退卡"
                        Click="Confirm_Click"
                        Content="确认退卡"
                        Style="{StaticResource WarnBtn}" />
            </StackPanel>
        </Border>

        <StackPanel>
            <TextBlock x:Name="HeaderText" Margin="0,0,0,12" FontSize="15" FontWeight="Bold" />

            <DockPanel Margin="0,0,0,12">
                <TextBlock Width="80" VerticalAlignment="Center" Foreground="#666" Text="当前余额" />
                <TextBlock x:Name="BalanceText" VerticalAlignment="Center"
                           FontSize="16" FontWeight="Bold" Foreground="#D9534F" />
            </DockPanel>

            <TextBlock Style="{StaticResource Cap}" Text="退款金额" />
            <DockPanel Margin="0,0,0,12">
                <Button DockPanel.Dock="Right"
                        Margin="8,0,0,0"
                        Padding="16,0"
                        AutomationProperties.Name="全额退款"
                        Click="RefundAll_Click"
                        Content="全退"
                        Style="{StaticResource GhostBtn}" />
                <TextBox x:Name="AmountBox"
                         AutomationProperties.Name="退款金额"
                         Style="{StaticResource FieldText}" />
            </DockPanel>

            <TextBlock Style="{StaticResource Cap}" Text="退款方式" />
            <StackPanel x:Name="MethodPanel" Margin="0,0,0,12" Orientation="Horizontal">
                <RadioButton BorderThickness="1,1,1,1"
                             CommandParameter="Wechat"
                             Content="微信"
                             GroupName="RM"
                             IsChecked="True"
                             Style="{StaticResource SegRadio}"
                             Tag="6,0,0,6" />
                <RadioButton CommandParameter="Alipay"
                             Content="支付宝"
                             GroupName="RM"
                             Style="{StaticResource SegRadio}"
                             Tag="0" />
                <RadioButton CommandParameter="BankCard"
                             Content="银行卡"
                             GroupName="RM"
                             Style="{StaticResource SegRadio}"
                             Tag="0" />
                <RadioButton CommandParameter="Cash"
                             Content="现金"
                             GroupName="RM"
                             Style="{StaticResource SegRadio}"
                             Tag="0" />
                <RadioButton CommandParameter="Other"
                             Content="其它"
                             GroupName="RM"
                             Style="{StaticResource SegRadio}"
                             Tag="0,6,6,0" />
            </StackPanel>

            <TextBlock Style="{StaticResource Cap}" Text="原因" />
            <TextBox x:Name="ReasonBox"
                     Height="72"
                     Margin="0,0,0,12"
                     AutomationProperties.Name="退卡原因"
                     MaxLength="200"
                     Style="{StaticResource FieldTextMultiline}" />

            <Border Padding="10,8"
                    Background="#FDF6EC"
                    BorderBrush="#F5DAB1"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBlock FontSize="12"
                           Foreground="#B88230"
                           Text="退卡后会员卡将被关闭，不能再充值或消费。请确认与客户达成一致再操作。"
                           TextWrapping="Wrap" />
            </Border>
        </StackPanel>
    </DockPanel>
</Window>
