<UserControl x:Class="MassageSaas.Cs.Views.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vmpos="clr-namespace:MassageSaas.Cs.ViewModels.Pos">
    <UserControl.Resources>
        <!--  分段式开关样式：把 RadioButton 渲染成实心按钮，选中态绿底白字，比圆点更直观  -->
        <Style x:Key="SegToggle" TargetType="RadioButton">
            <Setter Property="Height" Value="38" />
            <Setter Property="Foreground" Value="#555" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="White"
                                BorderBrush="#CBD5E0"
                                BorderThickness="1"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Content}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D6A4F" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2D6A4F" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="False" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#2D6A4F" />
                                <Setter Property="Foreground" Value="#2D6A4F" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#F0F0F0" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E0E0E0" />
                                <Setter Property="Foreground" Value="#BBB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  主操作按钮（查询会员）：绿底圆角，悬停加深、禁用变浅  -->
        <Style x:Key="PosPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2D6A4F" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#245A41" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#9CC3B0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  危险操作按钮（清空 / 移除）：白底红边圆角，悬停红底白字  -->
        <Style x:Key="PosDangerButton" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#D9534F" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#E0A3A1"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D9534F" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#D9534F" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#E5E7EB" />
                                <Setter Property="Foreground" Value="#BBB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  次操作按钮（✕ 取消关联）：白底描边圆角，悬停浅灰+绿边  -->
        <Style x:Key="PosGhostButton" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F3F4F6" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                                <Setter Property="Foreground" Value="#2D6A4F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="480" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="720" MinWidth="600" />
        </Grid.ColumnDefinitions>

        <!--  Left: services  -->
        <Border Grid.Column="0"
                Padding="16"
                Background="White"
                CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           Margin="0,0,0,12"
                           LastChildFill="True">
                    <TextBlock VerticalAlignment="Center"
                               DockPanel.Dock="Left"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="选择服务项目" />
                    <Button Width="38"
                            Height="32"
                            Margin="6,0,0,0"
                            AutomationProperties.HelpText="清空搜索框，恢复显示全部服务"
                            AutomationProperties.Name="清除服务搜索"
                            Command="{Binding ClearServiceFilterCommand}"
                            Content="✕"
                            DockPanel.Dock="Right"
                            Visibility="{Binding ServiceFilter, Converter={StaticResource NullToCollapsed}}" />
                    <TextBox x:Name="ServiceFilterBox"
                             Width="240"
                             Height="32"
                             Padding="6,0"
                             HorizontalAlignment="Right"
                             VerticalContentAlignment="Center"
                             AutomationProperties.HelpText="输入编码或名称，按回车快速加入第一项，按 Esc 清空"
                             AutomationProperties.Name="服务搜索框"
                             Text="{Binding ServiceFilter, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding QuickAddFirstCommand}" />
                            <KeyBinding Key="Esc" Command="{Binding ClearServiceFilterCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                </DockPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FilteredServices}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="216"
                                        Height="138"
                                        Margin="7"
                                        AutomationProperties.HelpText="点击加入订单"
                                        AutomationProperties.Name="{Binding Name}"
                                        Background="#F0F4F8"
                                        BorderBrush="#CBD5E0"
                                        BorderThickness="1"
                                        Command="{Binding DataContext.AddServiceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand">
                                    <StackPanel Margin="10,8">
                                        <TextBlock FontSize="17"
                                                   FontWeight="Bold"
                                                   Text="{Binding Name}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,6,0,0"
                                                   FontSize="13"
                                                   Foreground="#666">
                                            <Run Text="{Binding DurationMinutes, StringFormat='{}{0} 分钟', Mode=OneWay}" />
                                            <Run Text="   " />
                                            <Run Foreground="#999" Text="{Binding Code}" />
                                        </TextBlock>
                                        <!--  两种价格都显示；当前收银模式生效的那个高亮加粗，另一个淡化  -->
                                        <TextBlock x:Name="StdPrice"
                                                   Margin="0,8,0,0"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#2D6A4F">
                                            <Run Text="标准 ¥" />
                                            <Run Text="{Binding Price, StringFormat='F2', Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock x:Name="MemPrice"
                                                   Margin="0,2,0,0"
                                                   FontSize="13"
                                                   Foreground="#888">
                                            <Run Text="会员 ¥" />
                                            <Run Text="{Binding MemberPrice, StringFormat='F2', Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                                <DataTemplate.Triggers>
                                    <!--  会员模式：突出会员价、淡化标准价  -->
                                    <DataTrigger Binding="{Binding DataContext.IsMemberMode, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                        <Setter TargetName="MemPrice" Property="FontSize" Value="16" />
                                        <Setter TargetName="MemPrice" Property="FontWeight" Value="Bold" />
                                        <Setter TargetName="MemPrice" Property="Foreground" Value="#2D6A4F" />
                                        <Setter TargetName="StdPrice" Property="FontSize" Value="13" />
                                        <Setter TargetName="StdPrice" Property="FontWeight" Value="Normal" />
                                        <Setter TargetName="StdPrice" Property="Foreground" Value="#888" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!--  计时房费：点「开台」由收银开始计时；点「加入订单」把当前房费加入购物车一起结算  -->
                <Border Grid.Row="2"
                        Margin="0,12,0,0"
                        Visibility="{Binding HasTimedRooms, Converter={StaticResource BoolToVisible}}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock VerticalAlignment="Center"
                                       DockPanel.Dock="Left"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="计时房费" />
                            <TextBlock Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Left"
                                       FontSize="12"
                                       Foreground="#999"
                                       Text="开台计时 · 加入订单一起结算" />
                        </DockPanel>
                        <ScrollViewer MinHeight="220"
                                      MaxHeight="420"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TimedRoomCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="216"
                                                Margin="7"
                                                Padding="10,8"
                                                Background="#F0F4F8"
                                                BorderBrush="#CBD5E0"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Left"
                                                               FontSize="16"
                                                               FontWeight="Bold"
                                                               Text="{Binding RoomNo}" />
                                                    <TextBlock HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               DockPanel.Dock="Right"
                                                               FontSize="12"
                                                               Foreground="#666">
                                                        <Run Text="¥" />
                                                        <Run Text="{Binding HourlyRate, StringFormat='F2', Mode=OneWay}" />
                                                        <Run Text="/时" />
                                                    </TextBlock>
                                                </DockPanel>

                                                <!--  计时中  -->
                                                <StackPanel Margin="0,6,0,0" Visibility="{Binding HasOpenSession, Converter={StaticResource BoolToVisible}}">
                                                    <TextBlock FontSize="13" Foreground="#444">
                                                        <Run Text="已计时 " />
                                                        <Run FontWeight="Bold" Text="{Binding ElapsedMinutes, Mode=OneWay}" />
                                                        <Run Text=" 分钟" />
                                                    </TextBlock>
                                                    <TextBlock FontSize="12"
                                                               Foreground="#888"
                                                               Text="{Binding CustomerLabel}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="#2D6A4F">
                                                        <Run Text="≈ ¥" />
                                                        <Run Text="{Binding EstimatedAmount, StringFormat='F2', Mode=OneWay}" />
                                                    </TextBlock>
                                                    <Grid Margin="0,8,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button Grid.Column="0"
                                                                Height="32"
                                                                Margin="0,0,3,0"
                                                                AutomationProperties.Name="加入订单"
                                                                Background="#2D6A4F"
                                                                BorderThickness="0"
                                                                Command="{Binding DataContext.AddRoomChargeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="{Binding AddButtonLabel}"
                                                                Cursor="Hand"
                                                                Foreground="White"
                                                                IsEnabled="{Binding CanAddToCart}" />
                                                        <Button Grid.Column="1"
                                                                Height="32"
                                                                Margin="3,0,0,0"
                                                                AutomationProperties.Name="取消计时"
                                                                Background="Transparent"
                                                                BorderBrush="#D9534F"
                                                                Command="{Binding DataContext.CancelTimingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Content="取消计时"
                                                                Cursor="Hand"
                                                                Foreground="#D9534F" />
                                                    </Grid>
                                                </StackPanel>

                                                <!--  空闲  -->
                                                <Button Height="34"
                                                        Margin="0,8,0,0"
                                                        AutomationProperties.HelpText="为该计时房开台计时"
                                                        AutomationProperties.Name="{Binding RoomNo}"
                                                        Background="#2D6A4F"
                                                        BorderThickness="0"
                                                        Command="{Binding DataContext.OpenStartTimingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="开台"
                                                        Cursor="Hand"
                                                        FontWeight="SemiBold"
                                                        Foreground="White"
                                                        Visibility="{Binding IsIdle, Converter={StaticResource BoolToVisible}}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!--  中间分隔条：拖动调整左右区域宽度  -->
        <GridSplitter Grid.Column="1"
                      Width="12"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      AutomationProperties.HelpText="按住拖动，可调整服务区与收银区的宽度比例"
                      AutomationProperties.Name="左右区域宽度调整"
                      Background="Transparent"
                      Cursor="SizeWE"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns"
                      ShowsPreview="False">
            <GridSplitter.Template>
                <ControlTemplate TargetType="GridSplitter">
                    <Grid Background="{TemplateBinding Background}">
                        <!--  居中一条浅色竖线作为可见抓手  -->
                        <Border Width="2"
                                HorizontalAlignment="Center"
                                Background="#CBD5E0"
                                CornerRadius="1" />
                    </Grid>
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <!--  Right: cart + checkout  -->
        <Border Grid.Column="2"
                Padding="16"
                Background="White"
                CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Left"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="当前订单" />
                    <Button Height="30"
                            Padding="14,5"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="清空订单"
                            Command="{Binding ClearCommand}"
                            Content="清空"
                            DockPanel.Dock="Right"
                            Style="{StaticResource PosDangerButton}" />
                </DockPanel>

                <!--  收银模式：会员收银（按会员价、可关联卡合并结算）/ 散客收银（标准价、无会员）  -->
                <UniformGrid Grid.Row="1"
                             Margin="0,0,0,8"
                             Columns="2">
                    <RadioButton Margin="0,0,6,0"
                                 AutomationProperties.Name="会员收银模式"
                                 Content="会员收银"
                                 GroupName="PosMode"
                                 IsChecked="{Binding Mode, Converter={StaticResource StringEquals}, ConverterParameter=member, Mode=TwoWay}"
                                 Style="{StaticResource SegToggle}" />
                    <RadioButton AutomationProperties.Name="散客收银模式"
                                 Content="散客收银"
                                 GroupName="PosMode"
                                 IsChecked="{Binding Mode, Converter={StaticResource StringEquals}, ConverterParameter=walkin, Mode=TwoWay}"
                                 Style="{StaticResource SegToggle}" />
                </UniformGrid>

                <!--  会员区：仅会员模式可见。按手机号查询 → 列出名下所有卡 → 勾选多张合并结算  -->
                <StackPanel Grid.Row="2"
                            Margin="0,0,0,8"
                            Visibility="{Binding IsMemberMode, Converter={StaticResource BoolToVisible}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Height="38"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 AutomationProperties.HelpText="输入卡号或手机号，回车按人查询名下所有卡"
                                 AutomationProperties.Name="会员卡号或手机号"
                                 FontSize="15"
                                 Text="{Binding MemberKeyword, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding LookupMemberCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1"
                                Height="38"
                                Margin="8,0,0,0"
                                Padding="20,0"
                                AutomationProperties.Name="查询会员"
                                Command="{Binding LookupMemberCommand}"
                                Content="查询会员"
                                Style="{StaticResource PosPrimaryButton}" />
                        <Button Grid.Column="2"
                                Height="38"
                                Margin="8,0,0,0"
                                Padding="14,0"
                                AutomationProperties.Name="取消关联会员"
                                Command="{Binding ClearMemberCommand}"
                                Content="✕"
                                FontSize="15"
                                Style="{StaticResource PosGhostButton}"
                                Visibility="{Binding HasMemberCards, Converter={StaticResource BoolToVisible}}" />
                    </Grid>

                    <Border Margin="0,8,0,0"
                            Padding="8"
                            Background="#F5F7FA"
                            CornerRadius="3"
                            Visibility="{Binding HasMemberCards, Converter={StaticResource BoolToVisible}}">
                        <StackPanel>
                            <TextBlock AutomationProperties.Name="会员卡组"
                                       FontSize="12"
                                       Foreground="#666">
                                <Run Text="手机号 " />
                                <Run FontWeight="Bold" Text="{Binding PrimaryPhone, Mode=OneWay}" />
                                <Run Text="  共 " />
                                <Run Text="{Binding MemberCards.Count, Mode=OneWay}" />
                                <Run Text=" 张卡，可勾选合并结算" />
                            </TextBlock>

                            <ItemsControl Margin="0,4,0,0" ItemsSource="{Binding MemberCards}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,3">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Margin="6,0,0,0"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               DockPanel.Dock="Right"
                                                               FontSize="11"
                                                               Foreground="#D9534F"
                                                               Text="{Binding EligibilityHint}"
                                                               Visibility="{Binding ShowEligibilityHint, Converter={StaticResource BoolToVisible}}" />
                                                    <CheckBox VerticalAlignment="Center"
                                                              AutomationProperties.Name="{Binding CardNo}"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              IsEnabled="{Binding CanSelect}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock VerticalAlignment="Center"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding CardNo}" />
                                                            <Border Margin="6,0,0,0"
                                                                    Padding="4,1"
                                                                    Background="#EEE"
                                                                    CornerRadius="2">
                                                                <TextBlock FontSize="10"
                                                                           Foreground="#555"
                                                                           Text="{Binding TypeLabel}" />
                                                            </Border>
                                                            <TextBlock Margin="6,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="#D9534F">
                                                                <Run Text="余额 ¥" />
                                                                <Run Text="{Binding Balance, StringFormat='F2', Mode=OneWay}" />
                                                            </TextBlock>
                                                            <TextBlock Margin="6,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="11"
                                                                       Foreground="#888"
                                                                       Text="{Binding RemainText}" />
                                                        </StackPanel>
                                                    </CheckBox>
                                                </DockPanel>
                                                <TextBlock Margin="22,1,0,0"
                                                           AutomationProperties.Name="会员卡有效期"
                                                           FontSize="10"
                                                           Foreground="#999">
                                                    <Run Text="开卡 " />
                                                    <Run Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd}', Mode=OneWay}" />
                                                    <Run Text="  到期 " />
                                                    <Run Text="{Binding CardExpiresAt, Converter={StaticResource CardExpiry}, Mode=OneWay}" />
                                                    <Run Text="  " />
                                                    <Run Text="{Binding CardDaysRemaining, Converter={StaticResource CardDaysRemaining}, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <DockPanel Margin="0,6,0,0">
                                <TextBlock DockPanel.Dock="Left"
                                           FontSize="12"
                                           Foreground="#666">
                                    <Run Text="已选 " />
                                    <Run Text="{Binding SelectedCount, Mode=OneWay}" />
                                    <Run Text=" 张 · 合计余额" />
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Right"
                                           DockPanel.Dock="Right"
                                           FontWeight="Bold"
                                           Foreground="#D9534F">
                                    <Run Text="¥" />
                                    <Run Text="{Binding SelectedBalance, StringFormat='F2', Mode=OneWay}" />
                                </TextBlock>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <DockPanel Grid.Row="3">
                    <!--  列头：与每行同一组固定列宽对齐（* 列吸收滚动条差值）  -->
                    <Grid Margin="0,0,0,6" DockPanel.Dock="Top">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Cart.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="96" />
                            <ColumnDefinition Width="132" />
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="104" />
                            <ColumnDefinition Width="86" />
                            <ColumnDefinition Width="58" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#999"
                                   Text="项目" />
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#999"
                                   Text="技师" />
                        <TextBlock Grid.Column="2"
                                   HorizontalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#999"
                                   Text="排钟" />
                        <TextBlock Grid.Column="3"
                                   HorizontalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#999"
                                   Text="房间" />
                        <TextBlock Grid.Column="4"
                                   HorizontalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#999"
                                   Text="钟数" />
                        <TextBlock Grid.Column="5"
                                   HorizontalAlignment="Right"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#999"
                                   Text="小计" />
                        <TextBlock Grid.Column="6"
                                   HorizontalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#999"
                                   Text="操作" />
                    </Grid>

                    <!--  空车提示  -->
                    <TextBlock Margin="0,24,0,0"
                               HorizontalAlignment="Center"
                               DockPanel.Dock="Top"
                               FontSize="14"
                               Foreground="#AAB"
                               Text="未添加任何项目">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Cart.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Cart}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,6"
                                            BorderBrush="#EEF1F5"
                                            BorderThickness="0,0,0,1">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" MinWidth="96" />
                                                <ColumnDefinition Width="132" />
                                                <ColumnDefinition Width="84" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="104" />
                                                <ColumnDefinition Width="86" />
                                                <ColumnDefinition Width="58" />
                                            </Grid.ColumnDefinitions>

                                            <!--  项目（计时房标签 + 名称 + 会员不一致标签）  -->
                                            <DockPanel Grid.Column="0"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center">
                                                <Border Margin="0,0,6,0"
                                                        Padding="5,1"
                                                        VerticalAlignment="Center"
                                                        Background="#2D6A4F"
                                                        CornerRadius="2"
                                                        DockPanel.Dock="Left"
                                                        Visibility="{Binding IsRoomCharge, Converter={StaticResource BoolToVisible}}">
                                                    <TextBlock FontSize="11"
                                                               Foreground="White"
                                                               Text="计时房" />
                                                </Border>
                                                <Border Margin="6,0,0,0"
                                                        Padding="5,1"
                                                        VerticalAlignment="Center"
                                                        Background="#FDE2E1"
                                                        CornerRadius="2"
                                                        DockPanel.Dock="Right"
                                                        Visibility="{Binding IsMemberMismatch, Converter={StaticResource BoolToVisible}}">
                                                    <TextBlock FontSize="11"
                                                               Foreground="#D9534F"
                                                               Text="会员不一致" />
                                                </Border>
                                                <TextBlock VerticalAlignment="Center"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding ServiceName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding ServiceName}" />
                                            </DockPanel>

                                            <!--  技师  -->
                                            <ComboBox Grid.Column="1"
                                                      Height="34"
                                                      Margin="6,0,0,0"
                                                      VerticalContentAlignment="Center"
                                                      AutomationProperties.Name="选择技师"
                                                      ItemsSource="{Binding DataContext.Technicians, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      SelectedItem="{Binding Technician, Mode=TwoWay}"
                                                      Visibility="{Binding IsService, Converter={StaticResource BoolToVisible}}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock>
                                                            <Run Text="{Binding EmployeeNo, FallbackValue='-', Mode=OneWay}" />
                                                            <Run Text=" · " />
                                                            <Run Text="{Binding RealName, TargetNullValue='', Mode=OneWay}" />
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <TextBlock Grid.Column="1"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#BBB"
                                                       Text="—"
                                                       Visibility="{Binding IsRoomCharge, Converter={StaticResource BoolToVisible}}" />

                                            <!--  排钟（上钟方式）  -->
                                            <ComboBox Grid.Column="2"
                                                      Height="34"
                                                      Margin="6,0,0,0"
                                                      VerticalContentAlignment="Center"
                                                      AutomationProperties.HelpText="选择轮钟或点钟"
                                                      AutomationProperties.Name="上钟方式"
                                                      DisplayMemberPath="Label"
                                                      ItemsSource="{Binding Source={x:Static vmpos:CartItemViewModel.AssignmentOptions}}"
                                                      SelectedValue="{Binding AssignmentSource, Mode=TwoWay}"
                                                      SelectedValuePath="Value"
                                                      Visibility="{Binding IsService, Converter={StaticResource BoolToVisible}}" />
                                            <TextBlock Grid.Column="2"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#BBB"
                                                       Text="—"
                                                       Visibility="{Binding IsRoomCharge, Converter={StaticResource BoolToVisible}}" />

                                            <!--  房间  -->
                                            <ComboBox Grid.Column="3"
                                                      Height="34"
                                                      Margin="6,0,0,0"
                                                      VerticalContentAlignment="Center"
                                                      AutomationProperties.Name="选择房间"
                                                      DisplayMemberPath="RoomNo"
                                                      ItemsSource="{Binding DataContext.RoomOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      SelectedItem="{Binding Room, Mode=TwoWay}"
                                                      Visibility="{Binding IsService, Converter={StaticResource BoolToVisible}}" />
                                            <TextBlock Grid.Column="3"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#888"
                                                       Text="{Binding RoomNo}"
                                                       Visibility="{Binding IsRoomCharge, Converter={StaticResource BoolToVisible}}" />

                                            <!--  钟数：服务项用 −/＋ 步进；计时房展示时长  -->
                                            <Grid Grid.Column="4"
                                                  Height="34"
                                                  Margin="6,0,0,0"
                                                  Visibility="{Binding IsService, Converter={StaticResource BoolToVisible}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="34" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        AutomationProperties.Name="减少数量"
                                                        Background="#EEF1F5"
                                                        BorderBrush="#CBD5E0"
                                                        BorderThickness="1"
                                                        Command="{Binding DecrementCommand}"
                                                        Content="−"
                                                        Cursor="Hand"
                                                        FontSize="18" />
                                                <Border Grid.Column="1"
                                                        Background="White"
                                                        BorderBrush="#CBD5E0"
                                                        BorderThickness="0,1,0,1">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               AutomationProperties.Name="数量"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding Quantity}" />
                                                </Border>
                                                <Button Grid.Column="2"
                                                        AutomationProperties.Name="增加数量"
                                                        Background="#EEF1F5"
                                                        BorderBrush="#CBD5E0"
                                                        BorderThickness="1"
                                                        Command="{Binding IncrementCommand}"
                                                        Content="＋"
                                                        Cursor="Hand"
                                                        FontSize="16" />
                                            </Grid>
                                            <TextBlock Grid.Column="4"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       Foreground="#888"
                                                       Visibility="{Binding IsRoomCharge, Converter={StaticResource BoolToVisible}}">
                                                <Run Text="{Binding ElapsedMinutes, Mode=OneWay}" />
                                                <Run Text=" 分" />
                                            </TextBlock>

                                            <!--  小计  -->
                                            <TextBlock Grid.Column="5"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="#D9534F">
                                                <Run Text="¥" />
                                                <Run Text="{Binding LineTotal, StringFormat='F2', Mode=OneWay}" />
                                            </TextBlock>

                                            <!--  操作  -->
                                            <Button Grid.Column="6"
                                                    Height="28"
                                                    Margin="6,0,0,0"
                                                    Padding="0"
                                                    VerticalAlignment="Center"
                                                    AutomationProperties.Name="移除此项"
                                                    Command="{Binding DataContext.RemoveCartItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="移除"
                                                    FontSize="12"
                                                    Style="{StaticResource PosDangerButton}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>

                <Border Grid.Row="4"
                        Padding="0,8,0,8"
                        BorderBrush="#E5E7EB"
                        BorderThickness="0,1,0,1">
                    <StackPanel>
                        <!--  优惠券：未应用→输入区；已应用→展示券码+抵扣+移除按钮  -->
                        <Grid Margin="0,0,0,6"
                              AutomationProperties.Name="优惠券"
                              Visibility="{Binding AppliedVoucher, Converter={StaticResource InverseNullToCollapsed}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#666"
                                       Text="优惠券" />
                            <TextBox Grid.Column="1"
                                     Padding="6,0"
                                     VerticalContentAlignment="Center"
                                     AutomationProperties.HelpText="录入券码后按应用"
                                     AutomationProperties.Name="优惠券券码"
                                     Text="{Binding VoucherCode, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding ApplyVoucherCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="2"
                                    Margin="6,0,0,0"
                                    Padding="10,4"
                                    AutomationProperties.Name="应用优惠券"
                                    Command="{Binding ApplyVoucherCommand}"
                                    Content="应用"
                                    IsEnabled="{Binding VoucherApplying, Converter={StaticResource BoolInverse}}" />
                        </Grid>
                        <Grid Margin="0,0,0,6"
                              AutomationProperties.Name="已应用优惠券"
                              Visibility="{Binding AppliedVoucher, Converter={StaticResource NullToCollapsed}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       Foreground="#666"
                                       Text="优惠券" />
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                <Border Margin="0,0,6,0"
                                        Padding="6,2"
                                        Background="#E6F4EA"
                                        CornerRadius="3">
                                    <TextBlock FontSize="12"
                                               Foreground="#2D6A4F"
                                               Text="{Binding AppliedVoucher.Code}" />
                                </Border>
                                <TextBlock MaxWidth="140"
                                           FontSize="12"
                                           Foreground="#444"
                                           Text="{Binding AppliedVoucher.Title}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Margin="6,0,0,0"
                                    Padding="10,4"
                                    AutomationProperties.Name="移除优惠券"
                                    Background="Transparent"
                                    BorderBrush="#D9534F"
                                    Command="{Binding RemoveVoucherCommand}"
                                    Content="移除"
                                    Foreground="#D9534F" />
                        </Grid>

                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left"
                                       FontSize="13"
                                       Text="合计" />
                            <TextBlock HorizontalAlignment="Right" DockPanel.Dock="Right">
                                <Run Text="¥" />
                                <Run FontWeight="Bold" Text="{Binding Total, StringFormat='F2', Mode=OneWay}" />
                            </TextBlock>
                        </DockPanel>
                        <DockPanel Margin="0,4,0,0" Visibility="{Binding MemberDiscount, Converter={StaticResource DecimalToVisible}}">
                            <TextBlock DockPanel.Dock="Left"
                                       FontSize="12"
                                       Foreground="#888"
                                       Text="会员折扣" />
                            <TextBlock HorizontalAlignment="Right"
                                       DockPanel.Dock="Right"
                                       Foreground="#888">
                                <Run Text="-¥" />
                                <Run Text="{Binding MemberDiscount, StringFormat='F2', Mode=OneWay}" />
                            </TextBlock>
                        </DockPanel>
                        <DockPanel Margin="0,4,0,0" Visibility="{Binding VoucherDiscount, Converter={StaticResource DecimalToVisible}}">
                            <TextBlock DockPanel.Dock="Left"
                                       FontSize="12"
                                       Foreground="#2D6A4F"
                                       Text="券抵扣" />
                            <TextBlock HorizontalAlignment="Right"
                                       DockPanel.Dock="Right"
                                       Foreground="#2D6A4F">
                                <Run Text="-¥" />
                                <Run Text="{Binding VoucherDiscount, StringFormat='F2', Mode=OneWay}" />
                            </TextBlock>
                        </DockPanel>
                        <DockPanel Margin="0,4,0,0">
                            <TextBlock DockPanel.Dock="Left"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="应收" />
                            <TextBlock HorizontalAlignment="Right"
                                       DockPanel.Dock="Right"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#D9534F">
                                <Run Text="¥" />
                                <Run Text="{Binding Payable, StringFormat='F2', Mode=OneWay}" />
                            </TextBlock>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="5" Margin="0,8,0,0">
                    <!--  支付方式 / 实收金额改到「结账」弹窗里录入（对齐 BS 端 CheckoutDialog）  -->
                    <!--  与 BS 一致：未满足 CanCheckout（购物车空 / 有项未派技师 / 会员模式未选会员 / 计时房会员不一致）时置灰不可点  -->
                    <Button Height="60"
                            Margin="0,6,0,0"
                            AutomationProperties.HelpText="弹出结账窗口，选择支付方式并确认"
                            AutomationProperties.Name="下单并结账"
                            Command="{Binding CheckoutCommand}"
                            FontSize="19"
                            IsEnabled="{Binding CanCheckout}"
                            Style="{StaticResource PosPrimaryButton}">
                        <TextBlock>
                            <Run Text="下单并结账   应收 ¥" />
                            <Run Text="{Binding Payable, StringFormat='F2', Mode=OneWay}" />
                        </TextBlock>
                    </Button>

                    <Button Height="34"
                            Margin="0,8,0,0"
                            AutomationProperties.HelpText="发送一张测试小票并踢钱箱，用于调试打印机"
                            AutomationProperties.Name="测试打印小票"
                            Background="Transparent"
                            BorderBrush="#CBD5E0"
                            BorderThickness="1"
                            Command="{Binding TestPrintCommand}"
                            Content="测试打印小票"
                            Cursor="Hand"
                            FontSize="13"
                            Foreground="#555" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
