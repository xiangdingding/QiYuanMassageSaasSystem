<Window x:Class="MassageSaas.Cs.Views.StartTimingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="开台计时"
        Height="500" Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <!-- 主操作按钮（查询 / 开台）：绿底圆角，悬停加深 -->
        <Style x:Key="DialogPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2D6A4F" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#245A41" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#9CC3B0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次操作按钮（取消 / 清除）：白底描边圆角，悬停浅灰 -->
        <Style x:Key="DialogGhostButton" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="#D1D5DB" BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F3F4F6" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeaderText" FontWeight="Bold" FontSize="18" Margin="0,0,0,16" />

        <TextBlock Grid.Row="1" Text="关联会员（可选，按卡号/手机号查询；不填按散客处理）"
                   FontSize="13" Margin="0,0,0,6" Foreground="#666" />
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="MemberKeywordBox" Height="40" Padding="10,0" FontSize="14"
                     VerticalContentAlignment="Center" KeyDown="MemberKeywordBox_KeyDown"
                     AutomationProperties.Name="会员卡号或手机号"
                     AutomationProperties.HelpText="输入卡号或手机号后按回车即可查询会员" />
            <Button Grid.Column="1" Content="查询" Height="40" Padding="20,0" Margin="8,0,0,0"
                    Style="{StaticResource DialogPrimaryButton}" Click="Lookup_Click"
                    AutomationProperties.Name="查询会员" />
            <Button Grid.Column="2" Content="清除" Height="40" Padding="16,0" Margin="8,0,0,0"
                    Style="{StaticResource DialogGhostButton}" Click="ClearMember_Click"
                    AutomationProperties.Name="清除会员关联" />
        </Grid>
        <Border Grid.Row="3" Background="#F1F7F4" CornerRadius="6" Padding="12,8" Margin="0,0,0,14">
            <TextBlock x:Name="MemberLabel" FontSize="15" FontWeight="Bold"
                       Foreground="#2D6A4F" Text="未关联（散客）"
                       AutomationProperties.Name="会员关联状态" />
        </Border>

        <StackPanel Grid.Row="4" x:Name="CustomerPanel">
            <TextBlock Text="散客姓名（未关联会员时可填客人称呼）"
                       FontSize="13" Margin="0,0,0,6" Foreground="#666" />
            <TextBox x:Name="CustomerNameBox" Height="40" Padding="10,0" FontSize="14" Margin="0,0,0,14"
                     VerticalContentAlignment="Center" MaxLength="64" AutomationProperties.Name="散客姓名" />
        </StackPanel>

        <StackPanel Grid.Row="5">
            <TextBlock Text="备注" FontSize="13" Margin="0,0,0,6" Foreground="#666" />
            <TextBox x:Name="RemarkBox" Padding="10" Height="70" Margin="0,0,0,14" FontSize="14"
                     AcceptsReturn="True" TextWrapping="Wrap" MaxLength="200" AutomationProperties.Name="备注" />
        </StackPanel>

        <Border Grid.Row="7" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="22,8" Margin="0,0,10,0"
                        Style="{StaticResource DialogGhostButton}" Click="Cancel_Click"
                        AutomationProperties.Name="取消" />
                <Button x:Name="StartButton" Content="开台" Padding="28,8"
                        Style="{StaticResource DialogPrimaryButton}" FontWeight="Bold" Click="Start_Click"
                        AutomationProperties.Name="开台计时" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
