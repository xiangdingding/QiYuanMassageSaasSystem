<UserControl x:Class="MassageSaas.Cs.Views.DayCloseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock DockPanel.Dock="Left" Text="日结 / 交接班" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="营业日：" VerticalAlignment="Center" />
                    <DatePicker Width="140" SelectedDate="{Binding BusinessDate}" />
                    <Button Content="刷新" Padding="12,6" Margin="8,0,0,0" Command="{Binding LoadCommand}" />
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="4" Padding="12" Margin="0,0,0,12"
                    DataContext="{Binding Preview}">
                <StackPanel>
                    <TextBlock FontSize="14" FontWeight="SemiBold">
                        <Run Text="完成订单：" /><Run Text="{Binding OrderCount, Mode=OneWay}" />
                        <Run Text="    营业总额：¥" /><Run Text="{Binding RevenueTotal, StringFormat='F2', Mode=OneWay}" />
                        <Run Text="    预期现金：¥" /><Run Text="{Binding ExpectedCash, StringFormat='F2', Mode=OneWay}" />
                    </TextBlock>
                    <UniformGrid Columns="5" Margin="0,8,0,0">
                        <TextBlock><Run Text="现金 ¥" /><Run Text="{Binding CashAmount, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                        <TextBlock><Run Text="会员 ¥" /><Run Text="{Binding MemberCardAmount, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                        <TextBlock><Run Text="微信 ¥" /><Run Text="{Binding WechatAmount, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                        <TextBlock><Run Text="支付宝 ¥" /><Run Text="{Binding AlipayAmount, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                        <TextBlock><Run Text="银行卡 ¥" /><Run Text="{Binding BankCardAmount, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                    </UniformGrid>
                    <TextBlock Margin="0,4,0,0">
                        <Run Text="充值 ¥" /><Run Text="{Binding RechargeAmount, StringFormat='F2', Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock FontWeight="SemiBold" Foreground="#D9534F" Margin="0,4,0,0"
                               Visibility="{Binding AlreadyClosed, Converter={StaticResource BoolToVisible}}"
                               Text="该日已日结，仅供查看" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" /><ColumnDefinition Width="200" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="实际现金：" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Padding="6" Text="{Binding ActualCash}" />
                <TextBlock Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Run Text="差额 ¥" /><Run Text="{Binding Variance, StringFormat='F2', Mode=OneWay}" />
                </TextBlock>
                <TextBox Grid.Column="3" Margin="12,0,0,0" Padding="6" Text="{Binding Remark}" />
                <Button Grid.Column="4" Content="提交日结" Padding="16,6" Margin="12,0,0,0"
                        Background="#2D6A4F" Foreground="White" BorderThickness="0"
                        Command="{Binding SubmitCommand}" />
            </Grid>

            <DataGrid Grid.Row="3" ItemsSource="{Binding History}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="日期" Binding="{Binding BusinessDate, StringFormat='yyyy-MM-dd'}" Width="120" />
                    <DataGridTextColumn Header="订单数" Binding="{Binding OrderCount}" Width="80" />
                    <DataGridTextColumn Header="营业额" Binding="{Binding RevenueTotal, StringFormat='¥{0:F2}'}" Width="120" />
                    <DataGridTextColumn Header="预期现金" Binding="{Binding ExpectedCash, StringFormat='¥{0:F2}'}" Width="120" />
                    <DataGridTextColumn Header="实收" Binding="{Binding ActualCash, StringFormat='¥{0:F2}'}" Width="120" />
                    <DataGridTextColumn Header="差额" Binding="{Binding Variance, StringFormat='¥{0:F2}'}" Width="100" />
                    <DataGridTextColumn Header="操作员" Binding="{Binding OperatorName}" Width="120" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="240" />
                    <DataGridTemplateColumn Header="操作" Width="80"
                                            Visibility="{Binding DataContext.CanRevoke, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisible}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="撤销" Padding="6,2" Foreground="#D9534F" Background="Transparent" BorderThickness="0"
                                        Command="{Binding DataContext.RevokeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
