<UserControl x:Class="MassageSaas.Cs.Views.CommissionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls">
    <Border Padding="16"
            Background="White"
            CornerRadius="4">
        <TabControl>
            <!--  Tab 1：服务提成规则（原有）  -->
            <TabItem Header="服务提成规则">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Padding="16,0"
                                    AutomationProperties.Name="新建服务提成规则"
                                    Command="{Binding CreateCommand}"
                                    Content="新建规则"
                                    Style="{StaticResource PrimaryBtn}" />
                            <Button Margin="8,0,0,0"
                                    Padding="16,0"
                                    AutomationProperties.Name="批量设置服务提成"
                                    Command="{Binding BulkSetCommand}"
                                    Content="批量设置"
                                    Style="{StaticResource WarningBtn}" />
                            <Button Margin="8,0,0,0"
                                    Padding="16,0"
                                    AutomationProperties.Name="批量启用服务提成规则"
                                    Command="{Binding BatchEnableCommand}"
                                    Content="批量启用"
                                    Style="{StaticResource GhostBtn}" />
                            <Button Margin="8,0,0,0"
                                    Padding="16,0"
                                    AutomationProperties.Name="批量禁用服务提成规则"
                                    Command="{Binding BatchDisableCommand}"
                                    Content="批量禁用"
                                    Style="{StaticResource GhostBtn}" />
                            <Button Margin="8,0,0,0"
                                    Padding="16,0"
                                    AutomationProperties.Name="批量删除服务提成规则"
                                    Command="{Binding BatchDeleteCommand}"
                                    Content="批量删除"
                                    Foreground="#D9534F"
                                    Style="{StaticResource GhostBtn}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Foreground="#606266" Margin="0,0,6,0" Text="服务" />
                            <ComboBox Width="220"
                                      Style="{StaticResource FilterCombo}"
                                      AutomationProperties.Name="按服务过滤"
                                      ItemsSource="{Binding ServiceOptions}"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding FilterServiceId, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock VerticalAlignment="Center" Foreground="#606266" Margin="12,0,6,0" Text="技师" />
                            <ComboBox Width="220"
                                      Style="{StaticResource FilterCombo}"
                                      AutomationProperties.Name="按技师过滤"
                                      ItemsSource="{Binding TechnicianOptions}"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding FilterTechnicianId, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Margin="12,0,0,0"
                                    Padding="16,0"
                                    AutomationProperties.Name="查询服务提成规则"
                                    Command="{Binding ReloadCommand}"
                                    Content="查询"
                                    Style="{StaticResource GhostBtn}" />
                        </StackPanel>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              AutomationProperties.Name="服务提成规则列表"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Rows}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="44" CanUserSort="False">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <CheckBox HorizontalAlignment="Center"
                                                  AutomationProperties.Name="全选"
                                                  IsChecked="{Binding DataContext.AllChecked, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  AutomationProperties.Name="选择该规则"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Width="100"
                                                Binding="{Binding RuleTypeLabel}"
                                                Header="规则类型" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="160"
                                                Binding="{Binding ServiceDisplay}"
                                                Header="适用服务" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="160"
                                                Binding="{Binding TechnicianDisplay}"
                                                Header="适用技师" />
                            <DataGridTemplateColumn Width="170" Header="数值">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Visibility="{Binding IsDual, Converter={StaticResource BoolToVisible}}">
                                                <TextBlock Text="{Binding RotationText}" />
                                                <TextBlock Text="{Binding DesignationText}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding ValueText}"
                                                       Visibility="{Binding IsDual, Converter={StaticResource InverseBoolToVisible}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Width="80"
                                                Binding="{Binding Priority}"
                                                Header="优先级" />
                            <DataGridTemplateColumn Width="70" Header="状态">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Padding="8,2"
                                                Background="{Binding IsActive, Converter={StaticResource ActiveStatusBrush}}"
                                                CornerRadius="4">
                                            <TextBlock FontSize="12"
                                                       Foreground="White"
                                                       Text="{Binding StatusLabel}" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="170" Header="操作">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                            <Button AutomationProperties.Name="编辑服务提成规则"
                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="编辑"
                                                    Style="{StaticResource RowGhost}" />
                                            <Button AutomationProperties.Name="删除服务提成规则"
                                                    Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="删除"
                                                    IsEnabled="{Binding CanDelete}"
                                                    ToolTip="仅停用规则可删除"
                                                    Style="{StaticResource RowDanger}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!--  Tab 2：推荐开卡提成规则（全店统一）  -->
            <TabItem Header="推荐开卡提成规则">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="760"
                                Margin="4,16,4,4"
                                HorizontalAlignment="Left">
                        <!--  顾客推荐  -->
                        <TextBlock Margin="0,0,0,4"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#303133"
                                   Text="顾客推荐" />
                        <TextBlock Margin="0,0,0,12"
                                   FontSize="12"
                                   Foreground="#909399"
                                   Text="顾客介绍新客开卡的奖励，发到推荐顾客的卡内余额。充值返佣与固定推荐费二选一，或全部关闭。" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="#606266"
                                       Text="返佣方式" />
                            <ComboBox Grid.Column="1"
                                      Width="220"
                                      HorizontalAlignment="Left"
                                      AutomationProperties.Name="顾客推荐返佣方式"
                                      SelectedValue="{Binding RefCustomerMode, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      Style="{StaticResource FilterCombo}">
                                <ComboBoxItem Content="关闭" Tag="None" />
                                <ComboBoxItem Content="充值返佣百分比" Tag="PercentPerRecharge" />
                                <ComboBoxItem Content="固定推荐费 / 每张卡" Tag="FixedPerCard" />
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,12" IsEnabled="{Binding RefCustomerMode, Converter={StaticResource StringEquals}, ConverterParameter=PercentPerRecharge}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="#606266"
                                       Text="充值返佣百分比" />
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ctrl:NumericUpDown Width="150"
                                                    AutomationProperties.Name="顾客充值返佣百分比"
                                                    Decimals="2"
                                                    Maximum="100"
                                                    Minimum="0"
                                                    Step="1"
                                                    Value="{Binding RefCustomerPercent, Mode=TwoWay}" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="#909399"
                                           TextWrapping="Wrap"
                                           Text="%  · 被推荐人每次充值，按此比例返到推荐顾客余额" />
                            </Grid>
                        </Grid>
                        <Grid Margin="0,0,0,20" IsEnabled="{Binding RefCustomerMode, Converter={StaticResource StringEquals}, ConverterParameter=FixedPerCard}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="#606266"
                                       Text="固定推荐费/张" />
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ctrl:NumericUpDown Width="150"
                                                    AutomationProperties.Name="顾客固定推荐费"
                                                    Decimals="2"
                                                    Maximum="100000"
                                                    Minimum="0"
                                                    Step="10"
                                                    Value="{Binding RefCustomerFixed, Mode=TwoWay}" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="#909399"
                                           TextWrapping="Wrap"
                                           Text="元  · 每推荐开一张卡，一次性返到推荐顾客余额" />
                            </Grid>
                        </Grid>
                        <Border Height="1"
                                Margin="0,4,0,16"
                                Background="#EBEEF5" />
                        <!--  员工推荐  -->
                        <TextBlock Margin="0,0,0,4"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#303133"
                                   Text="员工推荐" />
                        <TextBlock Margin="0,0,0,12"
                                   FontSize="12"
                                   Foreground="#909399"
                                   Text="店内员工介绍客户开卡的提成，开卡时记一笔，按月并入该员工工资净额。" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="#606266"
                                       Text="提成模式" />
                            <ComboBox Grid.Column="1"
                                      Width="220"
                                      HorizontalAlignment="Left"
                                      AutomationProperties.Name="员工推荐提成模式"
                                      SelectedValue="{Binding RefStaffMode, Mode=TwoWay}"
                                      SelectedValuePath="Tag"
                                      Style="{StaticResource FilterCombo}">
                                <ComboBoxItem Content="关闭" Tag="None" />
                                <ComboBoxItem Content="固定金额 / 每张卡" Tag="FixedPerCard" />
                                <ComboBoxItem Content="开卡实收 × 百分比" Tag="PercentOfOpenCard" />
                            </ComboBox>
                        </Grid>
                        <Grid Margin="0,0,0,12" IsEnabled="{Binding RefStaffMode, Converter={StaticResource StringEquals}, ConverterParameter=FixedPerCard}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="#606266"
                                       Text="固定提成金额/张" />
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ctrl:NumericUpDown Width="150"
                                                    AutomationProperties.Name="员工固定推荐提成金额"
                                                    Decimals="2"
                                                    Maximum="100000"
                                                    Minimum="0"
                                                    Step="10"
                                                    Value="{Binding RefStaffFixed, Mode=TwoWay}" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="#909399"
                                           TextWrapping="Wrap"
                                           Text="元  · 每推荐开一张卡，固定记一笔到该员工工资" />
                            </Grid>
                        </Grid>
                        <Grid Margin="0,0,0,20" IsEnabled="{Binding RefStaffMode, Converter={StaticResource StringEquals}, ConverterParameter=PercentOfOpenCard}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Foreground="#606266"
                                       Text="开卡实收百分比" />
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ctrl:NumericUpDown Width="150"
                                                    AutomationProperties.Name="员工推荐提成百分比"
                                                    Decimals="2"
                                                    Maximum="100"
                                                    Minimum="0"
                                                    Step="1"
                                                    Value="{Binding RefStaffPercent, Mode=TwoWay}" />
                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="#909399"
                                           TextWrapping="Wrap"
                                           Text="%  · 按开卡实收金额的此比例，记一笔到该员工工资" />
                            </Grid>
                        </Grid>

                        <Border Height="1"
                                Margin="0,4,0,16"
                                Background="#EBEEF5" />
                        <Button Padding="20,0"
                                HorizontalAlignment="Left"
                                AutomationProperties.Name="保存推荐开卡提成规则"
                                Command="{Binding SaveReferralCommand}"
                                Content="保存推荐开卡提成规则"
                                Style="{StaticResource PrimaryBtn}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Border>
</UserControl>
