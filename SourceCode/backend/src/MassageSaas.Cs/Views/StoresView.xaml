<UserControl x:Class="MassageSaas.Cs.Views.StoresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="16"
            Background="White"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                <TextBlock Margin="10,0,20,0"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="门店管理" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Padding="16,0"
                            Command="{Binding CreateCommand}"
                            Content="新建分店"
                            Style="{StaticResource PrimaryBtn}" />

                    <Button Margin="8,0,0,0"
                            Padding="16,0"
                            Command="{Binding ReloadCommand}"
                            Content="刷新"
                            Style="{StaticResource GhostBtn}" />

                </StackPanel>
            </DockPanel>

            <DataGrid Grid.Row="1"
                      AlternatingRowBackground="#FAFAFA"
                      AutoGenerateColumns="False"
                      AutomationProperties.Name="门店列表"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="All"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      ItemsSource="{Binding Rows}">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="60"
                                        Binding="{Binding Id}"
                                        Header="ID" />
                    <DataGridTextColumn Width="200"
                                        Binding="{Binding Name}"
                                        Header="名称" />
                    <DataGridTextColumn Width="80"
                                        Binding="{Binding IsHeadquarters, Converter={StaticResource BoolLabel}, ConverterParameter='总店|分店'}"
                                        Header="类别" />
                    <DataGridTextColumn Width="*"
                                        MinWidth="200"
                                        Binding="{Binding Address}"
                                        Header="地址" />
                    <DataGridTextColumn Width="140"
                                        Binding="{Binding Phone}"
                                        Header="电话" />
                    <DataGridTextColumn Width="70"
                                        Binding="{Binding IsActive, Converter={StaticResource BoolLabel}, ConverterParameter='启用|停用'}"
                                        Header="启用" />
                    <DataGridTextColumn Width="80"
                                        Binding="{Binding DayCloseCutoffMinutes, StringFormat='切{0}min'}"
                                        Header="切日" />
                    <DataGridTemplateColumn Width="Auto"
                                            MinWidth="90"
                                            Header="操作">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button AutomationProperties.Name="编辑门店"
                                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Content="编辑"
                                        Style="{StaticResource RowGhost}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
