<Window x:Class="MassageSaas.Cs.Views.VoucherFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls"
        Title="新建券"
        Width="480"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="Cap" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="Row" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="20">
        <Border Margin="0,12,0,0"
                Padding="0,12,0,0"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Margin="0,0,8,0" Padding="20,0"
                        AutomationProperties.Name="取消"
                        Click="Cancel_Click" Content="取消" Style="{StaticResource GhostBtn}" />
                <Button Padding="20,0"
                        AutomationProperties.Name="保存"
                        Click="Save_Click" Content="保存" Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </Border>

        <StackPanel>
            <!--  类型  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="类型" /></TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <RadioButton x:Name="KindStore"
                                 AutomationProperties.Name="店内券"
                                 BorderThickness="1,1,1,1"
                                 Content="店内券"
                                 GroupName="Kind"
                                 IsChecked="True"
                                 Style="{StaticResource SegRadio}"
                                 Tag="6,0,0,6" />
                    <RadioButton x:Name="KindGroup"
                                 AutomationProperties.Name="团购券"
                                 Content="团购券"
                                 GroupName="Kind"
                                 Style="{StaticResource SegRadio}"
                                 Tag="0,6,6,0" />
                </StackPanel>
            </Grid>

            <!--  券码  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="券码" /></TextBlock>
                <TextBox x:Name="CodeBox" Grid.Column="1" MaxLength="64"
                         AutomationProperties.Name="券码"
                         AutomationProperties.HelpText="可手动录入团购券码，或点右侧生成店内码"
                         Style="{StaticResource FieldText}"
                         Tag="可手动录入，或点右侧生成" />
                <Button Grid.Column="2" Margin="8,0,0,0" Padding="16,0"
                        AutomationProperties.Name="按当前类型生成无歧义字符的券码"
                        Click="Generate_Click" Content="生成" Style="{StaticResource GhostBtn}" />
            </Grid>

            <!--  标题  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="标题" /></TextBlock>
                <TextBox x:Name="TitleBox" Grid.Column="1" MaxLength="200"
                         AutomationProperties.Name="标题" Style="{StaticResource FieldText}" />
            </Grid>

            <!--  抵扣方式  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="抵扣方式" /></TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <RadioButton x:Name="ModeFaceRadio"
                                 AutomationProperties.Name="按满减面值抵扣"
                                 BorderThickness="1,1,1,1"
                                 Content="满减面值"
                                 GroupName="DiscountMode"
                                 IsChecked="True"
                                 Style="{StaticResource SegRadio}"
                                 Tag="6,0,0,6" />
                    <RadioButton x:Name="ModePercentRadio"
                                 AutomationProperties.Name="按折扣率抵扣"
                                 Content="折扣率"
                                 GroupName="DiscountMode"
                                 Style="{StaticResource SegRadio}"
                                 Tag="0,6,6,0" />
                    <TextBlock Style="{StaticResource Hint}" Text="二选一" />
                </StackPanel>
            </Grid>

            <!--  面值（满减时）  -->
            <Grid Style="{StaticResource Row}" Visibility="{Binding ElementName=ModeFaceRadio, Path=IsChecked, Converter={StaticResource BoolToVisible}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="面值" /></TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ctrl:NumericUpDown x:Name="FaceBox" Width="150" HorizontalAlignment="Left"
                                        AutomationProperties.Name="面值"
                                        Decimals="2" Maximum="999999" Minimum="0" Step="10" Value="0" />
                    <TextBlock Style="{StaticResource Hint}" Text="元，结账时直接抵扣此金额" />
                </StackPanel>
            </Grid>

            <!--  折扣率（折扣时）  -->
            <Grid Style="{StaticResource Row}" Visibility="{Binding ElementName=ModePercentRadio, Path=IsChecked, Converter={StaticResource BoolToVisible}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="折扣率" /></TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ctrl:NumericUpDown x:Name="DiscountBox" Width="150" HorizontalAlignment="Left"
                                        AutomationProperties.Name="折扣率"
                                        Decimals="2" Maximum="0.99" Minimum="0.1" Step="0.05" Value="0.9" />
                    <TextBlock Style="{StaticResource Hint}" Text="0.9 表示 9 折" />
                </StackPanel>
            </Grid>

            <!--  最低订单额  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}" Text="最低订单额" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ctrl:NumericUpDown x:Name="MinBox" Width="150" HorizontalAlignment="Left"
                                        AutomationProperties.Name="最低订单额"
                                        Decimals="2" Maximum="999999" Minimum="0" Step="10" Value="0" />
                    <TextBlock Style="{StaticResource Hint}" Text="元，订单需达到才能使用" />
                </StackPanel>
            </Grid>

            <!--  平台（仅团购券）  -->
            <Grid Style="{StaticResource Row}" Visibility="{Binding ElementName=KindGroup, Path=IsChecked, Converter={StaticResource BoolToVisible}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}" Text="平台" />
                <TextBox x:Name="PlatformBox" Grid.Column="1" MaxLength="64"
                         AutomationProperties.Name="来源平台"
                         Style="{StaticResource FieldText}"
                         Tag="Meituan / Dianping / Douyin" />
            </Grid>

            <!--  生效起 / 到期  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}" Text="生效起" />
                <DatePicker x:Name="FromBox" Grid.Column="1" AutomationProperties.Name="生效日期" />
                <TextBlock Grid.Column="2" Margin="12,0,8,0" VerticalAlignment="Center" Foreground="#666" Text="到期" />
                <DatePicker x:Name="ExpiryBox" Grid.Column="3" AutomationProperties.Name="到期日期" />
            </Grid>

            <!--  备注  -->
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Margin="0,7,10,0" VerticalAlignment="Top" Style="{StaticResource Cap}" Text="备注" />
                <TextBox x:Name="RemarkBox" Grid.Column="1" Height="52" MaxLength="500"
                         AutomationProperties.Name="备注" Style="{StaticResource FieldTextMultiline}" />
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
