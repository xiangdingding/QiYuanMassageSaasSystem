<Window x:Class="MassageSaas.Cs.Views.VoucherFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="录入优惠券"
        Height="640" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="券类型" Margin="0,0,0,4" />
        <ComboBox Grid.Row="1" x:Name="KindBox" Height="32" Margin="0,0,0,10">
            <ComboBoxItem Content="团购券（美团 / 点评）" Tag="GroupBuy" />
            <ComboBoxItem Content="门店优惠券" Tag="StoreCoupon" />
        </ComboBox>

        <TextBlock Grid.Row="2" Text="券码" Margin="0,0,0,4" />
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="CodeBox" Padding="6"
                     AutomationProperties.Name="券码"
                     AutomationProperties.HelpText="可手动录入团购券码，或点右侧生成按钮自动生成店内券码" />
            <Button Grid.Column="1" Margin="8,0,0,0" Padding="14,4" Content="生成"
                    Click="Generate_Click"
                    AutomationProperties.Name="按当前类型生成无歧义字符的券码"
                    AutomationProperties.HelpText="按当前选择的券类型生成 SC 或 GB 前缀的随机券码" />
        </Grid>

        <TextBlock Grid.Row="4" Text="标题" Margin="0,0,0,4" />
        <TextBox Grid.Row="5" x:Name="TitleBox" Padding="6" Margin="0,0,0,10" />

        <!-- 抵扣方式互斥：满减面值 / 折扣率 二选一 -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="抵扣方式：" VerticalAlignment="Center" Margin="0,0,8,0" />
            <RadioButton x:Name="ModeFaceRadio" Content="满减面值" GroupName="DiscountMode" IsChecked="True"
                         VerticalAlignment="Center" Margin="0,0,12,0"
                         AutomationProperties.Name="按满减面值抵扣" />
            <RadioButton x:Name="ModePercentRadio" Content="折扣率" GroupName="DiscountMode"
                         VerticalAlignment="Center"
                         AutomationProperties.Name="按折扣率抵扣" />
        </StackPanel>

        <StackPanel Grid.Row="7" Margin="0,0,0,10"
                    Visibility="{Binding ElementName=ModeFaceRadio, Path=IsChecked, Converter={StaticResource BoolToVisible}}">
            <TextBlock Text="面值（元，结账时直接抵扣此金额）" Margin="0,0,0,4" />
            <TextBox x:Name="FaceBox" Padding="6" Text="0" />
        </StackPanel>
        <StackPanel Grid.Row="8" Margin="0,0,0,10"
                    Visibility="{Binding ElementName=ModePercentRadio, Path=IsChecked, Converter={StaticResource BoolToVisible}}">
            <TextBlock Text="折扣率（0.9 表示 9 折，0-1 之间）" Margin="0,0,0,4" />
            <TextBox x:Name="DiscountBox" Padding="6" Text="0" />
        </StackPanel>

        <TextBlock Grid.Row="9" Text="最低订单额（元，订单需达到才能用）" Margin="0,0,0,4" />
        <TextBox Grid.Row="10" x:Name="MinBox" Padding="6" Text="0" Margin="0,0,0,10" />

        <TextBlock Grid.Row="11" Text="来源平台（可空，如 美团）" Margin="0,0,0,4" />
        <TextBox Grid.Row="12" x:Name="PlatformBox" Padding="6" Margin="0,0,0,10" />

        <Grid Grid.Row="13" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="生效日期（可空）" Margin="0,0,0,4" />
                <DatePicker x:Name="FromBox" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="到期日期（可空）" Margin="0,0,0,4" />
                <DatePicker x:Name="ExpiryBox" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="14" Text="备注" Margin="0,0,0,4" />
        <TextBox Grid.Row="15" x:Name="RemarkBox" Padding="6" Height="50" TextWrapping="Wrap" AcceptsReturn="True" />

        <Border Grid.Row="17" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="保存" Padding="16,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
