<UserControl x:Class="MassageSaas.Cs.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="16"
            Background="White"
            CornerRadius="4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.3*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <CheckBox Margin="0,0,10,0"
                              VerticalAlignment="Center"
                              AutomationProperties.Name="仅显示库存预警"
                              Content="仅显示库存预警"
                              DockPanel.Dock="Left"
                              IsChecked="{Binding OnlyLowStock}" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Padding="16,0"
                                AutomationProperties.Name="建档"
                                Command="{Binding CreateCommand}"
                                Content="建档"
                                Style="{StaticResource PrimaryBtn}" />
                        <Button Margin="8,0,0,0"
                                Padding="16,0"
                                AutomationProperties.Name="刷新"
                                Command="{Binding ReloadCommand}"
                                Content="刷新"
                                Style="{StaticResource GhostBtn}" />
                    </StackPanel>
                </DockPanel>

                <DataGrid Grid.Row="1"
                          AlternatingRowBackground="#FAFAFA"
                          AutoGenerateColumns="False"
                          AutomationProperties.Name="物耗库存列表"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          ItemsSource="{Binding Rows}"
                          SelectedItem="{Binding Selected}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="100"
                                            Binding="{Binding Code}"
                                            Header="编码" />
                        <DataGridTextColumn Width="*"
                                            MinWidth="140"
                                            Binding="{Binding Name}"
                                            Header="名称" />
                        <DataGridTextColumn Width="60"
                                            Binding="{Binding Unit}"
                                            Header="单位" />
                        <DataGridTemplateColumn Width="130" Header="库存">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <TextBlock VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#303133" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LowStock}" Value="True">
                                                            <Setter Property="Foreground" Value="#C45656" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text="{Binding Quantity, StringFormat='{}{0:0.###}', Mode=OneWay}" /><Run Text=" " /><Run Text="{Binding Unit, Mode=OneWay}" />
                                        </TextBlock>
                                        <Border Margin="6,0,0,0"
                                                Padding="5,1"
                                                VerticalAlignment="Center"
                                                Background="#FDE2E2"
                                                CornerRadius="2"
                                                Visibility="{Binding LowStock, Converter={StaticResource BoolToVisible}}">
                                            <TextBlock FontSize="11"
                                                       Foreground="#C45656"
                                                       Text="预警" />
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Width="80"
                                            Binding="{Binding MinQuantity, StringFormat='{}{0:0.###}'}"
                                            Header="预警阈值" />
                        <DataGridTextColumn Width="80"
                                            Binding="{Binding UnitCost, StringFormat='{}{0:0.##}', TargetNullValue='—'}"
                                            Header="单价" />
                        <DataGridTemplateColumn Width="260" Header="操作">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button AutomationProperties.Name="入库"
                                                Background="#2D6A4F"
                                                Command="{Binding DataContext.PurchaseInCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Content="入库"
                                                Foreground="#fff"
                                                Style="{StaticResource RowGhost}" />
                                        <Button AutomationProperties.Name="领用"
                                                Background="Green"
                                                Command="{Binding DataContext.ConsumeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Content="领用"
                                                Foreground="#fff"
                                                Style="{StaticResource RowGhost}" />
                                        <Button AutomationProperties.Name="盘点"
                                                Background="Orange"
                                                Command="{Binding DataContext.AdjustCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Content="盘点"
                                                Foreground="#fff"
                                                Style="{StaticResource RowGhost}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!--  选中耗材的出入库流水  -->
            <Border Grid.Column="2"
                    Padding="10"
                    Background="#F7F9FB"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Margin="0,0,0,8"
                               FontWeight="SemiBold"
                               Text="出入库流水" />
                    <DataGrid Grid.Row="1"
                              AutoGenerateColumns="False"
                              Background="Transparent"
                              CanUserAddRows="False"
                              GridLinesVisibility="All"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Movements}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="150"
                                                Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                Header="时间" />
                            <DataGridTextColumn Width="90"
                                                Binding="{Binding Kind, Converter={StaticResource EnumLabel}}"
                                                Header="类型" />
                            <DataGridTextColumn Width="70"
                                                Binding="{Binding Delta, StringFormat='{}{0:+0.#;-0.#}'}"
                                                Header="变化" />
                            <DataGridTextColumn Width="70"
                                                Binding="{Binding QuantityAfter, StringFormat='{}{0:F1}'}"
                                                Header="结存" />
                            <DataGridTextColumn Width="*"
                                                Binding="{Binding Remark}"
                                                Header="备注" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
