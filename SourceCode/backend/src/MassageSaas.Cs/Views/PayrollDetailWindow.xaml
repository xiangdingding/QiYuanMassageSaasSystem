<Window x:Class="MassageSaas.Cs.Views.PayrollDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="工资单明细"
        Height="780" Width="1240"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部状态/汇总 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock DockPanel.Dock="Left" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"
                       Text="{Binding CurrentPeriod.Status, Converter={StaticResource EnumLabel}, StringFormat='工资单明细（状态：{0}，仅草稿可改）', FallbackValue=工资单明细}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="人数：" Foreground="#666" VerticalAlignment="Center" />
                <TextBlock Text="{Binding CurrentPeriod.ItemCount}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0" />
                <TextBlock Text="工资总额：" Foreground="#666" VerticalAlignment="Center" />
                <TextBlock Text="{Binding CurrentPeriod.TotalAmount, StringFormat='¥{0:F2}'}" FontWeight="SemiBold" Foreground="#D9534F" VerticalAlignment="Center" />
            </StackPanel>
        </DockPanel>

        <!-- 员工工资明细 -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding DetailItems}" SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="All" AlternatingRowBackground="#FAFAFA"
                  AutomationProperties.Name="员工工资明细">
            <DataGrid.Columns>
                <DataGridTextColumn Header="工号" Binding="{Binding EmployeeNo}" Width="60" />
                <DataGridTextColumn Header="员工" Binding="{Binding UserName}" Width="110" />
                <DataGridTextColumn Header="底薪" Binding="{Binding BaseSalary, StringFormat='¥{0:F0}'}" Width="90" />
                <DataGridTextColumn Header="服务提成" Binding="{Binding CommissionTotal, StringFormat='¥{0:F0}'}" Width="90" />
                <DataGridTextColumn Header="开卡提成" Binding="{Binding ReferralCommissionTotal, StringFormat='¥{0:F0}'}" Width="100" />
                <DataGridTemplateColumn Header="加班" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="{Binding OvertimeHours, StringFormat='{}{0:0.##}', Mode=OneWay}" /><Run Text="h / " /><Run Text="{Binding OvertimeAmount, StringFormat='¥{0:F0}', Mode=OneWay}" />
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="满勤" Binding="{Binding AttendanceBonus, StringFormat='¥{0:F0}'}" Width="80" />
                <DataGridTextColumn Header="调整" Binding="{Binding AdjustmentTotal, StringFormat='¥{0:F0}'}" Width="80" />
                <DataGridTextColumn Header="小费" Binding="{Binding TipsTotal, StringFormat='¥{0:F0}'}" Width="80" />
                <DataGridTextColumn Header="净额" Binding="{Binding NetTotal, StringFormat='¥{0:F2}'}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Foreground" Value="#D9534F" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="排班/请假" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="{Binding ScheduledDays, Mode=OneWay}" /><Run Text="/" /><Run Text="{Binding LeaveDays, StringFormat='{}{0:0.#}', Mode=OneWay}" />
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="操作" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="改"
                                        AutomationProperties.Name="改加班满勤"
                                        IsEnabled="{Binding DataContext.CurrentPeriod.Status, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEquals}, ConverterParameter=Draft}"
                                        Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource RowGhost}" />
                                <Button Content="奖/扣"
                                        AutomationProperties.Name="录入奖金扣款"
                                        IsEnabled="{Binding DataContext.CurrentPeriod.Status, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEquals}, ConverterParameter=Draft}"
                                        Command="{Binding DataContext.AddAdjustmentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource RowGhost}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 奖扣明细 -->
        <TextBlock Grid.Row="2" Margin="0,14,0,6" FontWeight="SemiBold" Foreground="#666"
                   Text="{Binding SelectedItem.UserName, StringFormat='{}{0} 的奖扣明细', FallbackValue=选中上方员工查看其奖扣明细}" />

        <DataGrid Grid.Row="3" ItemsSource="{Binding SelectedItem.Adjustments}" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                  GridLinesVisibility="All" Background="#F7F9FB" AlternatingRowBackground="#FFFFFF"
                  AutomationProperties.Name="奖扣明细">
            <DataGrid.Columns>
                <DataGridTextColumn Header="类型" Binding="{Binding Kind, Converter={StaticResource EnumLabel}}" Width="90" />
                <DataGridTextColumn Header="金额" Binding="{Binding Amount, StringFormat='¥{0:F2}'}" Width="120" />
                <DataGridTextColumn Header="原因" Binding="{Binding Reason}" Width="320" />
                <DataGridTextColumn Header="操作人" Binding="{Binding OperatorName}" Width="120" />
                <DataGridTextColumn Header="时间" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="170" />
                <DataGridTemplateColumn Header="操作" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="删除"
                                    AutomationProperties.Name="删除奖扣"
                                    IsEnabled="{Binding DataContext.CurrentPeriod.Status, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringEquals}, ConverterParameter=Draft}"
                                    Command="{Binding DataContext.RemoveAdjustmentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource RowDanger}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4" Margin="0,14,0,0" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="关闭" Padding="20,0" AutomationProperties.Name="关闭"
                        Click="Close_Click" Style="{StaticResource GhostBtn}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
