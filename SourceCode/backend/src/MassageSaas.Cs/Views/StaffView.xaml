<UserControl x:Class="MassageSaas.Cs.Views.StaffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls">
    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock DockPanel.Dock="Left" Text="员工管理" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBox Width="200"
                             Style="{StaticResource SearchBox}"
                             Tag="账号 / 姓名 / 手机号"
                             Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="搜索框" />
                    <ComboBox Width="120" Margin="8,0,0,0"
                              Style="{StaticResource FilterCombo}"
                              SelectedValuePath="Tag" SelectedValue="{Binding RoleFilter}"
                              AutomationProperties.Name="按角色过滤">
                        <ComboBoxItem Content="全部角色" Tag="" />
                        <ComboBoxItem Content="店主" Tag="ShopOwner" />
                        <ComboBoxItem Content="店长" Tag="StoreManager" />
                        <ComboBoxItem Content="收银员" Tag="Cashier" />
                        <ComboBoxItem Content="技师" Tag="Technician" />
                    </ComboBox>
                    <ComboBox Width="150" Margin="8,0,0,0"
                              Style="{StaticResource FilterCombo}"
                              ItemsSource="{Binding StoreOptions}"
                              SelectedValuePath="Id" SelectedValue="{Binding StoreFilter}"
                              AutomationProperties.Name="按门店过滤">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="查询" Padding="16,0" Margin="8,0,0,0" Command="{Binding SearchCommand}" Style="{StaticResource PrimaryBtn}" />
                    <Button Content="重置" Padding="16,0" Margin="8,0,0,0" Command="{Binding ResetQueryCommand}" Style="{StaticResource GhostBtn}" />
                    <Button Content="添加员工" Padding="16,0" Margin="8,0,0,0" Command="{Binding CreateCommand}" Style="{StaticResource PrimaryBtn}" />
                </StackPanel>
            </DockPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="All"
                      AlternatingRowBackground="#FAFAFA"
                      AutomationProperties.Name="员工列表">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="AutomationProperties.Name">
                            <Setter.Value>
                                <MultiBinding StringFormat="工号 {0}，{1}，{2}，{3}">
                                    <Binding Path="Dto.EmployeeNo" FallbackValue="无" />
                                    <Binding Path="Dto.RealName" FallbackValue="" />
                                    <Binding Path="Dto.Role" />
                                    <Binding Path="Dto.IsActive" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="工号" Binding="{Binding Dto.EmployeeNo}" Width="60" />
                    <DataGridTextColumn Header="账号" Binding="{Binding Dto.Username}" Width="*" MinWidth="130" />
                    <DataGridTextColumn Header="姓名" Binding="{Binding Dto.RealName}" Width="110" />
                    <DataGridTextColumn Header="手机号" Binding="{Binding Dto.Phone}" Width="120" />
                    <DataGridTextColumn Header="角色" Binding="{Binding Dto.Role, Converter={StaticResource EnumLabel}}" Width="90" />
                    <DataGridTextColumn Header="所属门店" Binding="{Binding StoreName}" Width="140" />
                    <DataGridTextColumn Header="盲人" Binding="{Binding Dto.IsBlind, Converter={StaticResource BoolLabel}, ConverterParameter='盲人|—'}" Width="60" />
                    <DataGridTemplateColumn Header="状态" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Background="{Binding Dto.IsActive, Converter={StaticResource ActiveStatusBrush}}">
                                    <TextBlock Foreground="White" FontSize="12"
                                               Text="{Binding Dto.IsActive, Converter={StaticResource BoolLabel}, ConverterParameter='在职|停职'}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="操作" Width="Auto" MinWidth="280">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="编辑"
                                            AutomationProperties.Name="编辑员工"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Dto}"
                                            Style="{StaticResource RowPrimary}" />
                                    <Button Content="重置密码"
                                            AutomationProperties.Name="重置密码"
                                            Command="{Binding DataContext.ResetPasswordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Dto}"
                                            Style="{StaticResource RowWarning}" />
                                    <Button Content="跨店调动"
                                            AutomationProperties.Name="跨店调动"
                                            Command="{Binding DataContext.TransferCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Dto}"
                                            Style="{StaticResource RowPrimary}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 分页（BS 端订单流水同款样式） -->
            <ctrl:PaginationBar Grid.Row="2" Margin="0,10,0,0"
                                Total="{Binding Total}"
                                Page="{Binding Page, Mode=TwoWay}"
                                PageSize="{Binding PageSize, Mode=TwoWay}"
                                PageChangedCommand="{Binding ReloadCommand}" />
        </Grid>
    </Border>
</UserControl>
