<Window x:Class="MassageSaas.Cs.Views.PickTechnicianWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="指派技师"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2D6A4F" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#245A41" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#9CC3B0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="#D1D5DB" BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F3F4F6" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 上钟方式分段切换：两段并排、单击切换、选中高亮，比下拉框更直观好操作 -->
        <Style x:Key="SegmentToggle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="0,9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EAF2EE" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2D6A4F" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#1B4332" />
                                <Setter TargetName="bd" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 钟数 −/＋ 步进按钮：字形用 TextBlock 居中渲染，保证全角 ＋ 完整显示不被裁 -->
        <Style x:Key="StepperBtn" TargetType="Button">
            <Setter Property="Background" Value="#F2F5F9" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="sb" Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="sb" Property="Background" Value="#E2E8F0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#C0C7D0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 单价 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock DockPanel.Dock="Left" Text="单价" Width="84" FontSize="14" Foreground="#666"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="UnitText" FontSize="18" FontWeight="Bold" Foreground="#D9534F"
                           AutomationProperties.Name="单价" />
                <TextBlock x:Name="DurationText" FontSize="13" Foreground="#999" Margin="10,0,0,0"
                           VerticalAlignment="Center" />
            </StackPanel>
        </DockPanel>

        <!-- 技师（必选） -->
        <DockPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock DockPanel.Dock="Left" Text="技师" Width="84" FontSize="14" Foreground="#666"
                       VerticalAlignment="Center" />
            <ComboBox x:Name="TechCombo"
                      Style="{StaticResource FilterCombo}"
                      SelectionChanged="Tech_SelectionChanged"
                      AutomationProperties.Name="选择技师"
                      AutomationProperties.HelpText="必选，选择为本服务上钟的技师">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding EmployeeNo, FallbackValue='-', Mode=OneWay}" />
                            <Run Text=" · " />
                            <Run Text="{Binding RealName, TargetNullValue='', Mode=OneWay}" />
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </DockPanel>

        <!-- 上钟方式 -->
        <DockPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock DockPanel.Dock="Left" Text="上钟方式" Width="84" FontSize="14" Foreground="#666"
                       VerticalAlignment="Center" />
            <Border BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="8" Background="#F3F4F6" Padding="3"
                    AutomationProperties.Name="上钟方式"
                    AutomationProperties.HelpText="轮钟为前台叫号下一位；点钟为客人指定技师">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="SourceRotation" Grid.Column="0" GroupName="Source" IsChecked="True"
                                 Content="轮钟（叫号）" Style="{StaticResource SegmentToggle}"
                                 AutomationProperties.Name="轮钟，前台叫号下一位" />
                    <RadioButton x:Name="SourceDesignation" Grid.Column="1" GroupName="Source"
                                 Content="点钟（客人指定）" Style="{StaticResource SegmentToggle}"
                                 AutomationProperties.Name="点钟，客人指定技师" />
                </Grid>
            </Border>
        </DockPanel>

        <!-- 数量 -->
        <DockPanel Grid.Row="3" Margin="0,0,0,18">
            <TextBlock DockPanel.Dock="Left" Text="数量" Width="84" FontSize="14" Foreground="#666"
                       VerticalAlignment="Center" />
            <Border HorizontalAlignment="Left" Width="140" Height="38"
                    Background="White" BorderBrush="#CBD5E0" BorderThickness="1"
                    CornerRadius="6" SnapsToDevicePixels="True">
                <Border CornerRadius="6" ClipToBounds="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="38" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="38" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="−" Style="{StaticResource StepperBtn}"
                                Click="Decrement_Click" AutomationProperties.Name="减少数量" />
                        <Border Grid.Column="1" BorderBrush="#E2E8F0" BorderThickness="1,0">
                            <TextBlock x:Name="QtyText" Text="1" FontSize="15" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       AutomationProperties.Name="数量" />
                        </Border>
                        <Button Grid.Column="2" Content="＋" Style="{StaticResource StepperBtn}"
                                Click="Increment_Click" AutomationProperties.Name="增加数量" />
                    </Grid>
                </Border>
            </Border>
        </DockPanel>

        <!-- 底栏 -->
        <Border Grid.Row="4" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="22,8" Margin="0,0,10,0"
                        Style="{StaticResource GhostButton}" Click="Cancel_Click"
                        AutomationProperties.Name="取消，放弃指派" />
                <Button x:Name="ConfirmButton" Content="加入订单" Padding="26,8" IsEnabled="False"
                        Style="{StaticResource PrimaryButton}" FontWeight="Bold" Click="Confirm_Click"
                        AutomationProperties.Name="加入订单" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
