<Window x:Class="MassageSaas.Cs.Views.InventoryMovementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls"
        Title="出入库登记"
        Width="420"
        ResizeMode="NoResize"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="Cap" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#999" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="Row" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="20">
        <Border Margin="0,12,0,0"
                Padding="0,12,0,0"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Margin="0,0,8,0"
                        Padding="20,0"
                        AutomationProperties.Name="取消"
                        Click="Cancel_Click"
                        Content="取消"
                        Style="{StaticResource GhostBtn}" />
                <Button Padding="20,0"
                        AutomationProperties.Name="提交"
                        Click="Save_Click"
                        Content="提交"
                        Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </Border>

        <StackPanel>
            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Style="{StaticResource Cap}"
                           Text="物品" />
                <TextBlock x:Name="ItemNameText"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
            </Grid>

            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource Cap}"><Run Foreground="#D9534F" Text="* " /><Run Text="数量" /></TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ctrl:NumericUpDown x:Name="DeltaBox"
                                        Width="150"
                                        HorizontalAlignment="Left"
                                        AutomationProperties.Name="数量"
                                        Decimals="3"
                                        Maximum="999999"
                                        Minimum="-999999"
                                        Step="1"
                                        Value="1" />
                    <TextBlock x:Name="DeltaHint" Style="{StaticResource Hint}" />
                </StackPanel>
            </Grid>

            <Grid Style="{StaticResource Row}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Style="{StaticResource Cap}"
                           Text="备注" />
                <TextBox x:Name="RemarkBox"
                         Grid.Column="1"
                         Height="152"
                         AutomationProperties.Name="备注"
                         MaxLength="200"
                         Style="{StaticResource FieldText}" />
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
