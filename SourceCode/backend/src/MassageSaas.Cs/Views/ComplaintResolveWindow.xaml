<Window x:Class="MassageSaas.Cs.Views.ComplaintResolveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="处理投诉"
        Height="440" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FEF3C7" CornerRadius="3" Padding="10" Margin="0,0,0,12">
            <TextBlock x:Name="SummaryText" Foreground="#92400E" TextWrapping="Wrap" />
        </Border>

        <TextBlock Grid.Row="1" Text="处理方式" Margin="0,0,0,4" Foreground="#666" />
        <ComboBox Grid.Row="2" x:Name="ResolutionBox" Width="200" HorizontalAlignment="Left" Margin="0,0,0,12"
                  AutomationProperties.Name="处理方式"
                  SelectionChanged="ResolutionBox_SelectionChanged"
                  Style="{StaticResource FilterCombo}">
            <ComboBoxItem x:Name="ReassignItem" Content="改派" Tag="Reassigned" />
            <ComboBoxItem x:Name="RefundItem" Content="退款" Tag="Refunded" />
            <ComboBoxItem Content="道歉/补偿" Tag="Apologized" />
            <ComboBoxItem Content="不予处理" Tag="NoAction" />
        </ComboBox>

        <TextBlock Grid.Row="3" x:Name="TechLabel" Text="改派至技师" Margin="0,0,0,4" Foreground="#666" />
        <ComboBox Grid.Row="4" x:Name="TechBox" Width="240" HorizontalAlignment="Left" Margin="0,0,0,12"
                  AutomationProperties.Name="改派至技师"
                  Style="{StaticResource FilterCombo}">
            <ComboBox.ItemTemplate>
                <DataTemplate><TextBlock Text="{Binding Name}" /></DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Grid.Row="5" Text="处理说明" Margin="0,0,0,4" Foreground="#666" />
        <TextBox Grid.Row="6" x:Name="NoteBox" Height="70" Margin="0,0,0,12" MaxLength="500"
                 AutomationProperties.Name="处理说明" Style="{StaticResource FieldTextMultiline}" />

        <Border Grid.Row="8" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="20,0" Margin="0,0,8,0" AutomationProperties.Name="取消"
                        Click="Cancel_Click" Style="{StaticResource GhostBtn}" />
                <Button Content="确认处理" Padding="20,0" AutomationProperties.Name="确认处理"
                        Click="Save_Click" Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
