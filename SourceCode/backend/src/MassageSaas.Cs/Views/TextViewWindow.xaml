<Window x:Class="MassageSaas.Cs.Views.TextViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="查看"
        Width="720"
        Height="640"
        Background="White"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText"
                   Margin="2,0,0,12"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#1F2937"
                   Text="查看" />

        <Border Grid.Row="1"
                BorderBrush="#EBEEF5"
                BorderThickness="1"
                CornerRadius="6">
            <TextBox x:Name="BodyText"
                     AutomationProperties.Name="正文内容"
                     BorderThickness="0"
                     FontSize="14"
                     IsReadOnly="True"
                     Padding="14"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
        </Border>

        <Button Grid.Row="2"
                Margin="0,12,0,0"
                Padding="24,6"
                HorizontalAlignment="Right"
                AutomationProperties.Name="关闭"
                Click="Close_Click"
                Content="关闭"
                IsCancel="True" />
    </Grid>
</Window>
