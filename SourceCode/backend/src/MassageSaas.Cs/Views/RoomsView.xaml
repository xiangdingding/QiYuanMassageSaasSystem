<UserControl x:Class="MassageSaas.Cs.Views.RoomsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock DockPanel.Dock="Left" Text="房间 / 床位" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="含已停用" IsChecked="{Binding IncludeInactive}" VerticalAlignment="Center" Margin="0,0,12,0"
                              AutomationProperties.Name="含已停用房间" />
                    <Button Content="新建房间" Padding="16,0"
                            Style="{StaticResource PrimaryBtn}"
                            Visibility="{Binding CanManage, Converter={StaticResource BoolToVisible}}"
                            Command="{Binding CreateCommand}"
                            AutomationProperties.Name="新建房间" />
                    <Button Content="刷新" Padding="16,0" Margin="8,0,0,0"
                            Style="{StaticResource GhostBtn}"
                            Command="{Binding ReloadCommand}"
                            AutomationProperties.Name="刷新房间列表" />
                </StackPanel>
            </DockPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                      AutomationProperties.Name="房间列表">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="AutomationProperties.Name">
                            <Setter.Value>
                                <MultiBinding StringFormat="{}{0} 号房，容客 {1} 人">
                                    <Binding Path="RoomNo" />
                                    <Binding Path="Capacity" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="房间号" Binding="{Binding RoomNo}" Width="100" />
                    <DataGridTextColumn Header="类型" Binding="{Binding TypeDisplay}" Width="110" />
                    <DataGridTextColumn Header="容客（人）" Binding="{Binding Capacity}" Width="90" />
                    <DataGridTextColumn Header="计时单价" Binding="{Binding HourlyRateDisplay}" Width="110" />
                    <DataGridTextColumn Header="状态" Binding="{Binding StatusDisplay}" Width="90" />
                    <DataGridTextColumn Header="计时进度" Binding="{Binding ProgressDisplay}" Width="*" />
                    <DataGridTemplateColumn Header="操作" Width="320">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="编辑" Style="{StaticResource RowGhost}"
                                            Visibility="{Binding DataContext.CanManage, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisible}}"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            AutomationProperties.Name="编辑房间" />
                                    <Button Content="取消计时" Style="{StaticResource RowDanger}"
                                            Visibility="{Binding ShowCancelTiming, Converter={StaticResource BoolToVisible}}"
                                            Command="{Binding DataContext.CancelTimingCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            AutomationProperties.Name="取消计时" />
                                    <Button Content="{Binding ToggleActiveLabel}" Style="{StaticResource RowGhost}"
                                            Visibility="{Binding DataContext.CanManage, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisible}}"
                                            Command="{Binding DataContext.ToggleActiveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            AutomationProperties.Name="{Binding ToggleActiveAutomationName}" />
                                    <Button Content="删除" Style="{StaticResource RowDanger}"
                                            Visibility="{Binding DataContext.CanManage, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisible}}"
                                            IsEnabled="{Binding CanDelete}"
                                            ToolTipService.ShowOnDisabled="True"
                                            ToolTip="仅已停用的房间可删除，请先停用"
                                            Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            AutomationProperties.Name="删除房间" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
