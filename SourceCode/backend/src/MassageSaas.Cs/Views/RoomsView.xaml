<UserControl x:Class="MassageSaas.Cs.Views.RoomsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock DockPanel.Dock="Left" Text="房间 / 床位" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <CheckBox Content="含已停用" IsChecked="{Binding IncludeInactive}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Content="新建房间" Padding="12,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Command="{Binding CreateCommand}" />
                    <Button Content="刷新" Padding="12,6" Margin="8,0,0,0" Command="{Binding ReloadCommand}" />
                </StackPanel>
            </DockPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                      AutomationProperties.Name="房间列表">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="AutomationProperties.Name">
                            <Setter.Value>
                                <MultiBinding StringFormat="{}{0} 号房，容客 {1} 人，{2}">
                                    <Binding Path="RoomNo" />
                                    <Binding Path="Capacity" />
                                    <Binding Path="OccupiedByOrderNo" FallbackValue="空闲" TargetNullValue="空闲" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="房间号" Binding="{Binding RoomNo}" Width="100" />
                    <DataGridTextColumn Header="类型" Binding="{Binding RoomType, Converter={StaticResource RoomTypeDisplay}}" Width="120" />
                    <DataGridTextColumn Header="容客（人）" Binding="{Binding Capacity}" Width="100" />
                    <DataGridTextColumn Header="占用中" Binding="{Binding IsOccupied}" Width="80" />
                    <DataGridTextColumn Header="占用订单" Binding="{Binding OccupiedByOrderNo}" Width="160" />
                    <DataGridTextColumn Header="启用" Binding="{Binding IsActive}" Width="60" />
                    <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="240" />
                    <DataGridTemplateColumn Header="操作" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Margin="2" Padding="6,2" Content="编辑"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                    <Button Margin="2" Padding="6,2" Content="删除" Background="#D9534F" Foreground="White" BorderThickness="0"
                                            Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
