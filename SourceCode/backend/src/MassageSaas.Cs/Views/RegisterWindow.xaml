<Window x:Class="MassageSaas.Cs.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="注册新店铺"
        Height="720" Width="920"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/AuthStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Margin="14" CornerRadius="12" Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.18" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧品牌区 -->
            <Border Grid.Column="0" Background="{StaticResource BrandGradient}" CornerRadius="12,0,0,12">
                <StackPanel VerticalAlignment="Center" Margin="40,0">
                    <Border Width="80" Height="80" CornerRadius="40" Background="#33FFFFFF"
                            HorizontalAlignment="Left" Margin="0,0,0,28">
                        <TextBlock Text="齐源" FontSize="26" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="开店，从这里开始" Foreground="White" FontSize="24" FontWeight="Bold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="注册即创建一家新门店，自动获得 30 天免费试用，无需付费即可体验全部功能。"
                               Foreground="#CFE6DA" FontSize="14" Margin="0,16,0,0" TextWrapping="Wrap" LineHeight="22" />

                    <StackPanel Margin="0,36,0,0">
                        <TextBlock Text="✓  收银 · 会员 · 排钟 · 报表" Foreground="#EAF7F0" FontSize="13" Margin="0,0,0,10" />
                        <TextBlock Text="✓  总店 + 分店多门店管理" Foreground="#EAF7F0" FontSize="13" Margin="0,0,0,10" />
                        <TextBlock Text="✓  无障碍适配，读屏可用" Foreground="#EAF7F0" FontSize="13" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 右侧表单区 -->
            <Border Grid.Column="1" Background="White" CornerRadius="0,12,12,0">
                <DockPanel Margin="40,32,40,24">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="注册新店铺" FontSize="24" FontWeight="Bold" Foreground="#1F2933" />
                        <TextBlock Text="填写门店与店主登录信息，手机号即登录账号"
                                   FontSize="13" Foreground="#8A929B" Margin="0,6,0,18" />
                    </StackPanel>

                    <Border DockPanel.Dock="Bottom" Margin="0,16,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <CheckBox x:Name="AgreeCheck" VerticalAlignment="Center"
                                          AutomationProperties.Name="我已阅读并同意用户服务协议和隐私协议" />
                                <TextBlock VerticalAlignment="Center" Margin="6,0,0,0" FontSize="13"
                                           Foreground="#5A6470" TextWrapping="Wrap">
                                    <Run Text="我已阅读并同意" />
                                    <Hyperlink Click="ServiceAgreement_Click">《用户服务协议》</Hyperlink>
                                    <Run Text="和" />
                                    <Hyperlink Click="PrivacyPolicy_Click">《隐私协议》</Hyperlink>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock x:Name="ErrorText" Foreground="#D9534F" FontSize="13"
                                       TextWrapping="Wrap" Margin="0,0,0,12" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="取消" Style="{StaticResource OutlineButton}" Width="110"
                                        Margin="0,0,12,0" Click="Cancel_Click" IsCancel="True"
                                        AutomationProperties.Name="取消注册" />
                                <Button x:Name="SubmitButton" Content="注 册" Style="{StaticResource PrimaryButton}"
                                        Width="160" Click="Submit_Click" IsDefault="True"
                                        AutomationProperties.Name="提交注册" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Text="店铺名" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="NameBox" Style="{StaticResource RoundedTextBox}" MaxLength="64"
                                 Margin="0,0,0,18" AutomationProperties.Name="店铺名"
                                 AutomationProperties.HelpText="如：齐源按摩中心" />

                        <TextBlock Text="联系人（可选）" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="ContactNameBox" Style="{StaticResource RoundedTextBox}" MaxLength="32"
                                 Margin="0,0,0,18" AutomationProperties.Name="联系人" />

                        <TextBlock Text="登录手机号" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="OwnerPhoneBox" Style="{StaticResource RoundedTextBox}" MaxLength="11"
                                 Margin="0,0,0,4" AutomationProperties.Name="登录手机号"
                                 AutomationProperties.HelpText="店长 / 店员都用手机号登录，同时作为店铺联系电话" />
                        <TextBlock Text="店长 / 店员都用手机号登录，同时作为店铺联系电话"
                                   FontSize="12" Foreground="#8A929B" TextWrapping="Wrap"
                                   Margin="2,0,0,18" />

                        <TextBlock Text="登录密码（至少 6 位）" Style="{StaticResource FieldLabel}" />
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource RoundedPasswordBox}"
                                     Margin="0,0,0,18"
                                     AutomationProperties.Name="登录密码"
                                     AutomationProperties.HelpText="至少 6 位，登录时使用" />

                        <TextBlock Text="确认密码" Style="{StaticResource FieldLabel}" />
                        <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource RoundedPasswordBox}"
                                     AutomationProperties.Name="确认密码"
                                     AutomationProperties.HelpText="再次输入登录密码" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 可拖动标题条 -->
            <Border Grid.ColumnSpan="2" VerticalAlignment="Top" Height="46"
                    Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown" />

            <!-- 关闭按钮 -->
            <Button Grid.Column="1" Style="{StaticResource WindowCloseButton}" Content="✕"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,14,0"
                    Click="Cancel_Click" ToolTip="关闭" AutomationProperties.Name="关闭窗口" />
        </Grid>
    </Border>
</Window>
