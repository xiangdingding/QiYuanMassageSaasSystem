<UserControl x:Class="MassageSaas.Cs.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseDetailCommand}" />
    </UserControl.InputBindings>
    <UserControl.Resources>
        <!--  圆角下拉框 / 搜索框 / 主次按钮：与预约管理界面统一  -->
        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="Toggle"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd"
                                                Background="White"
                                                BorderBrush="#D1D5DB"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="26" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="10,0,0,0"
                                                                  VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Path Grid.Column="1"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M0,0 L4,4 L8,0"
                                                      Stroke="#9CA3AF"
                                                      StrokeThickness="1.4" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        Margin="0,4,0,0"
                                        Background="White"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer MaxHeight="260">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" />
                                <TextBlock x:Name="ph"
                                           Margin="11,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#9CA3AF"
                                           IsHitTestVisible="False"
                                           Text="{TemplateBinding Tag}"
                                           Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="ph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="#2D6A4F" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#245A41" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#9CC3B0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F3F4F6" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>
    <Border Padding="16"
            Background="White"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  工具栏：状态 / 关键字 / 日期范围 / 查询 / 重置（去标题，统一圆角控件与按钮）  -->
            <WrapPanel Grid.Row="0"
                       Margin="0,0,0,12"
                       VerticalAlignment="Center">
                <TextBlock Margin="8,0,8,0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#6B7280"
                           Text="状态" />
                <ComboBox Width="130"
                          Height="34"
                          VerticalAlignment="Center"
                          VerticalContentAlignment="Center"
                          AutomationProperties.Name="订单状态筛选"
                          SelectedValue="{Binding StatusFilter}"
                          SelectedValuePath="Tag"
                          Style="{StaticResource FilterCombo}">
                    <ComboBoxItem Content="全部状态" Tag="" />
                    <ComboBoxItem Content="待结账" Tag="Pending" />
                    <ComboBoxItem Content="已完成" Tag="Completed" />
                    <ComboBoxItem Content="已取消" Tag="Cancelled" />
                    <ComboBoxItem Content="已退款" Tag="Refunded" />
                </ComboBox>
                <TextBox Width="240"
                         Margin="8,0,0,0"
                         AutomationProperties.HelpText="按订单号、会员卡号、姓名或手机号查询，回车搜索"
                         AutomationProperties.Name="按订单号、会员卡号、姓名或手机号查询，回车搜索"
                         Style="{StaticResource SearchBox}"
                         Tag="订单号 / 会员卡号 / 姓名 / 手机号"
                         Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <TextBlock Margin="8,0,8,0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#6B7280"
                           Text="开始日期" />

                <DatePicker Width="170"
                            Margin="8,0,8,0"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="开始日期"
                            PreviewMouseLeftButtonUp="DatePicker_PreviewMouseUp"
                            SelectedDate="{Binding FromDate, Mode=TwoWay}"
                            SelectedDateFormat="Short"
                            Style="{StaticResource FilterDatePicker}" />


                <TextBlock Margin="8,0,8,0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#6B7280"
                           Text="至" />
                <DatePicker Width="170"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="结束日期"
                            PreviewMouseLeftButtonUp="DatePicker_PreviewMouseUp"
                            SelectedDate="{Binding ToDate, Mode=TwoWay}"
                            SelectedDateFormat="Short"
                            Style="{StaticResource FilterDatePicker}" />
                <Button Margin="12,0,0,0"
                        Padding="16,0"
                        AutomationProperties.Name="查询"
                        Command="{Binding SearchCommand}"
                        Content="查询"
                        Style="{StaticResource PrimaryBtn}" />
                <Button Margin="8,0,0,0"
                        Padding="16,0"
                        AutomationProperties.Name="重置筛选"
                        Command="{Binding ResetCommand}"
                        Content="重置"
                        Style="{StaticResource GhostBtn}" />
            </WrapPanel>

            <!--  列表铺满整宽；详情以右侧抽屉叠加显示  -->
            <Grid Grid.Row="1">

                <!--  列表 + 分页  -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              AutomationProperties.Name="订单流水列表，双击查看详情"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              GridLinesVisibility="All"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Rows}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="AutomationProperties.Name">
                                    <Setter.Value>
                                        <MultiBinding StringFormat="订单 {0}，金额 {1:F2} 元">
                                            <Binding Path="OrderNo" />
                                            <Binding Path="PaidAmount" />
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.InputBindings>
                            <MouseBinding Command="{Binding ShowDetailCommand}"
                                          CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          Gesture="LeftDoubleClick" />
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="160"
                                                Binding="{Binding OrderNo}"
                                                Header="订单号" />
                            <DataGridTextColumn Width="50"
                                                Binding="{Binding ItemCount}"
                                                Header="项数" />
                            <DataGridTextColumn Width="78"
                                                Binding="{Binding Total, StringFormat='¥{0:F2}'}"
                                                Header="金额" />
                            <DataGridTextColumn Width="78"
                                                Binding="{Binding PaidAmount, StringFormat='¥{0:F2}'}"
                                                Header="实收" />
                            <DataGridTextColumn Width="70"
                                                Binding="{Binding PayMethod, Converter={StaticResource EnumLabel}}"
                                                Header="支付" />
                            <DataGridTextColumn Width="70"
                                                Binding="{Binding Status, Converter={StaticResource EnumLabel}}"
                                                Header="状态" />
                            <DataGridTextColumn Width="130"
                                                Binding="{Binding MemberCardNo, TargetNullValue='散客'}"
                                                Header="会员卡号" />
                            <DataGridTextColumn Width="*"
                                                MinWidth="120"
                                                Binding="{Binding MemberPhone, TargetNullValue='散客'}"
                                                Header="会员手机号" />
                            <DataGridTextColumn Width="130"
                                                Binding="{Binding CompletedAt, StringFormat='yyyy-MM-dd HH:mm', TargetNullValue=''}"
                                                Header="消费时间" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!--  分页（BS 端订单流水同款样式）  -->
                    <ctrl:PaginationBar Grid.Row="1"
                                        Margin="0,8,0,0"
                                        Page="{Binding Page, Mode=TwoWay}"
                                        PageChangedCommand="{Binding ReloadCommand}"
                                        PageSize="{Binding PageSize, Mode=TwoWay}"
                                        Total="{Binding Total}" />
                </Grid>

                <!--  详情抽屉：遮罩 + 右侧滑入面板（对齐 BS 端 el-drawer）  -->
                <Grid Panel.ZIndex="10" Visibility="{Binding IsDetailOpen, Converter={StaticResource BoolToVisible}}">
                    <!--  半透明遮罩，点击空白处关闭  -->
                    <Rectangle Fill="#44000000">
                        <Rectangle.InputBindings>
                            <MouseBinding Command="{Binding CloseDetailCommand}" Gesture="LeftClick" />
                        </Rectangle.InputBindings>
                    </Rectangle>

                    <!--  抽屉本体：右侧、固定宽度、白底、左侧投影、自右滑入  -->
                    <Border Width="520"
                            HorizontalAlignment="Right"
                            Background="White"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1,0,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18"
                                              Opacity="0.18"
                                              ShadowDepth="0"
                                              Color="#000000" />
                        </Border.Effect>
                        <Border.RenderTransform>
                            <TranslateTransform X="520" />
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDetailOpen}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.X"
                                                                     From="520"
                                                                     To="0"
                                                                     Duration="0:0:0.22">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  抽屉头部：标题 + 关闭  -->
                            <Border Grid.Row="0"
                                    Padding="16,12"
                                    Background="#F7FAF8"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <Button Width="28"
                                            Height="28"
                                            AutomationProperties.Name="关闭详情"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding CloseDetailCommand}"
                                            Content="✕"
                                            Cursor="Hand"
                                            DockPanel.Dock="Right"
                                            FontSize="15"
                                            Foreground="#888" />
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Text="{Binding SelectedDetail.OrderNo, StringFormat='订单详情：{0}'}" />
                                </DockPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1"
                                          Padding="16,12"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>

                                    <!--  概要  -->
                                    <Border Margin="0,8,0,0"
                                            Padding="10,8"
                                            Background="#F7FAF8"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock Margin="0,0,0,3">
                                                <Run Foreground="#666" Text="状态：" /><Run FontWeight="SemiBold" Text="{Binding SelectedDetail.Status, Converter={StaticResource EnumLabel}, Mode=OneWay}" />
                                                <Run Foreground="#666" Text="    支付：" /><Run Text="{Binding SelectedDetail.PayMethod, Converter={StaticResource EnumLabel}, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Margin="0,0,0,3">
                                                <Run Foreground="#666" Text="合计：¥" /><Run Text="{Binding SelectedDetail.Total, StringFormat='F2', Mode=OneWay}" />
                                                <Run Foreground="#666" Text="    优惠：¥" /><Run Text="{Binding SelectedDetail.DiscountAmount, StringFormat='F2', Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Margin="0,0,0,3">
                                                <Run Foreground="#666" Text="实收：¥" /><Run FontWeight="Bold"
                                                     Foreground="#D9534F"
                                                     Text="{Binding SelectedDetail.PaidAmount, StringFormat='F2', Mode=OneWay}" />
                                                <Run Foreground="#666" Text="    收银员：" /><Run Text="{Binding SelectedDetail.CashierName, TargetNullValue='—', Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Margin="0,0,0,3"
                                                       Foreground="#2D6A4F"
                                                       Visibility="{Binding HasPunch, Converter={StaticResource BoolToVisible}}">
                                                <Run Text="消费次数：" /><Run Text="{Binding SelectedDetail.PunchCardUsedCount, Mode=OneWay}" /><Run Text=" 次（次卡核销）" />
                                            </TextBlock>
                                            <StackPanel Visibility="{Binding IsMemberOrder, Converter={StaticResource BoolToVisible}}">
                                                <TextBlock Margin="0,0,0,3">
                                                    <Run Foreground="#666" Text="会员卡号：" /><Run Text="{Binding SelectedDetail.MemberCardNo, TargetNullValue='—', Mode=OneWay}" />
                                                    <Run Foreground="#666" Text="    手机：" /><Run Text="{Binding SelectedDetail.MemberPhone, TargetNullValue='—', Mode=OneWay}" />
                                                </TextBlock>
                                                <TextBlock>
                                                    <Run Foreground="#666" Text="会员：" /><Run Text="{Binding SelectedDetail.MemberName, TargetNullValue='—', Mode=OneWay}" />
                                                    <Run Foreground="#666" Text="    卡类型：" /><Run Text="{Binding SelectedDetail.MemberTypeName, TargetNullValue='普通', Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Margin="0,3,0,0" TextWrapping="Wrap">
                                                <Run Foreground="#666" Text="备注：" /><Run Text="{Binding SelectedDetail.Remark, TargetNullValue='—', Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!--  项目明细  -->
                                    <TextBlock Margin="0,12,0,4"
                                               FontWeight="SemiBold"
                                               Text="项目明细" />
                                    <ItemsControl ItemsSource="{Binding DetailItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="0,6"
                                                        BorderBrush="#EEE"
                                                        BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock VerticalAlignment="Center"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding ServiceName}" />
                                                                <Border Margin="6,0,0,0"
                                                                        Padding="4,1"
                                                                        VerticalAlignment="Center"
                                                                        Background="#E6F4EA"
                                                                        CornerRadius="3"
                                                                        Visibility="{Binding IsPunch, Converter={StaticResource BoolToVisible}}">
                                                                    <TextBlock FontSize="11"
                                                                               Foreground="#2D6A4F"
                                                                               Text="次卡" />
                                                                </Border>
                                                            </StackPanel>
                                                            <StackPanel Margin="0,2,0,0" Orientation="Horizontal">
                                                                <TextBlock VerticalAlignment="Center"
                                                                           FontSize="12"
                                                                           Foreground="#666">
                                                                    <Run Text="技师：" /><Run Text="{Binding TechnicianName, Mode=OneWay}" />
                                                                    <Run Text="  房间：" /><Run Text="{Binding RoomNo, Mode=OneWay}" />
                                                                    <Run Text="  " /><Run Text="{Binding QuantityText, Mode=OneWay}" />
                                                                </TextBlock>
                                                                <Border Margin="4,0,0,0"
                                                                        Padding="4,1"
                                                                        VerticalAlignment="Center"
                                                                        Background="#EEF2F7"
                                                                        CornerRadius="3"
                                                                        Visibility="{Binding ShowAssignTag, Converter={StaticResource BoolToVisible}}">
                                                                    <TextBlock FontSize="11"
                                                                               Foreground="#666"
                                                                               Text="{Binding AssignTag}" />
                                                                </Border>
                                                                <Border Margin="4,0,0,0"
                                                                        Padding="4,1"
                                                                        VerticalAlignment="Center"
                                                                        Background="#FEF3C7"
                                                                        CornerRadius="3"
                                                                        Visibility="{Binding ShowTransferred, Converter={StaticResource BoolToVisible}}">
                                                                    <TextBlock FontSize="11"
                                                                               Foreground="#92400E"
                                                                               Text="已转" />
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Margin="0,2,0,0"
                                                                       FontSize="12"
                                                                       Foreground="#888">
                                                                <Run Text="金额 " /><Run Text="{Binding AmountText, Mode=OneWay}" />
                                                                <Run Text="  提成 " /><Run Text="{Binding CommissionText, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <Button Padding="10,4"
                                                                    AutomationProperties.Name="转钟，更换技师"
                                                                    Command="{Binding DataContext.TransferCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="转钟"
                                                                    FontSize="12"
                                                                    Visibility="{Binding CanTransfer, Converter={StaticResource BoolToVisible}}" />
                                                            <Button Margin="0,4,0,0"
                                                                    Padding="10,4"
                                                                    AutomationProperties.Name="登记投诉"
                                                                    Background="#E6A23C"
                                                                    BorderThickness="0"
                                                                    Command="{Binding DataContext.ComplaintCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="投诉"
                                                                    FontSize="12"
                                                                    Foreground="White"
                                                                    Visibility="{Binding CanComplain, Converter={StaticResource BoolToVisible}}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!--  计时房费  -->
                                    <StackPanel Visibility="{Binding HasRoomCharges, Converter={StaticResource BoolToVisible}}">
                                        <TextBlock Margin="0,12,0,4"
                                                   FontWeight="SemiBold"
                                                   Text="计时房费" />
                                        <ItemsControl ItemsSource="{Binding SelectedDetail.RoomCharges}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="0,5"
                                                            BorderBrush="#EEE"
                                                            BorderThickness="0,0,0,1">
                                                        <DockPanel>
                                                            <Border Margin="0,0,6,0"
                                                                    Padding="5,1"
                                                                    VerticalAlignment="Center"
                                                                    Background="#2D6A4F"
                                                                    CornerRadius="2"
                                                                    DockPanel.Dock="Left">
                                                                <TextBlock FontSize="11"
                                                                           Foreground="White"
                                                                           Text="计时房" />
                                                            </Border>
                                                            <TextBlock HorizontalAlignment="Right"
                                                                       VerticalAlignment="Center"
                                                                       DockPanel.Dock="Right"
                                                                       FontWeight="Bold"
                                                                       Foreground="#D9534F"
                                                                       Text="{Binding Amount, StringFormat='¥{0:F2}'}" />
                                                            <TextBlock VerticalAlignment="Center"
                                                                       FontSize="12"
                                                                       Foreground="#666">
                                                                <Run Text="{Binding RoomNo, Mode=OneWay}" />
                                                                <Run Text="  " /><Run Text="{Binding Minutes, Mode=OneWay}" /><Run Text=" 分钟" />
                                                                <Run Text="  ¥" /><Run Text="{Binding HourlyRate, StringFormat='F2', Mode=OneWay}" /><Run Text="/时" />
                                                            </TextBlock>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!--  订单操作  -->
                                    <StackPanel Margin="0,16,0,0"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal">
                                        <Button Margin="0,0,8,0"
                                                Padding="14,6"
                                                AutomationProperties.Name="退款"
                                                Background="#D9534F"
                                                BorderThickness="0"
                                                Command="{Binding RefundCommand}"
                                                Content="退款"
                                                Foreground="White"
                                                Visibility="{Binding CanRefund, Converter={StaticResource BoolToVisible}}" />
                                        <Button Padding="14,6"
                                                AutomationProperties.Name="取消订单"
                                                Command="{Binding CancelCommand}"
                                                Content="取消订单"
                                                Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisible}}" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
