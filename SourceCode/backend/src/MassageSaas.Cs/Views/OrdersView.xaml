<UserControl x:Class="MassageSaas.Cs.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock DockPanel.Dock="Left" Text="订单流水" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="状态：" VerticalAlignment="Center" />
                    <ComboBox Width="120" SelectedValuePath="Tag" SelectedValue="{Binding StatusFilter}">
                        <ComboBoxItem Content="全部" Tag="" />
                        <ComboBoxItem Content="待结账" Tag="Pending" />
                        <ComboBoxItem Content="已完成" Tag="Completed" />
                        <ComboBoxItem Content="已取消" Tag="Cancelled" />
                        <ComboBoxItem Content="已退款" Tag="Refunded" />
                    </ComboBox>
                    <Button Content="刷新" Padding="12,6" Margin="8,0,0,0" Command="{Binding ReloadCommand}" />
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="420" />
                </Grid.ColumnDefinitions>

                <DataGrid Grid.Column="0" ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#FAFAFA"
                          AutomationProperties.Name="订单流水列表，回车键查看详情">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="AutomationProperties.Name">
                                <Setter.Value>
                                    <MultiBinding StringFormat="订单 {0}，{1}，金额 {2:F2} 元，{3}">
                                        <Binding Path="OrderNo" />
                                        <Binding Path="Status" />
                                        <Binding Path="PaidAmount" />
                                        <Binding Path="PayMethod" />
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.InputBindings>
                        <MouseBinding Gesture="LeftDoubleClick"
                                      Command="{Binding ShowDetailCommand}"
                                      CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="订单号" Binding="{Binding OrderNo}" Width="160" />
                        <DataGridTextColumn Header="项数" Binding="{Binding ItemCount}" Width="60" />
                        <DataGridTextColumn Header="金额" Binding="{Binding Total, StringFormat='¥{0:F2}'}" Width="80" />
                        <DataGridTextColumn Header="实收" Binding="{Binding PaidAmount, StringFormat='¥{0:F2}'}" Width="80" />
                        <DataGridTextColumn Header="支付" Binding="{Binding PayMethod}" Width="80" />
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80" />
                        <DataGridTextColumn Header="时间" Binding="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Column="1" BorderBrush="#E5E7EB" BorderThickness="1,0,0,0" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding SelectedDetail}">
                            <TextBlock FontSize="14" FontWeight="Bold" Text="{Binding OrderNo, StringFormat='订单详情：{0}'}" />
                            <TextBlock Margin="0,4,0,0">
                                <Run Text="状态：" /><Run Text="{Binding Status}" />
                                <Run Text="    支付：" /><Run Text="{Binding PayMethod}" />
                            </TextBlock>
                            <TextBlock>
                                <Run Text="合计：¥" /><Run Text="{Binding Total, StringFormat='F2'}" />
                                <Run Text="    实收：¥" /><Run Text="{Binding PaidAmount, StringFormat='F2'}" />
                            </TextBlock>
                            <TextBlock Margin="0,8,0,4" FontWeight="SemiBold" Text="项目明细" />
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding ServiceName}" FontWeight="SemiBold" />
                                                    <TextBlock FontSize="12" Foreground="#666">
                                                        <Run Text="技师：" /><Run Text="{Binding TechnicianName}" />
                                                        <Run Text="    房间：" /><Run Text="{Binding RoomNo, FallbackValue='—'}" />
                                                        <Run Text="    数量：" /><Run Text="{Binding Quantity}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock VerticalAlignment="Center"
                                                               Text="{Binding ItemTotal, StringFormat='¥{0:F2}'}" FontWeight="Bold" />
                                                    <Button Content="投诉" Padding="8,3" Margin="12,0,0,0"
                                                            Background="#E6A23C" Foreground="White" BorderThickness="0"
                                                            Command="{Binding DataContext.ComplaintCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="退款" Padding="12,6" Margin="0,0,8,0"
                                        Background="#D9534F" Foreground="White" BorderThickness="0"
                                        Command="{Binding DataContext.RefundCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <Button Content="取消订单" Padding="12,6"
                                        Command="{Binding DataContext.CancelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
