<UserControl x:Class="MassageSaas.Cs.Views.MembersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- 小徽标 -->
        <Style x:Key="Badge" TargetType="Border">
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="#EEF1F5" />
        </Style>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock DockPanel.Dock="Left" Text="会员管理" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0" />
                <CheckBox DockPanel.Dock="Left" Content="含已关闭" VerticalAlignment="Center"
                          IsChecked="{Binding IncludeClosed, Mode=TwoWay}" Margin="0,0,12,0" />
                <Button DockPanel.Dock="Right" Padding="12,0" Height="32" Content="开卡"
                        Background="#2D6A4F" Foreground="White" BorderThickness="0" Command="{Binding CreateCommand}" />
                <Button DockPanel.Dock="Right" Padding="12,0" Height="32" Margin="0,0,8,0" Content="重置"
                        Command="{Binding ResetCommand}" />
                <Button DockPanel.Dock="Right" Padding="12,0" Height="32" Margin="0,0,8,0" Content="查询"
                        Command="{Binding ReloadCommand}" />
                <TextBox Height="32" Padding="8,0" VerticalContentAlignment="Center"
                         Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="搜索会员，卡号/手机号/姓名">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding ReloadCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
            </DockPanel>

            <Grid Grid.Row="1">
                <TextBlock Text="暂无会员，使用上方“开卡”按钮新开第一张" Foreground="#AAA"
                           HorizontalAlignment="Center" Margin="0,40,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Groups.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Groups}" AutomationProperties.Name="会员列表，按手机号聚合">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Margin="0,0,0,8" Background="#FAFBFC" BorderBrush="#E5E7EB" BorderThickness="1"
                                          AutomationProperties.Name="{Binding Phone}">
                                    <Expander.Header>
                                        <DockPanel LastChildFill="True" Margin="4,4,8,4">
                                            <Button DockPanel.Dock="Right" Content="加办一张卡" Padding="10,3" VerticalAlignment="Center"
                                                    Background="#2D6A4F" Foreground="White" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding DataContext.CreateForPhoneCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Phone}"
                                                    AutomationProperties.Name="加办一张卡" />
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Phone}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#444" VerticalAlignment="Center" Margin="10,0,0,0" />
                                                    <Border Style="{StaticResource Badge}" Background="#F0E6D2"
                                                            Visibility="{Binding HasInactive, Converter={StaticResource BoolToVisible}}">
                                                        <TextBlock Text="含关闭卡" FontSize="11" Foreground="#9A7B3F" />
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Foreground="#888" FontSize="12">
                                                        <Run Text="持卡 " /><Run Text="{Binding CardCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="#444" /><Run Text=" 张" />
                                                    </TextBlock>
                                                    <TextBlock Margin="16,0,0,0" Foreground="#888" FontSize="12">
                                                        <Run Text="总余额 ¥" /><Run Text="{Binding TotalBalance, StringFormat='F2', Mode=OneWay}" FontWeight="SemiBold" Foreground="#D9534F" />
                                                    </TextBlock>
                                                    <TextBlock Margin="16,0,0,0" Foreground="#888" FontSize="12">
                                                        <Run Text="累计充值 ¥" /><Run Text="{Binding TotalRecharge, StringFormat='F2', Mode=OneWay}" Foreground="#444" />
                                                    </TextBlock>
                                                    <TextBlock Margin="16,0,0,0" Foreground="#888" FontSize="12">
                                                        <Run Text="累计消费 ¥" /><Run Text="{Binding TotalConsumed, StringFormat='F2', Mode=OneWay}" Foreground="#444" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </DockPanel>
                                    </Expander.Header>

                                    <!-- 名下卡列表 -->
                                    <ItemsControl ItemsSource="{Binding Cards}" Margin="8,4,8,8">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="White" BorderBrush="#ECEFF2" BorderThickness="1" CornerRadius="3"
                                                        Padding="10,8" Margin="0,0,0,6">
                                                    <DockPanel LastChildFill="True">
                                                        <!-- 操作 -->
                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Content="充值" Padding="8,2" Margin="2"
                                                                    IsEnabled="{Binding CanRecharge}"
                                                                    Command="{Binding DataContext.RechargeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding Dto}" />
                                                            <Button Content="办卡" Padding="8,2" Margin="2"
                                                                    IsEnabled="{Binding CanRecharge}"
                                                                    Command="{Binding DataContext.IssueCardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding Dto}" />
                                                            <Button Content="流水" Padding="8,2" Margin="2"
                                                                    Command="{Binding DataContext.ShowHistoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding Dto}" />
                                                            <Button Content="编辑" Padding="8,2" Margin="2"
                                                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding Dto}" />
                                                            <Button Content="退卡" Padding="8,2" Margin="2"
                                                                    IsEnabled="{Binding CanRefundOrTransfer}"
                                                                    Command="{Binding DataContext.RefundCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding Dto}" />
                                                            <Button Content="转赠" Padding="8,2" Margin="2"
                                                                    IsEnabled="{Binding CanRefundOrTransfer}"
                                                                    Command="{Binding DataContext.TransferCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding Dto}" />
                                                            <Button Content="引荐" Padding="8,2" Margin="2"
                                                                    Command="{Binding DataContext.ShowReferralsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding Dto}" />
                                                        </StackPanel>
                                                        <!-- 卡信息 -->
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock VerticalAlignment="Center">
                                                                    <Run Text="卡号 " Foreground="#888" /><Run Text="{Binding CardNo, Mode=OneWay}" FontWeight="SemiBold" />
                                                                </TextBlock>
                                                                <Border Style="{StaticResource Badge}"
                                                                        Visibility="{Binding HasMemberType, Converter={StaticResource BoolToVisible}}">
                                                                    <TextBlock Text="{Binding MemberTypeName}" FontSize="11" Foreground="#555" />
                                                                </Border>
                                                                <Border Style="{StaticResource Badge}" Background="#FDF0DC"
                                                                        Visibility="{Binding ShowDiscount, Converter={StaticResource BoolToVisible}}">
                                                                    <TextBlock Text="{Binding DiscountText}" FontSize="11" Foreground="#B8860B" />
                                                                </Border>
                                                                <Border Style="{StaticResource Badge}" Background="#EDEFF2"
                                                                        Visibility="{Binding ShowClosed, Converter={StaticResource BoolToVisible}}">
                                                                    <TextBlock Text="已关闭" FontSize="11" Foreground="#999" />
                                                                </Border>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                                <TextBlock Foreground="#888" FontSize="12">
                                                                    <Run Text="余额 ¥" /><Run Text="{Binding Balance, StringFormat='F2', Mode=OneWay}" FontWeight="SemiBold" Foreground="#D9534F" />
                                                                </TextBlock>
                                                                <TextBlock Margin="14,0,0,0" Foreground="#888" FontSize="12">
                                                                    <Run Text="充值 ¥" /><Run Text="{Binding TotalRecharge, StringFormat='F2', Mode=OneWay}" Foreground="#444" />
                                                                </TextBlock>
                                                                <TextBlock Margin="14,0,0,0" Foreground="#888" FontSize="12">
                                                                    <Run Text="消费 ¥" /><Run Text="{Binding TotalConsumed, StringFormat='F2', Mode=OneWay}" Foreground="#444" />
                                                                </TextBlock>
                                                                <TextBlock Margin="14,0,0,0" Foreground="#888" FontSize="12"
                                                                           Visibility="{Binding IsCountBased, Converter={StaticResource BoolToVisible}}">
                                                                    <Run Text="次数 " /><Run Text="{Binding CountText, Mode=OneWay}" Foreground="#444" />
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <TextBlock Foreground="#999" FontSize="11" Margin="0,5,0,0">
                                                                <Run Text="开卡 " /><Run Text="{Binding CardStartText, Mode=OneWay}" />
                                                                <Run Text="    " /><Run Text="{Binding ValidityText, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</UserControl>
