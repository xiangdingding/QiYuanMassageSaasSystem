<UserControl x:Class="MassageSaas.Cs.Views.MembersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBox DockPanel.Dock="Left" Width="240" Height="32" VerticalContentAlignment="Center" Padding="6,0"
                         Text="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="搜索会员" />
                <Button DockPanel.Dock="Left" Margin="6,0" Padding="12,0" Content="查询"
                        Command="{Binding ReloadCommand}" />
                <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Padding="12,0" Background="#2D6A4F" Foreground="White"
                        BorderThickness="0" Content="开卡" Command="{Binding CreateCommand}" />
            </DockPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Rows}" SelectedItem="{Binding Selected, Mode=TwoWay}"
                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#FAFAFA"
                      AutomationProperties.Name="会员列表">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="AutomationProperties.Name">
                            <Setter.Value>
                                <MultiBinding StringFormat="会员 {0}，卡号 {1}，余额 {2:F2} 元，累计消费 {3:F2} 元">
                                    <Binding Path="Name" FallbackValue="未填姓名" />
                                    <Binding Path="CardNo" />
                                    <Binding Path="Balance" />
                                    <Binding Path="TotalConsumed" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="卡号" Binding="{Binding CardNo}" Width="120" />
                    <DataGridTextColumn Header="姓名" Binding="{Binding Name}" Width="100" />
                    <DataGridTextColumn Header="手机号" Binding="{Binding Phone}" Width="120" />
                    <DataGridTextColumn Header="余额" Binding="{Binding Balance, StringFormat='¥{0:F2}'}" Width="100" />
                    <DataGridTextColumn Header="累计充值" Binding="{Binding TotalRecharge, StringFormat='¥{0:F2}'}" Width="100" />
                    <DataGridTextColumn Header="累计消费" Binding="{Binding TotalConsumed, StringFormat='¥{0:F2}'}" Width="100" />
                    <DataGridTextColumn Header="折扣" Binding="{Binding Discount, StringFormat='F2'}" Width="60" />
                    <DataGridTextColumn Header="开卡时间" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="150" />
                    <DataGridTextColumn Header="到期时间" Binding="{Binding CardExpiresAt, Converter={StaticResource CardExpiry}}" Width="150" />
                    <DataGridTextColumn Header="剩余" Binding="{Binding CardDaysRemaining, Converter={StaticResource CardDaysRemaining}}" Width="90" />
                    <DataGridTemplateColumn Header="操作" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Margin="2" Padding="6,2" Content="充值"
                                            Command="{Binding DataContext.RechargeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                    <Button Margin="2" Padding="6,2" Content="编辑"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
