<Window x:Class="MassageSaas.Cs.Views.LeaveFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登记请假"
        Height="600" Width="440"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="员工" Margin="0,0,0,4" Foreground="#666" />
        <ComboBox Grid.Row="1" x:Name="UserBox" Margin="0,0,0,12"
                  AutomationProperties.Name="选择员工"
                  Style="{StaticResource FilterCombo}">
            <ComboBox.ItemTemplate>
                <DataTemplate><TextBlock Text="{Binding Display}" /></DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Grid.Row="2" Text="类型" Margin="0,0,0,4" Foreground="#666" />
        <ComboBox Grid.Row="3" x:Name="TypeBox" Margin="0,0,0,12"
                  AutomationProperties.Name="请假类型" Style="{StaticResource FilterCombo}">
            <ComboBoxItem Content="病假" Tag="Sick" />
            <ComboBoxItem Content="事假" Tag="Personal" IsSelected="True" />
            <ComboBoxItem Content="年假" Tag="Annual" />
        </ComboBox>

        <TextBlock Grid.Row="4" Text="开始" Margin="0,0,0,4" Foreground="#666" />
        <Grid Grid.Row="5" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <DatePicker Grid.Column="0" x:Name="FromBox" Margin="0,0,8,0"
                        AutomationProperties.Name="开始日期"
                        PreviewMouseLeftButtonUp="DatePicker_PreviewMouseUp"
                        SelectedDateChanged="OnInputChanged"
                        SelectedDateFormat="Short"
                        Style="{StaticResource FilterDatePicker}" />
            <ComboBox Grid.Column="1" x:Name="StartHalfBox"
                      AutomationProperties.Name="开始时段"
                      SelectionChanged="OnInputChanged"
                      Style="{StaticResource FilterCombo}">
                <ComboBoxItem Content="上午" Tag="Morning" IsSelected="True" />
                <ComboBoxItem Content="下午" Tag="Afternoon" />
            </ComboBox>
        </Grid>

        <TextBlock Grid.Row="6" Text="结束" Margin="0,0,0,4" Foreground="#666" />
        <Grid Grid.Row="7" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <DatePicker Grid.Column="0" x:Name="ToBox" Margin="0,0,8,0"
                        AutomationProperties.Name="结束日期"
                        PreviewMouseLeftButtonUp="DatePicker_PreviewMouseUp"
                        SelectedDateChanged="OnInputChanged"
                        SelectedDateFormat="Short"
                        Style="{StaticResource FilterDatePicker}" />
            <ComboBox Grid.Column="1" x:Name="EndHalfBox"
                      AutomationProperties.Name="结束时段"
                      SelectionChanged="OnInputChanged"
                      Style="{StaticResource FilterCombo}">
                <ComboBoxItem Content="上午" Tag="Morning" />
                <ComboBoxItem Content="下午" Tag="Afternoon" IsSelected="True" />
            </ComboBox>
        </Grid>

        <Border Grid.Row="8" Margin="0,0,0,12" Padding="10,6" Background="#F0F7F4" CornerRadius="4">
            <TextBlock x:Name="DaysText" Foreground="#2D6A4F" FontWeight="SemiBold"
                       AutomationProperties.Name="请假天数" Text="共 1 天" />
        </Border>

        <TextBlock Grid.Row="9" Text="事由（可空）" Margin="0,0,0,4" Foreground="#666" />
        <TextBox Grid.Row="10" x:Name="ReasonBox" MaxLength="200" VerticalAlignment="Stretch"
                 AutomationProperties.Name="事由" Style="{StaticResource FieldTextMultiline}" />

        <Border Grid.Row="11" Margin="0,12,0,0" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="20,0" Margin="0,0,8,0" AutomationProperties.Name="取消"
                        Click="Cancel_Click" Style="{StaticResource GhostBtn}" />
                <Button Content="提交" Padding="20,0" AutomationProperties.Name="提交"
                        Click="Save_Click" Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
