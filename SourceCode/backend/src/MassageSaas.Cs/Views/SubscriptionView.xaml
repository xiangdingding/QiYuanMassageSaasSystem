<UserControl x:Class="MassageSaas.Cs.Views.SubscriptionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,4,0">

                <!--  订阅与到期信息  -->
                <Border Background="White" CornerRadius="6" Padding="20">
                    <StackPanel>
                        <TextBlock Text="订阅与到期信息" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" />
                        <Grid DataContext="{Binding Status}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="状态：" />
                            <TextBlock Grid.Row="0" Grid.Column="1" FontWeight="SemiBold"
                                       Text="{Binding Status, Converter={StaticResource EnumLabel}, Mode=OneWay}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="当前套餐：" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,8,0,0"
                                       Text="{Binding CurrentPlanName, FallbackValue='—', Mode=OneWay}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="到期时间：" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,8,0,0"
                                       Text="{Binding ExpireAt, StringFormat='yyyy-MM-dd HH:mm:ss', FallbackValue='—', Mode=OneWay}" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="距离到期：" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,8,0,0"
                                       Text="{Binding DaysToExpire, StringFormat='{}{0} 天', FallbackValue='—', Mode=OneWay}" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="租户 ID：" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,8,0,0"
                                       Text="{Binding TenantId, Mode=OneWay}" />
                        </Grid>

                        <Border BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,16,0,0">
                            <StackPanel>
                                <!--  说明 + 客服联系方式：由平台端配置，本端自动获取  -->
                                <TextBlock Foreground="#666" TextWrapping="Wrap"
                                           Text="{Binding NoticeText, Mode=OneWay}" />
                                <TextBlock Foreground="#9A3412" TextWrapping="Wrap" Margin="0,8,0,0"
                                           Text="{Binding ContactText, Mode=OneWay}"
                                           Visibility="{Binding HasContact, Converter={StaticResource BoolToVisible}}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!--  购买 / 续费  -->
                <Border Background="White" CornerRadius="6" Padding="20" Margin="0,16,0,0"
                        Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisible}}">
                    <StackPanel>
                        <TextBlock Text="购买 / 续费" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" />

                        <TextBlock Text="选择套餐" Foreground="#606266" Margin="0,0,0,8" />
                        <ListBox ItemsSource="{Binding Plans}"
                                 SelectedItem="{Binding SelectedPlan, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 AutomationProperties.Name="选择订阅套餐">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="0,0,12,12" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="bd" Width="220" Padding="16"
                                                        Background="White" BorderBrush="#DCDFE6"
                                                        BorderThickness="1.5" CornerRadius="10">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="BorderBrush" Value="#5A8B76" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                                                        <Setter TargetName="bd" Property="Background" Value="#F3FAF6" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel AutomationProperties.Name="{Binding Name}">
                                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" />
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                                            <TextBlock Foreground="#2D6A4F" FontSize="14" VerticalAlignment="Bottom" Text="￥" />
                                            <TextBlock Foreground="#2D6A4F" FontSize="28" FontWeight="Bold"><Run Text="{Binding AnnualPrice, Mode=OneWay, StringFormat={}{0:0}}" /></TextBlock>
                                            <TextBlock Foreground="#909399" FontSize="12" VerticalAlignment="Bottom" Margin="6,0,0,4" Text="/ 年" />
                                        </StackPanel>
                                        <Border BorderBrush="#EBEEF5" BorderThickness="0,1,0,0" Padding="0,8,0,0">
                                            <StackPanel>
                                                <TextBlock FontSize="13" Foreground="#606266"><Run Text="最多 " /><Run Text="{Binding MaxStores, Mode=OneWay}" /><Run Text=" 个门店" /></TextBlock>
                                                <TextBlock FontSize="13" Foreground="#606266" Margin="0,4,0,0"><Run Text="最多 " /><Run Text="{Binding MaxStaff, Mode=OneWay}" /><Run Text=" 名员工" /></TextBlock>
                                                <TextBlock FontSize="13" Foreground="#909399" Margin="0,4,0,0"><Run Text="套餐编码：" /><Run Text="{Binding Code, Mode=OneWay}" /></TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!--  年限 + 渠道  -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="购买年限：" VerticalAlignment="Center" />
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox Width="80"
                                         AutomationProperties.Name="购买年限（1 到 10 年）"
                                         Text="{Binding Years, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Foreground="#909399" Margin="10,0,0,0" VerticalAlignment="Center"><Run Text="到期日将延后 " /><Run Text="{Binding Years, Mode=OneWay}" /><Run Text=" 年" /></TextBlock>
                            </StackPanel>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="支付渠道：" VerticalAlignment="Center" Margin="0,12,0,0" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,12,0,0">
                                <RadioButton Content="微信支付" GroupName="payChannel"
                                             AutomationProperties.Name="微信支付"
                                             IsChecked="{Binding Channel, Converter={StaticResource StringEquals}, ConverterParameter=Wechat}" />
                                <RadioButton Content="支付宝" GroupName="payChannel" Margin="20,0,0,0"
                                             AutomationProperties.Name="支付宝"
                                             IsChecked="{Binding Channel, Converter={StaticResource StringEquals}, ConverterParameter=Alipay}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="应付金额：" VerticalAlignment="Center" Margin="0,12,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="1" FontSize="20" FontWeight="Bold" Foreground="#E6A23C" Margin="0,12,0,0"><Run Text="￥" /><Run Text="{Binding TotalAmount, Mode=OneWay, StringFormat={}{0:0.00}}" /></TextBlock>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button Content="发起续费" Padding="20,8"
                                    AutomationProperties.Name="发起续费"
                                    Command="{Binding CreatePaymentCommand}"
                                    Style="{StaticResource PrimaryBtn}" />
                            <Button Content="刷新" Padding="20,8" Margin="12,0,0,0"
                                    AutomationProperties.Name="刷新"
                                    Command="{Binding ReloadCommand}"
                                    Style="{StaticResource GhostBtn}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!--  支付弹窗（拉起支付后轮询状态）  -->
        <Grid Background="#80000000"
              Visibility="{Binding IsPayDialogOpen, Converter={StaticResource BoolToVisible}}">
            <Border Width="460" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="White" CornerRadius="10" Padding="24"
                    AutomationProperties.Name="支付窗口">
                <StackPanel>
                    <TextBlock Text="完成支付" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" />

                    <!--  创建中  -->
                    <TextBlock Text="正在创建支付单…" Foreground="#909399"
                               Visibility="{Binding PayOrder, Converter={StaticResource InverseNullToCollapsed}}" />

                    <!--  支付单详情  -->
                    <StackPanel Visibility="{Binding PayOrder, Converter={StaticResource NullToCollapsed}}">
                        <TextBlock Margin="0,0,0,6"><Run Text="订单号：" /><Run Text="{Binding PayOrder.OrderNo, Mode=OneWay}" FontWeight="SemiBold" /></TextBlock>
                        <TextBlock Margin="0,0,0,6"><Run Text="金额：" /><Run Text="￥" Foreground="#E6A23C" /><Run Text="{Binding PayOrder.Amount, Mode=OneWay, StringFormat={}{0:0.00}}" Foreground="#E6A23C" FontWeight="SemiBold" /></TextBlock>
                        <TextBlock Margin="0,0,0,6"><Run Text="状态：" /><Run Text="{Binding PayStatusLabel, Mode=OneWay}" FontWeight="SemiBold" /></TextBlock>

                        <StackPanel Visibility="{Binding PayOrder.PayUrl, Converter={StaticResource NullToCollapsed}}">
                            <TextBlock Text="支付链接（复制到微信/支付宝，或用手机扫码）：" Foreground="#909399" FontSize="12" Margin="0,4,0,4" />
                            <TextBox Text="{Binding PayOrder.PayUrl, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                                     AutomationProperties.Name="支付链接" />
                        </StackPanel>

                        <Border Background="#ECF5FF" CornerRadius="4" Padding="10" Margin="0,12,0,0"
                                Visibility="{Binding IsPayPending, Converter={StaticResource BoolToVisible}}">
                            <TextBlock Foreground="#1F5599" TextWrapping="Wrap"
                                       Text="已生成支付单，在第三方完成支付后此处会自动刷新。" />
                        </Border>
                        <Border Background="#F0F9EB" CornerRadius="4" Padding="10" Margin="0,12,0,0"
                                Visibility="{Binding IsPaySucceeded, Converter={StaticResource BoolToVisible}}">
                            <TextBlock Foreground="#2D6A4F" TextWrapping="Wrap" FontWeight="SemiBold"
                                       Text="支付成功，到期时间已延长。" />
                        </Border>
                        <Border Background="#FEF0F0" CornerRadius="4" Padding="10" Margin="0,12,0,0"
                                Visibility="{Binding IsPayFailed, Converter={StaticResource BoolToVisible}}">
                            <TextBlock Foreground="#D9534F" TextWrapping="Wrap"
                                       Text="支付失败，请关闭后重试。" />
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="我已支付，立即查询" Padding="16,6"
                                AutomationProperties.Name="我已支付，立即查询"
                                Command="{Binding CheckOnceCommand}"
                                Style="{StaticResource GhostBtn}"
                                Visibility="{Binding IsPayPending, Converter={StaticResource BoolToVisible}}" />
                        <Button Content="关闭" Padding="20,6" Margin="12,0,0,0"
                                AutomationProperties.Name="关闭支付窗口"
                                Command="{Binding ClosePayDialogCommand}"
                                Style="{StaticResource PrimaryBtn}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
