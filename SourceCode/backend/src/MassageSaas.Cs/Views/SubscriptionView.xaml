<UserControl x:Class="MassageSaas.Cs.Views.SubscriptionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" CornerRadius="4" Padding="20">
        <StackPanel DataContext="{Binding Status}">
            <TextBlock Text="订阅状态" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="状态：" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Status, Converter={StaticResource EnumLabel}}" FontWeight="SemiBold" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="当前套餐：" Margin="0,8,0,0" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentPlanName, FallbackValue='—'}" Margin="0,8,0,0" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="到期时间：" Margin="0,8,0,0" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ExpireAt, StringFormat='yyyy-MM-dd', FallbackValue='—'}" Margin="0,8,0,0" />
                <TextBlock Grid.Row="3" Grid.Column="0" Text="剩余天数：" Margin="0,8,0,0" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DaysToExpire, FallbackValue='—'}" Margin="0,8,0,0" />
                <TextBlock Grid.Row="4" Grid.Column="0" Text="租户 ID：" Margin="0,8,0,0" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding TenantId}" Margin="0,8,0,0" />
            </Grid>

            <Border BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,16,0,0" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="续费请联系平台方或登录平台端在线下单。" Foreground="#666" />
                    <Button Content="刷新" Padding="12,6" Margin="0,12,0,0" HorizontalAlignment="Left"
                            Command="{Binding DataContext.ReloadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
