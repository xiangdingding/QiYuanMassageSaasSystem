<UserControl x:Class="MassageSaas.Cs.Views.PayrollView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TabControl Background="Transparent" BorderThickness="0">
        <!-- 工资单 -->
        <TabItem Header="工资单">
            <Grid Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="3*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="4" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock DockPanel.Dock="Left" Text="月度工资单" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <TextBlock Text="年份" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBox Text="{Binding YearFilter, UpdateSourceTrigger=PropertyChanged}" Width="64" Height="30"
                                         AutomationProperties.Name="工资单年份" />
                                <Button Content="生成工资单" Padding="12,6" Margin="12,0,0,0" Background="#2D6A4F" Foreground="White" BorderThickness="0" Command="{Binding GenerateCommand}" />
                                <Button Content="刷新" Padding="12,6" Margin="8,0,0,0" Command="{Binding ReloadCommand}" />
                            </StackPanel>
                        </DockPanel>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Periods}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#FAFAFA">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="年" Binding="{Binding Year}" Width="70" />
                                <DataGridTextColumn Header="月" Binding="{Binding Month}" Width="50" />
                                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80" />
                                <DataGridTextColumn Header="人数" Binding="{Binding ItemCount}" Width="70" />
                                <DataGridTextColumn Header="工资总额" Binding="{Binding TotalAmount, StringFormat='¥{0:F2}'}" Width="120" />
                                <DataGridTextColumn Header="生成时间" Binding="{Binding GeneratedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="150" />
                                <DataGridTextColumn Header="操作人" Binding="{Binding OperatorName}" Width="100" />
                                <DataGridTemplateColumn Header="操作" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Margin="2" Padding="6,2" Content="查看"
                                                        Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Margin="2" Padding="6,2" Content="封盘"
                                                        Command="{Binding DataContext.LockCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Margin="2" Padding="6,2" Content="已发放" Background="#2D6A4F" Foreground="White" BorderThickness="0"
                                                        Command="{Binding DataContext.MarkPaidCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Margin="2" Padding="6,2" Content="删除" Background="#D9534F" Foreground="White" BorderThickness="0"
                                                        Command="{Binding DataContext.DeleteDraftCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- 选中工资单的明细 -->
                <Border Grid.Row="2" Background="White" CornerRadius="4" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="2*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Margin="0,0,0,8" FontWeight="SemiBold"
                                   Text="{Binding CurrentPeriod.Status, StringFormat='工资单明细（状态：{0}，仅草稿可改）', FallbackValue=工资单明细（点上方查看）}" />

                        <DataGrid Grid.Row="1" ItemsSource="{Binding DetailItems}" SelectedItem="{Binding SelectedItem}"
                                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" AlternatingRowBackground="#FAFAFA">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="工号" Binding="{Binding EmployeeNo}" Width="60" />
                                <DataGridTextColumn Header="员工" Binding="{Binding UserName}" Width="100" />
                                <DataGridTextColumn Header="底薪" Binding="{Binding BaseSalary, StringFormat='¥{0:F0}'}" Width="80" />
                                <DataGridTextColumn Header="提成" Binding="{Binding CommissionTotal, StringFormat='¥{0:F0}'}" Width="80" />
                                <DataGridTextColumn Header="加班" Binding="{Binding OvertimeAmount, StringFormat='¥{0:F0}'}" Width="80" />
                                <DataGridTextColumn Header="满勤" Binding="{Binding AttendanceBonus, StringFormat='¥{0:F0}'}" Width="70" />
                                <DataGridTextColumn Header="奖扣" Binding="{Binding AdjustmentTotal, StringFormat='¥{0:F0}'}" Width="70" />
                                <DataGridTextColumn Header="小费" Binding="{Binding TipsTotal, StringFormat='¥{0:F0}'}" Width="70" />
                                <DataGridTextColumn Header="实发" Binding="{Binding NetTotal, StringFormat='¥{0:F2}'}" Width="100" />
                                <DataGridTextColumn Header="排班/请假" Binding="{Binding ScheduledDays}" Width="80" />
                                <DataGridTemplateColumn Header="操作" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Margin="2" Padding="6,2" Content="改加班/满勤"
                                                        Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Margin="2" Padding="6,2" Content="奖/扣"
                                                        Command="{Binding DataContext.AddAdjustmentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="2" Margin="0,10,0,6" Foreground="#666"
                                   Text="{Binding SelectedItem.UserName, StringFormat='{}{0} 的奖扣明细', FallbackValue=选中员工查看奖扣明细}" />

                        <DataGrid Grid.Row="3" ItemsSource="{Binding SelectedItem.Adjustments}" AutoGenerateColumns="False"
                                  CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal" Background="#F7F9FB">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="类型" Binding="{Binding Kind}" Width="80" />
                                <DataGridTextColumn Header="金额" Binding="{Binding Amount, StringFormat='¥{0:F2}'}" Width="100" />
                                <DataGridTextColumn Header="原因" Binding="{Binding Reason}" Width="240" />
                                <DataGridTextColumn Header="操作人" Binding="{Binding OperatorName}" Width="100" />
                                <DataGridTextColumn Header="时间" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="150" />
                                <DataGridTemplateColumn Header="操作" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Margin="2" Padding="6,2" Content="删除" Background="#D9534F" Foreground="White" BorderThickness="0"
                                                    Command="{Binding DataContext.RemoveAdjustmentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>

        <!-- 薪资配置 -->
        <TabItem Header="薪资配置">
            <Border Background="White" CornerRadius="4" Padding="16" Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="员工薪资档案（底薪 / 加班时薪 / 满勤奖）" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Profiles}" AutoGenerateColumns="False"
                              CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal" AlternatingRowBackground="#FAFAFA">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="员工" Binding="{Binding UserName}" Width="160" />
                            <DataGridTextColumn Header="月底薪" Binding="{Binding BaseMonthly, StringFormat='¥{0:F2}'}" Width="120" />
                            <DataGridTextColumn Header="加班时薪" Binding="{Binding OvertimeHourRate, StringFormat='¥{0:F2}'}" Width="120" />
                            <DataGridTextColumn Header="满勤奖" Binding="{Binding AttendanceBonusAmount, StringFormat='¥{0:F2}'}" Width="110" />
                            <DataGridTextColumn Header="满勤天数" Binding="{Binding RequiredAttendanceDays}" Width="90" />
                            <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="200" />
                            <DataGridTemplateColumn Header="操作" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Margin="2" Padding="6,2" Content="编辑"
                                                Command="{Binding DataContext.EditProfileCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>
    </TabControl>
</UserControl>
