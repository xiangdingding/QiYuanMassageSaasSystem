<UserControl x:Class="MassageSaas.Cs.Views.PayrollView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <TabControl Background="Transparent" BorderThickness="0">
        <!--  工资单  -->
        <TabItem Header="工资单">
            <Grid Margin="0,8,0,0">
                <Border Padding="16"
                        Background="White"
                        CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Margin="0,0,20,0"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Left"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{Binding PeriodsTitle}" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <TextBlock Margin="0,0,6,0"
                                           VerticalAlignment="Center"
                                           Text="年份" />
                                <ComboBox Width="90"
                                          AutomationProperties.Name="工资单年份"
                                          ItemsSource="{Binding YearOptions}"
                                          SelectedItem="{Binding YearFilter, Mode=TwoWay}"
                                          Style="{StaticResource FilterCombo}" />
                                <TextBlock Margin="30,0,6,0"
                                           VerticalAlignment="Center"
                                           Text="月份" />
                                <ComboBox Width="90"
                                          AutomationProperties.Name="生成工资单的月份"
                                          ItemsSource="{Binding MonthOptions}"
                                          SelectedItem="{Binding GenMonthNumber, Mode=TwoWay}"
                                          Style="{StaticResource FilterCombo}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StringFormat='{}{0}月'}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Margin="12,0,0,0"
                                        Padding="16,0"
                                        Command="{Binding GenerateCommand}"
                                        Content="生成工资单"
                                        Style="{StaticResource PrimaryBtn}" />
                                <Button Margin="8,0,0,0"
                                        Padding="16,0"
                                        Command="{Binding ReloadCommand}"
                                        Content="刷新"
                                        Style="{StaticResource GhostBtn}" />
                            </StackPanel>
                        </DockPanel>
                        <DataGrid Grid.Row="1"
                                  AlternatingRowBackground="#FAFAFA"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="All"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding Periods}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="100" Header="月份">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center">
                                                <Run Text="{Binding Year, Mode=OneWay}" /><Run Text="-" /><Run Text="{Binding Month, StringFormat='{}{0:D2}', Mode=OneWay}" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="80"
                                                    Binding="{Binding Status, Converter={StaticResource EnumLabel}}"
                                                    Header="状态" />
                                <DataGridTextColumn Width="70"
                                                    Binding="{Binding ItemCount}"
                                                    Header="人数" />
                                <DataGridTextColumn Width="120"
                                                    Binding="{Binding TotalAmount, StringFormat='¥{0:F2}'}"
                                                    Header="工资总额" />
                                <DataGridTextColumn Width="160"
                                                    Binding="{Binding GeneratedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                    Header="生成时间" />
                                <DataGridTextColumn Width="100"
                                                    Binding="{Binding OperatorName}"
                                                    Header="操作人" />
                                <DataGridTextColumn Width="*"
                                                    MinWidth="130"
                                                    Binding="{Binding Remark}"
                                                    Header="备注" />
                                <DataGridTemplateColumn Width="Auto"
                                                        MinWidth="300"
                                                        Header="操作">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button AutomationProperties.Name="查看工资单明细"
                                                        Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Content="查看"
                                                        Style="{StaticResource RowGhost}" />
                                                <Button AutomationProperties.Name="封盘工资单"
                                                        Command="{Binding DataContext.LockCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Content="封盘"
                                                        IsEnabled="{Binding Status, Converter={StaticResource StringEquals}, ConverterParameter=Draft}"
                                                        Style="{StaticResource RowGhost}" />
                                                <Button AutomationProperties.Name="标记已发放"
                                                        Command="{Binding DataContext.MarkPaidCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Content="已发放"
                                                        IsEnabled="{Binding Status, Converter={StaticResource StringEquals}, ConverterParameter=Locked}"
                                                        Style="{StaticResource RowPrimary}" />
                                                <Button AutomationProperties.Name="删除工资单草稿"
                                                        Command="{Binding DataContext.DeleteDraftCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Content="删除"
                                                        IsEnabled="{Binding Status, Converter={StaticResource StringEquals}, ConverterParameter=Draft}"
                                                        Style="{StaticResource RowDanger}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>

        <!--  薪资配置  -->
        <TabItem Header="薪资配置">
            <Border Margin="0,8,0,0"
                    Padding="16"
                    Background="White"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Margin="0,0,0,12"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding ProfilesTitle}" />
                    <DataGrid Grid.Row="1"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              GridLinesVisibility="All"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Profiles}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="160"
                                                Binding="{Binding UserName}"
                                                Header="员工" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding BaseMonthly, StringFormat='¥{0:F2}'}"
                                                Header="月底薪" />
                            <DataGridTextColumn Width="120"
                                                Binding="{Binding OvertimeHourRate, StringFormat='¥{0:F2}'}"
                                                Header="加班时薪" />
                            <DataGridTemplateColumn Width="160" Header="满勤奖">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="{Binding AttendanceBonusAmount, StringFormat='¥{0:F2}', Mode=OneWay}" /><Run Text=" / " /><Run Text="{Binding RequiredAttendanceDays, Mode=OneWay}" /><Run Text=" 天" />
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Width="*"
                                                MinWidth="120"
                                                Binding="{Binding Remark}"
                                                Header="备注" />
                            <DataGridTemplateColumn Width="Auto"
                                                    MinWidth="80"
                                                    Header="操作">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button HorizontalAlignment="Left"
                                                AutomationProperties.Name="编辑薪资档案"
                                                Command="{Binding DataContext.EditProfileCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Content="编辑"
                                                Style="{StaticResource RowGhost}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </TabItem>
    </TabControl>
</UserControl>
