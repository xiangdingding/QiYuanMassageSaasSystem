<Window x:Class="MassageSaas.Cs.Views.CommissionFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="提成规则"
        Height="500" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="服务项目 ID（留空 = 全部）" Margin="0,0,0,4" />
        <TextBox Grid.Row="1" x:Name="ServiceIdBox" Padding="6" Margin="0,0,0,12" />

        <TextBlock Grid.Row="2" Text="技师 ID（留空 = 全部）" Margin="0,0,0,4" />
        <TextBox Grid.Row="3" x:Name="TechIdBox" Padding="6" Margin="0,0,0,12" />

        <TextBlock Grid.Row="4" Text="规则类型" Margin="0,0,0,4" />
        <ComboBox Grid.Row="5" x:Name="RuleTypeBox" Padding="6" Margin="0,0,0,12" SelectedIndex="0">
            <ComboBoxItem Content="FixedAmount" />
            <ComboBoxItem Content="Percentage" />
            <ComboBoxItem Content="Tiered" />
            <ComboBoxItem Content="Timed" />
        </ComboBox>

        <TextBlock Grid.Row="6" Text="金额 / 比例（如 0.2 表示 20%）" Margin="0,0,0,4" />
        <TextBox Grid.Row="7" x:Name="AmountBox" Padding="6" Margin="0,0,0,12" Text="0" />

        <TextBlock Grid.Row="8" Text="阶梯规则 JSON（仅 Tiered 用）" Margin="0,0,0,4" />
        <TextBox Grid.Row="9" x:Name="TieredBox" Padding="6" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12" />

        <TextBlock Grid.Row="10" Text="优先级（数字大优先）" Margin="0,0,0,4" />
        <TextBox Grid.Row="11" x:Name="PriorityBox" Padding="6" Margin="0,0,0,12" Text="0" />

        <CheckBox x:Name="ActiveBox" Grid.Row="12" Content="启用" IsChecked="True" />

        <Border Grid.Row="13" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="保存" Padding="16,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
