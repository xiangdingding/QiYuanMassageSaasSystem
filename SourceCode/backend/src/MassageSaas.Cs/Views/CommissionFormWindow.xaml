<Window x:Class="MassageSaas.Cs.Views.CommissionFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="提成规则"
        Height="720" Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="服务项目 ID（留空 = 全部）" Margin="0,0,0,4" />
        <TextBox Grid.Row="1" x:Name="ServiceIdBox" Padding="6" Margin="0,0,0,12" />

        <TextBlock Grid.Row="2" Text="技师 ID（留空 = 全部）" Margin="0,0,0,4" />
        <TextBox Grid.Row="3" x:Name="TechIdBox" Padding="6" Margin="0,0,0,12" />

        <TextBlock Grid.Row="4" Text="规则类型" Margin="0,0,0,4" />
        <ComboBox Grid.Row="5" x:Name="RuleTypeBox" Padding="6" Margin="0,0,0,12" SelectedIndex="0">
            <ComboBoxItem Content="FixedAmount" />
            <ComboBoxItem Content="Percentage" />
            <ComboBoxItem Content="Tiered" />
            <ComboBoxItem Content="Timed" />
        </ComboBox>

        <Border Grid.Row="6" Background="#F8FAFC" Padding="10" CornerRadius="4" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="按上钟方式（FixedAmount / Percentage 类型必填）" Foreground="#666" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" /><ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="轮钟金额" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" x:Name="RotationAmountBox" Padding="6" Margin="0,0,8,0" />
                    <TextBlock Grid.Column="2" Text="点钟金额" VerticalAlignment="Center" />
                    <TextBox Grid.Column="3" x:Name="DesignationAmountBox" Padding="6" />
                </Grid>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="7" Text="金额 / 比例（Tiered 默认值、Timed 元/小时使用此项）" Margin="0,0,0,4" />
        <TextBox Grid.Row="8" x:Name="AmountBox" Padding="6" Margin="0,0,0,12" Text="0" />

        <TextBlock Grid.Row="9" Text="阶梯档位（仅 Tiered 用）" Margin="0,0,0,4" />
        <Border Grid.Row="10" Background="#F8FAFC" Padding="8" CornerRadius="4" Margin="0,0,0,12">
            <StackPanel>
                <DataGrid x:Name="TiersGrid" Height="140" AutoGenerateColumns="False" RowHeight="34"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="All"
                          AlternatingRowBackground="#FAFAFA">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="从第几单起" Binding="{Binding FromQty}" Width="140" />
                        <DataGridTextColumn Header="提成金额（元）" Binding="{Binding Amount, StringFormat='F2'}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="+ 添加档位" Padding="8,3" Click="AddTier_Click" />
                    <Button Content="删除选中" Padding="8,3" Margin="6,0,0,0" Click="RemoveTier_Click" />
                </StackPanel>
                <TextBlock Foreground="#666" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"
                           Text="按本月已完成单数匹配最后一档。例：0 单起 ¥20、31 单起 ¥30，表示 1-30 单每单 ¥20，第 31 单起每单 ¥30。" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="11" Text="优先级（数字大优先）" Margin="0,0,0,4" />
        <TextBox Grid.Row="12" x:Name="PriorityBox" Padding="6" Margin="0,0,0,12" Text="0" />

        <CheckBox x:Name="ActiveBox" Grid.Row="13" Content="启用" IsChecked="True" />

        <Border Grid.Row="14" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="保存" Padding="16,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
