<Window x:Class="MassageSaas.Cs.Views.CommissionFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls"
        Title="提成规则"
        Height="720" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="20">
        <!-- 底部操作条 -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Margin="0,0,8,0"
                        Padding="20,0"
                        AutomationProperties.Name="取消"
                        Click="Cancel_Click"
                        Content="取消"
                        Style="{StaticResource GhostBtn}" />
                <Button Padding="20,0"
                        AutomationProperties.Name="保存"
                        Click="Save_Click"
                        Content="保存"
                        Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 适用服务 -->
                <TextBlock Text="适用服务" Margin="0,0,0,4" Foreground="#606266" />
                <ComboBox x:Name="ServiceBox" Margin="0,0,0,12" Style="{StaticResource FilterCombo}"
                          SelectedValuePath="Id" AutomationProperties.Name="适用服务，留空为全部服务">
                    <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- 适用技师 -->
                <TextBlock Text="适用技师" Margin="0,0,0,4" Foreground="#606266" />
                <ComboBox x:Name="TechBox" Margin="0,0,0,12" Style="{StaticResource FilterCombo}"
                          SelectedValuePath="Id" AutomationProperties.Name="适用技师，留空为全部技师">
                    <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- 规则类型 -->
                <TextBlock Text="规则类型" Margin="0,0,0,4" Foreground="#606266" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <RadioButton x:Name="RbFixed" GroupName="RuleType" Content="固定金额"
                                 BorderThickness="1,1,1,1" Tag="4,0,0,4" IsChecked="True"
                                 Style="{StaticResource SegRadio}" Checked="RuleType_Checked"
                                 AutomationProperties.Name="规则类型固定金额" />
                    <RadioButton x:Name="RbPercent" GroupName="RuleType" Content="百分比"
                                 Tag="0" Style="{StaticResource SegRadio}" Checked="RuleType_Checked"
                                 AutomationProperties.Name="规则类型百分比" />
                    <RadioButton x:Name="RbTiered" GroupName="RuleType" Content="阶梯"
                                 Tag="0" Style="{StaticResource SegRadio}" Checked="RuleType_Checked"
                                 AutomationProperties.Name="规则类型阶梯" />
                    <RadioButton x:Name="RbTimed" GroupName="RuleType" Content="按时计费"
                                 Tag="0,4,4,0" Style="{StaticResource SegRadio}" Checked="RuleType_Checked"
                                 AutomationProperties.Name="规则类型按时计费" />
                </StackPanel>

                <!-- 固定金额：按上钟方式（轮钟/点钟，单位元） -->
                <Border x:Name="FixedPanel" Background="#F8FAFC" Padding="12" CornerRadius="4" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="按上钟方式" Foreground="#909399" FontSize="12" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="轮钟金额" VerticalAlignment="Center" Foreground="#606266" />
                            <ctrl:NumericUpDown Grid.Column="1" x:Name="RotationFixedBox" Width="200"
                                                Decimals="2" Minimum="0" Maximum="100000" Step="5"
                                                AutomationProperties.Name="轮钟金额" />
                            <TextBlock Grid.Column="2" Text="元" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#909399" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="点钟金额" VerticalAlignment="Center" Foreground="#606266" />
                            <ctrl:NumericUpDown Grid.Column="1" x:Name="DesignationFixedBox" Width="200"
                                                Decimals="2" Minimum="0" Maximum="100000" Step="5"
                                                AutomationProperties.Name="点钟金额" />
                            <TextBlock Grid.Column="2" Text="元" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#909399" />
                        </Grid>
                        <TextBlock Text="轮钟项按轮钟金额计提，点钟项按点钟金额计提。" Foreground="#909399" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- 百分比：按上钟方式（轮钟/点钟，单位%） -->
                <Border x:Name="PercentPanel" Background="#F8FAFC" Padding="12" CornerRadius="4" Margin="0,0,0,12" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="按上钟方式" Foreground="#909399" FontSize="12" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="轮钟比例" VerticalAlignment="Center" Foreground="#606266" />
                            <ctrl:NumericUpDown Grid.Column="1" x:Name="RotationPercentBox" Width="200"
                                                Decimals="2" Minimum="0" Maximum="100" Step="1"
                                                AutomationProperties.Name="轮钟比例" />
                            <TextBlock Grid.Column="2" Text="%" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#909399" />
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="72" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="点钟比例" VerticalAlignment="Center" Foreground="#606266" />
                            <ctrl:NumericUpDown Grid.Column="1" x:Name="DesignationPercentBox" Width="200"
                                                Decimals="2" Minimum="0" Maximum="100" Step="1"
                                                AutomationProperties.Name="点钟比例" />
                            <TextBlock Grid.Column="2" Text="%" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#909399" />
                        </Grid>
                        <TextBlock Text="按订单项金额的百分比计提。" Foreground="#909399" FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- 单值：Timed（元/小时）/ Tiered（默认数值） -->
                <StackPanel x:Name="SinglePanel" Margin="0,0,0,12" Visibility="Collapsed">
                    <TextBlock x:Name="SingleLabel" Text="元/小时" Margin="0,0,0,4" Foreground="#606266" />
                    <StackPanel Orientation="Horizontal">
                        <ctrl:NumericUpDown x:Name="AmountBox" Width="200"
                                            Decimals="2" Minimum="0" Maximum="100000" Step="5"
                                            AutomationProperties.Name="金额或比例" />
                        <TextBlock x:Name="SingleHint" Margin="8,0,0,0" VerticalAlignment="Center"
                                   Foreground="#909399" FontSize="12" Text="按服务时长比例计算" />
                    </StackPanel>
                </StackPanel>

                <!-- 阶梯档位：Tiered -->
                <StackPanel x:Name="TierPanel" Margin="0,0,0,12" Visibility="Collapsed">
                    <TextBlock Text="阶梯配置" Margin="0,0,0,4" Foreground="#606266" />
                    <Border Background="#F8FAFC" Padding="8" CornerRadius="4">
                        <StackPanel>
                            <DataGrid x:Name="TiersGrid" Height="150" AutoGenerateColumns="False" RowHeight="34"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      HeadersVisibility="Column" GridLinesVisibility="All"
                                      AlternatingRowBackground="#FAFAFA" AutomationProperties.Name="阶梯档位">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="从第几单起" Binding="{Binding FromQty}" Width="*" />
                                    <DataGridTextColumn Header="提成金额（元）" Binding="{Binding Amount, StringFormat='F2'}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="+ 添加档位" Padding="8,3" Click="AddTier_Click" />
                                <Button Content="删除选中" Padding="8,3" Margin="6,0,0,0" Click="RemoveTier_Click" />
                            </StackPanel>
                            <TextBlock Foreground="#909399" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"
                                       Text="按“本月已完成单数”匹配最后一档。例：第 1 档“0 单起 ¥20”、第 2 档“31 单起 ¥30”，代表 1~30 单每单提 ¥20，第 31 单起每单提 ¥30。" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 优先级 -->
                <TextBlock Text="优先级" Margin="0,0,0,4" Foreground="#606266" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <ctrl:NumericUpDown x:Name="PriorityBox" Width="200"
                                        Decimals="0" Minimum="0" Maximum="100" Step="1"
                                        AutomationProperties.Name="优先级" />
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Foreground="#909399" FontSize="12"
                               Text="同维度下数值大的优先" />
                </StackPanel>

                <!-- 启用（开关，对齐 BS el-switch） -->
                <ToggleButton x:Name="ActiveBox" Content="启用" IsChecked="True"
                              Style="{StaticResource SwitchToggle}" AutomationProperties.Name="启用" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
