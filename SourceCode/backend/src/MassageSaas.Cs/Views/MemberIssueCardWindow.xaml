<Window x:Class="MassageSaas.Cs.Views.MemberIssueCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="办卡"
        Height="480" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <DockPanel Margin="20">
        <Border DockPanel.Dock="Bottom" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button x:Name="ConfirmButton" Content="确认办卡" Padding="16,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Click="Confirm_Click" />
            </StackPanel>
        </Border>

        <StackPanel>
            <TextBlock x:Name="HeaderText" FontWeight="Bold" FontSize="15" Margin="0,0,0,12" />

            <TextBlock Text="选择会员类型" Margin="0,0,0,4" Foreground="#666" />
            <ComboBox x:Name="TypeBox" AutomationProperties.Name="会员类型" Height="34" Margin="0,0,0,8" VerticalContentAlignment="Center"
                      SelectionChanged="Type_Changed">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Border x:Name="RulesBox" Background="#EEF4FB" CornerRadius="3" Padding="10,8" Margin="0,0,0,10" Visibility="Collapsed">
                <TextBlock x:Name="RulesText" FontSize="12" Foreground="#3A6A99" TextWrapping="Wrap" />
            </Border>

            <!-- 充值卡 -->
            <StackPanel x:Name="StoredPanel" Visibility="Collapsed">
                <TextBlock Text="充值金额" Margin="0,0,0,4" Foreground="#666" />
                <TextBox x:Name="AmountBox" AutomationProperties.Name="充值金额" Height="34" Padding="8,0" Margin="0,0,0,10" Text="0" VerticalContentAlignment="Center" />
            </StackPanel>

            <!-- 计次卡 -->
            <StackPanel x:Name="CountPanel" Visibility="Collapsed">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="购买次数" Margin="0,0,0,4" Foreground="#666" />
                        <TextBox x:Name="CountBox" AutomationProperties.Name="购买次数" Height="34" Padding="8,0" Text="1" VerticalContentAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="实收金额（现金价）" Margin="0,0,0,4" Foreground="#666" />
                        <TextBox x:Name="PaidBox" AutomationProperties.Name="实收金额" Height="34" Padding="8,0" Text="0" VerticalContentAlignment="Center" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <TextBlock Text="支付方式" Margin="0,0,0,4" Foreground="#666" />
            <WrapPanel x:Name="PayPanel" Margin="0,0,0,10">
                <RadioButton Content="微信" Tag="Wechat" GroupName="Pay" IsChecked="True" Margin="0,0,12,0" />
                <RadioButton Content="支付宝" Tag="Alipay" GroupName="Pay" Margin="0,0,12,0" />
                <RadioButton Content="银行卡" Tag="BankCard" GroupName="Pay" Margin="0,0,12,0" />
                <RadioButton Content="现金" Tag="Cash" GroupName="Pay" Margin="0,0,12,0" />
                <RadioButton Content="其它" Tag="Other" GroupName="Pay" />
            </WrapPanel>

            <TextBlock Text="备注" Margin="0,0,0,4" Foreground="#666" />
            <TextBox x:Name="RemarkBox" AutomationProperties.Name="备注" Height="44" Padding="6" AcceptsReturn="True" TextWrapping="Wrap" MaxLength="200" />
        </StackPanel>
    </DockPanel>
</Window>
