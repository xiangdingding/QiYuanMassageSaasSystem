<Window x:Class="MassageSaas.Cs.Views.ComplaintCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登记投诉"
        Width="780"
        Height="800"
        MinHeight="640"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="20">
        <Border Margin="0,12,0,0"
                Padding="0,12,0,0"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                DockPanel.Dock="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Margin="0,0,8,0"
                        Padding="20,0"
                        AutomationProperties.Name="取消"
                        Click="Cancel_Click"
                        Content="取消"
                        Style="{StaticResource GhostBtn}" />
                <Button x:Name="SubmitButton"
                        Padding="20,0"
                        AutomationProperties.Name="登记投诉"
                        Click="Submit_Click"
                        Content="登记投诉"
                        Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </Border>

        <!--  服务项列表占弹性空间，标签/描述始终固定可见  -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,10" Orientation="Horizontal">
                <ToggleButton x:Name="AnonymousBox"
                              VerticalAlignment="Center"
                              AutomationProperties.Name="不指定项目"
                              Checked="Anonymous_Changed"
                              Content="不指定项目"
                              Style="{StaticResource SwitchToggle}"
                              Unchecked="Anonymous_Changed" />
                <TextBlock Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#999"
                           Text="打开后无需选具体订单项，仅记录文字内容（处理时只能道歉/补偿或不予处理）" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="#666"
                           Text="被投诉技师" />
                <ComboBox x:Name="TechBox"
                          Grid.Column="1"
                          Height="32"
                          VerticalContentAlignment="Center"
                          AutomationProperties.Name="被投诉技师"
                          SelectionChanged="Tech_Changed">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding RealName, TargetNullValue='', Mode=OneWay}" />
                                <Run Text="（工号 " /><Run Text="{Binding EmployeeNo, FallbackValue='—', Mode=OneWay}" /><Run Text="）" />
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <DatePicker x:Name="DateBox"
                            Grid.Column="2"
                            Width="150"
                            Margin="8,0,0,0"
                            AutomationProperties.Name="日期" />
                <Button x:Name="LookupButton"
                        Grid.Column="3"
                        Margin="8,0,0,0"
                        Padding="16,0"
                        AutomationProperties.Name="查询订单"
                        Click="Lookup_Click"
                        Content="查询订单"
                        Style="{StaticResource PrimaryBtn}" />
            </Grid>

            <Grid x:Name="ItemsPanel" Grid.Row="2" Margin="0,0,0,4" MinHeight="150">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Margin="0,0,0,4"
                           Foreground="#666"
                           Text="选择被投诉的服务项目" />
                <TextBlock x:Name="ItemsHint"
                           Grid.Row="1"
                           Margin="0,0,0,6"
                           FontSize="12"
                           Foreground="#999"
                           Text="请先选择技师与日期，再点“查询订单”。" />
                <DataGrid x:Name="ItemsGrid"
                          Grid.Row="2"
                          MinHeight="140"
                          AlternatingRowBackground="#FAFAFA"
                          AutoGenerateColumns="False"
                          AutomationProperties.Name="已完成服务项目"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="160"
                                            Binding="{Binding OrderNo}"
                                            Header="订单号" />
                        <DataGridTextColumn Width="*"
                                            Binding="{Binding ServiceName}"
                                            Header="服务" />
                        <DataGridTextColumn Width="150"
                                            Binding="{Binding CompletedAt, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                            Header="完成时间" />
                        <DataGridTextColumn Width="110"
                                            Binding="{Binding MemberDisplay}"
                                            Header="会员" />
                        <DataGridTextColumn Width="90"
                                            Binding="{Binding Amount, StringFormat='¥{0:F2}'}"
                                            Header="金额" />
                        <DataGridTextColumn Width="80"
                                            Binding="{Binding StatusLabel}"
                                            Header="状态" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <TextBlock Grid.Row="3"
                       Margin="0,10,0,6"
                       Foreground="#666"
                       Text="常用标签" />
            <ItemsControl x:Name="TagOptionsControl" Grid.Row="4">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ToggleButton AutomationProperties.Name="{Binding Label}"
                                      Content="{Binding Label}"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Style="{StaticResource TagToggle}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Grid.Row="5"
                       Margin="0,6,0,4"
                       Foreground="#666"
                       Text="其他标签（可手动填写，逗号分隔）" />
            <TextBox x:Name="TagsBox"
                     Grid.Row="6"
                     Margin="0,0,0,10"
                     AutomationProperties.Name="其他标签"
                     MaxLength="200"
                     Style="{StaticResource FieldText}" />

            <TextBlock Grid.Row="7"
                       Margin="0,0,0,4"
                       Foreground="#666"
                       Text="描述（客户原话 / 补充）" />
            <TextBox x:Name="CommentBox"
                     Grid.Row="8"
                     Height="64"
                     AutomationProperties.Name="描述"
                     MaxLength="500"
                     Style="{StaticResource FieldTextMultiline}" />
        </Grid>
    </DockPanel>
</Window>
