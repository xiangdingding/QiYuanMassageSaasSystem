<Window x:Class="MassageSaas.Cs.Views.ComplaintCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登记投诉"
        Height="640" Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="20">
        <Border DockPanel.Dock="Bottom" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button x:Name="SubmitButton" Content="登记投诉" Padding="16,6" Background="#2D6A4F" Foreground="White"
                        BorderThickness="0" Click="Submit_Click" />
            </StackPanel>
        </Border>

        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <CheckBox x:Name="AnonymousBox" Content="不指定项目" VerticalAlignment="Center" Checked="Anonymous_Changed" Unchecked="Anonymous_Changed" />
                <TextBlock Text="打开后无需选具体订单项，仅记录文字内容（处理时只能道歉/补偿或不予处理）"
                           Foreground="#999" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="被投诉技师" VerticalAlignment="Center" Foreground="#666" Margin="0,0,8,0" />
                <ComboBox Grid.Column="1" x:Name="TechBox" AutomationProperties.Name="被投诉技师" Height="32" VerticalContentAlignment="Center"
                          SelectionChanged="Tech_Changed">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding RealName, TargetNullValue='', Mode=OneWay}" />
                                <Run Text="（工号 " /><Run Text="{Binding EmployeeNo, FallbackValue='—', Mode=OneWay}" /><Run Text="）" />
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <DatePicker Grid.Column="2" x:Name="DateBox" AutomationProperties.Name="日期" Width="150" Margin="8,0,0,0" />
                <Button Grid.Column="3" x:Name="LookupButton" Content="查询订单" Padding="12,0" Height="32" Margin="8,0,0,0" Click="Lookup_Click" />
            </Grid>

            <StackPanel x:Name="ItemsPanel">
                <TextBlock Text="选择被投诉的服务项目" Foreground="#666" Margin="0,0,0,4" />
                <TextBlock x:Name="ItemsHint" Text="请先选择技师与日期，再点“查询订单”。" Foreground="#999" FontSize="12" Margin="0,0,0,6" />
                <DataGrid x:Name="ItemsGrid" Height="220" AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" SelectionMode="Single" HeadersVisibility="Column"
                          AlternatingRowBackground="#FAFAFA" AutomationProperties.Name="已完成服务项目">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="订单号" Binding="{Binding OrderNo}" Width="160" />
                        <DataGridTextColumn Header="服务" Binding="{Binding ServiceName}" Width="*" />
                        <DataGridTextColumn Header="完成时间" Binding="{Binding CompletedAt, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="150" />
                        <DataGridTextColumn Header="会员" Binding="{Binding MemberDisplay}" Width="110" />
                        <DataGridTextColumn Header="金额" Binding="{Binding Amount, StringFormat='¥{0:F2}'}" Width="90" />
                        <DataGridTextColumn Header="状态" Binding="{Binding StatusLabel}" Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <TextBlock Text="标签（逗号分隔，如：态度差,力度不合适）" Foreground="#666" Margin="0,10,0,4" />
            <TextBox x:Name="TagsBox" AutomationProperties.Name="标签" Height="32" Padding="6,0" Margin="0,0,0,10" VerticalContentAlignment="Center" MaxLength="200" />

            <TextBlock Text="描述（客户原话 / 补充）" Foreground="#666" Margin="0,0,0,4" />
            <TextBox x:Name="CommentBox" AutomationProperties.Name="描述" Height="64" Padding="6" AcceptsReturn="True" TextWrapping="Wrap" MaxLength="500" />
        </StackPanel>
    </DockPanel>
</Window>
