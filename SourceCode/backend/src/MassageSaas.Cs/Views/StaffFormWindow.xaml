<Window x:Class="MassageSaas.Cs.Views.StaffFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="员工资料"
        Height="540" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="登录用户名" Margin="0,0,0,4" />
        <TextBox Grid.Row="1" x:Name="UsernameBox" Padding="6" Margin="0,0,0,12" />

        <TextBlock Grid.Row="2" Text="姓名" Margin="0,0,0,4" />
        <TextBox Grid.Row="3" x:Name="RealNameBox" Padding="6" Margin="0,0,0,12" />

        <TextBlock Grid.Row="4" Text="手机号" Margin="0,0,0,4" />
        <TextBox Grid.Row="5" x:Name="PhoneBox" Padding="6" Margin="0,0,0,12" />

        <Grid Grid.Row="6" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="角色" Margin="0,0,0,4" />
                <ComboBox x:Name="RoleBox" Padding="6" SelectedIndex="3">
                    <ComboBoxItem Content="ShopOwner" />
                    <ComboBoxItem Content="StoreManager" />
                    <ComboBoxItem Content="Cashier" />
                    <ComboBoxItem Content="Technician" />
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="工号" Margin="0,0,0,4" />
                <TextBox x:Name="EmployeeNoBox" Padding="6" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="7" Text="初始密码（仅新建）" Margin="0,0,0,4" />
        <PasswordBox Grid.Row="8" x:Name="PasswordBox" Padding="6" Margin="0,0,0,12" />

        <CheckBox Grid.Row="9" x:Name="BlindBox" Content="盲人技师" Margin="0,0,0,8" />
        <CheckBox Grid.Row="10" x:Name="ActiveBox" Content="启用" IsChecked="True" Margin="0,0,0,8" />

        <Border Grid.Row="14" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
                <Button Content="保存" Padding="16,6" Background="#2D6A4F" Foreground="White" BorderThickness="0" Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
