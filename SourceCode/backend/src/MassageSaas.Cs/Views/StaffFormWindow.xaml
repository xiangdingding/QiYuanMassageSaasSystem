<Window x:Class="MassageSaas.Cs.Views.StaffFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:MassageSaas.Cs.Controls"
        Title="员工资料"
        Height="760" Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#606266" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <!--  专长标签芯片（对齐 BS el-check-tag）：未选浅灰、选中绿底白字  -->
        <Style x:Key="ChipToggle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Foreground" Value="#606266" />
            <Setter Property="Background" Value="#F0F2F5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="14,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E6F0EB" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2D6A4F" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <DockPanel Margin="20">
        <!--  底部操作条  -->
        <Border DockPanel.Dock="Bottom" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Padding="20,0" Margin="0,0,8,0" AutomationProperties.Name="取消" Click="Cancel_Click" Style="{StaticResource GhostBtn}" />
                <Button Content="保存" Padding="20,0" AutomationProperties.Name="保存" Click="Save_Click" Style="{StaticResource PrimaryBtn}" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="0,0,4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  工号 | 手机号  -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                    <TextBlock Text="工号" Style="{StaticResource FieldLabel}" />
                    <ctrl:NumericUpDown x:Name="EmployeeNoBox" Decimals="0" Minimum="0" Maximum="1000000" Step="1" AutomationProperties.Name="工号" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,12">
                    <TextBlock Text="手机号（用作登录账号）" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="PhoneBox" Style="{StaticResource FieldText}" Tag="11 位手机号" AutomationProperties.Name="手机号" />
                </StackPanel>

                <!--  初始密码（仅新建） | 姓名  -->
                <StackPanel x:Name="PasswordCell" Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                    <TextBlock Text="初始密码（至少 6 位）" Style="{StaticResource FieldLabel}" />
                    <PasswordBox x:Name="PasswordBox" Style="{StaticResource FieldPassword}" AutomationProperties.Name="初始密码" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,12">
                    <TextBlock Text="姓名" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="RealNameBox" Style="{StaticResource FieldText}" AutomationProperties.Name="姓名" />
                </StackPanel>

                <!--  身份证号 | 出生日期  -->
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,12">
                    <TextBlock Text="身份证号（18 位）" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="IdCardBox" MaxLength="18" Style="{StaticResource FieldText}" TextChanged="IdCard_TextChanged" AutomationProperties.Name="身份证号" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,12">
                    <TextBlock Text="出生日期" Style="{StaticResource FieldLabel}" />
                    <DatePicker x:Name="BirthDatePicker" SelectedDateFormat="Short" Style="{StaticResource FilterDatePicker}" AutomationProperties.Name="出生日期" />
                </StackPanel>

                <!--  紧急联系人 | 联系人电话  -->
                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,12">
                    <TextBlock Text="紧急联系人" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="EmergencyNameBox" Style="{StaticResource FieldText}" AutomationProperties.Name="紧急联系人" />
                </StackPanel>
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,12">
                    <TextBlock Text="联系人电话" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="EmergencyPhoneBox" Style="{StaticResource FieldText}" AutomationProperties.Name="联系人电话" />
                </StackPanel>

                <!--  入职日期 | 离职日期  -->
                <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,8,12">
                    <TextBlock Text="入职日期" Style="{StaticResource FieldLabel}" />
                    <DatePicker x:Name="HireDatePicker" SelectedDateFormat="Short" Style="{StaticResource FilterDatePicker}" AutomationProperties.Name="入职日期" />
                </StackPanel>
                <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,0,0,12">
                    <TextBlock Text="离职日期（在职留空）" Style="{StaticResource FieldLabel}" />
                    <DatePicker x:Name="TerminationDatePicker" SelectedDateFormat="Short" Style="{StaticResource FilterDatePicker}" AutomationProperties.Name="离职日期" />
                </StackPanel>

                <!--  角色 | 所属门店  -->
                <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,8,12">
                    <TextBlock Text="角色" Style="{StaticResource FieldLabel}" />
                    <ComboBox x:Name="RoleBox" Style="{StaticResource FilterCombo}" SelectedValuePath="Tag" AutomationProperties.Name="角色">
                        <ComboBoxItem Content="店主" Tag="ShopOwner" />
                        <ComboBoxItem Content="店长" Tag="StoreManager" />
                        <ComboBoxItem Content="收银员" Tag="Cashier" />
                        <ComboBoxItem Content="技师" Tag="Technician" />
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Row="5" Grid.Column="1" Margin="8,0,0,12">
                    <TextBlock Text="所属门店" Style="{StaticResource FieldLabel}" />
                    <ComboBox x:Name="StoreBox" Style="{StaticResource FilterCombo}" SelectedValuePath="Id" AutomationProperties.Name="所属门店">
                        <ComboBox.ItemTemplate>
                            <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!--  盲人技师 | 状态  -->
                <StackPanel Grid.Row="6" Grid.Column="0" Margin="0,0,8,12">
                    <TextBlock Text="盲人技师" Style="{StaticResource FieldLabel}" />
                    <ToggleButton x:Name="BlindToggle" Style="{StaticResource SwitchToggle}" AutomationProperties.Name="盲人技师" />
                </StackPanel>
                <StackPanel Grid.Row="6" Grid.Column="1" Margin="8,0,0,12">
                    <TextBlock Text="状态（开为在职）" Style="{StaticResource FieldLabel}" />
                    <ToggleButton x:Name="ActiveToggle" Content="在职" IsChecked="True" Style="{StaticResource SwitchToggle}" AutomationProperties.Name="状态" />
                </StackPanel>

                <!--  专长（可多选）  -->
                <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,4">
                    <TextBlock Text="专长（可多选，便于排班和派单）" Style="{StaticResource FieldLabel}" />
                    <WrapPanel x:Name="SpecialtyPanel" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
