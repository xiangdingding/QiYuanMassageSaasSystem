<UserControl x:Class="MassageSaas.Cs.Views.MemberTypesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,4">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="会员类型" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="定义可售卡种：充值卡（充钱进余额）/ 计次卡（绑定服务、按次扣减）"
                               Foreground="#999" FontSize="12" Margin="0,2,0,0" />
                </StackPanel>
                <Button DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Padding="12,6" Background="#2D6A4F" Foreground="White" BorderThickness="0"
                        Content="新增会员类型" Command="{Binding CreateCommand}" />
            </DockPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,12">
                <TextBlock Text="卡种" VerticalAlignment="Center" Foreground="#666" Margin="0,0,8,0" />
                <ComboBox Width="140" Height="32" VerticalContentAlignment="Center"
                          SelectedValuePath="Tag" SelectedValue="{Binding FilterKind, Mode=TwoWay}"
                          AutomationProperties.Name="按卡种筛选">
                    <ComboBoxItem Content="全部" Tag="" IsSelected="True" />
                    <ComboBoxItem Content="充值卡" Tag="StoredValue" />
                    <ComboBoxItem Content="计次卡" Tag="CountBased" />
                </ComboBox>
            </StackPanel>

            <DataGrid Grid.Row="2" ItemsSource="{Binding Rows}" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                      AutomationProperties.Name="会员类型列表">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="AutomationProperties.Name">
                            <Setter.Value>
                                <MultiBinding StringFormat="{}{0}，{1}，{2}">
                                    <Binding Path="Name" />
                                    <Binding Path="KindLabel" />
                                    <Binding Path="StatusLabel" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="排序" Binding="{Binding Sort}" Width="60" />
                    <DataGridTextColumn Header="编码" Binding="{Binding Code}" Width="110" />
                    <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="类型" Binding="{Binding KindLabel}" Width="80" />
                    <DataGridTextColumn Header="绑定服务 / 最低门槛" Binding="{Binding BindingOrThreshold}" Width="200" />
                    <DataGridTextColumn Header="折扣" Binding="{Binding DiscountLabel}" Width="70" />
                    <DataGridTextColumn Header="赠送" Binding="{Binding BonusLabel}" Width="90" />
                    <DataGridTextColumn Header="有效期" Binding="{Binding ValidDaysLabel}" Width="80" />
                    <DataGridTextColumn Header="状态" Binding="{Binding StatusLabel}" Width="70" />
                    <DataGridTemplateColumn Header="操作" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Margin="2" Padding="8,2" Content="编辑"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                    <Button Margin="2" Padding="8,2" Content="删除" Background="#D9534F" Foreground="White" BorderThickness="0"
                                            Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
