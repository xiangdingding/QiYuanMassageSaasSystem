<UserControl x:Class="MassageSaas.Cs.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <UserControl.Resources>
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#EBEEF5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style x:Key="ChartCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#EBEEF5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style x:Key="MLabel" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#909399" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style x:Key="MValue" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#2D6A4F" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
        <Style x:Key="MSub" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#909399" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style x:Key="ChartTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="Margin" Value="2,0,0,8" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,4,0,12">

            <!--  工具条  -->
            <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#1F2937">
                    <Run Text="{Binding ActiveStoreName, Mode=OneWay}" /><Run Text=" · 经营数据看板" />
                </TextBlock>
                <Button Margin="16,0,0,0"
                        Padding="16,0"
                        AutomationProperties.Name="刷新看板"
                        Command="{Binding ReloadCommand}"
                        Content="刷新"
                        Style="{StaticResource PrimaryBtn}" />
                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#909399"
                           Text="趋势/排行统计区间：近 30 天" />
            </StackPanel>

            <!--  关键指标卡  -->
            <UniformGrid Columns="6" Rows="1">
                <Border Margin="0,0,6,0" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MLabel}" Text="今日营业额" />
                        <TextBlock Style="{StaticResource MValue}"><Run Text="¥" /><Run Text="{Binding TodayRevenue, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                        <TextBlock Style="{StaticResource MSub}"><Run Text="订单 " /><Run Text="{Binding TodayOrderCount, Mode=OneWay}" /><Run Text=" 单" /></TextBlock>
                    </StackPanel>
                </Border>
                <Border Margin="3,0,3,0" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MLabel}" Text="今日充值" />
                        <TextBlock Style="{StaticResource MValue}"><Run Text="¥" /><Run Text="{Binding TodayRecharge, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                        <TextBlock Style="{StaticResource MSub}"><Run Text="{Binding TodayRechargeCount, Mode=OneWay}" /><Run Text=" 笔" /></TextBlock>
                    </StackPanel>
                </Border>
                <Border Margin="3,0,3,0" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MLabel}" Text="本月营业额" />
                        <TextBlock Style="{StaticResource MValue}"><Run Text="¥" /><Run Text="{Binding MonthRevenue, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                        <TextBlock Style="{StaticResource MSub}"><Run Text="客单价 ¥" /><Run Text="{Binding MonthAverageOrder, StringFormat='F2', Mode=OneWay}" /></TextBlock>
                    </StackPanel>
                </Border>
                <Border Margin="3,0,3,0" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MLabel}" Text="本月钟数" />
                        <TextBlock Style="{StaticResource MValue}" Text="{Binding MonthRounds, Mode=OneWay}" />
                        <TextBlock Style="{StaticResource MSub}"><Run Text="订单 " /><Run Text="{Binding MonthOrderCount, Mode=OneWay}" /><Run Text=" 单" /></TextBlock>
                    </StackPanel>
                </Border>
                <Border Margin="3,0,3,0" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MLabel}" Text="会员总数" />
                        <TextBlock Style="{StaticResource MValue}" Text="{Binding MemberTotal, Mode=OneWay}" />
                        <TextBlock Style="{StaticResource MSub}"><Run Text="本月新增 " /><Run Text="{Binding NewMembers, Mode=OneWay}" /></TextBlock>
                    </StackPanel>
                </Border>
                <Border Margin="6,0,0,0" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MLabel}" Text="会员复购率" />
                        <TextBlock Style="{StaticResource MValue}"><Run Text="{Binding RepeatRate, Mode=OneWay}" /><Run Text="%" /></TextBlock>
                        <TextBlock Style="{StaticResource MSub}"><Run Text="复购 " /><Run Text="{Binding RepeatMembers, Mode=OneWay}" /><Run Text=" 人" /></TextBlock>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!--  营业额趋势 + 支付方式占比  -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="0,0,6,0" Style="{StaticResource ChartCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ChartTitle}" Text="本月每日营业额趋势" />
                        <lvc:CartesianChart Height="280"
                                            AutomationProperties.Name="本月每日营业额折线图"
                                            LegendPosition="Bottom"
                                            Series="{Binding RevenueSeries}"
                                            XAxes="{Binding RevenueXAxes}"
                                            YAxes="{Binding RevenueYAxes}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Margin="6,0,0,0" Style="{StaticResource ChartCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ChartTitle}" Text="今日支付方式占比" />
                        <lvc:PieChart Height="280"
                                      AutomationProperties.Name="今日支付方式占比饼图"
                                      LegendPosition="Bottom"
                                      Series="{Binding PaySeries}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  技师业绩 + 服务热度  -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="0,0,6,0" Style="{StaticResource ChartCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ChartTitle}" Text="技师业绩排行 · 近 30 天提成" />
                        <lvc:CartesianChart Height="280"
                                            AutomationProperties.Name="技师业绩排行柱状图"
                                            Series="{Binding TechSeries}"
                                            XAxes="{Binding TechXAxes}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Margin="6,0,0,0" Style="{StaticResource ChartCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ChartTitle}" Text="服务热度 Top 10 · 近 30 天钟数" />
                        <lvc:CartesianChart Height="280"
                                            AutomationProperties.Name="服务热度排行柱状图"
                                            Series="{Binding PopularitySeries}"
                                            YAxes="{Binding PopularityYAxes}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  客流趋势 + 会员构成  -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="0,0,6,0" Style="{StaticResource ChartCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ChartTitle}" Text="客流趋势 · 近 30 天" />
                        <lvc:CartesianChart Height="280"
                                            AutomationProperties.Name="客流趋势折线图"
                                            LegendPosition="Bottom"
                                            Series="{Binding FlowSeries}"
                                            XAxes="{Binding FlowXAxes}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Margin="6,0,0,0" Style="{StaticResource ChartCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource ChartTitle}" Text="会员构成" />
                        <lvc:PieChart Height="280"
                                      AutomationProperties.Name="会员构成饼图"
                                      LegendPosition="Bottom"
                                      Series="{Binding MemberSeries}" />
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
