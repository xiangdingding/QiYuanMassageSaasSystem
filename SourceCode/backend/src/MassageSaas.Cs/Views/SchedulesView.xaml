<UserControl x:Class="MassageSaas.Cs.Views.SchedulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <!-- 排班 -->
        <Border Grid.Row="0" Background="White" CornerRadius="4" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock DockPanel.Dock="Left" Text="技师排班" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <TextBlock Text="从" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <DatePicker SelectedDate="{Binding FromDate}" Width="130" AutomationProperties.Name="排班起始日期" />
                        <TextBlock Text="到" VerticalAlignment="Center" Margin="8,0,6,0" />
                        <DatePicker SelectedDate="{Binding ToDate}" Width="130" AutomationProperties.Name="排班结束日期" />
                        <Button Content="新增班次" Padding="12,6" Margin="12,0,0,0" Background="#2D6A4F" Foreground="White" BorderThickness="0" Command="{Binding AddScheduleCommand}" />
                        <Button Content="刷新" Padding="12,6" Margin="8,0,0,0" Command="{Binding ReloadCommand}" />
                    </StackPanel>
                </DockPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Schedules}" AutoGenerateColumns="False"
                          CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" AlternatingRowBackground="#FAFAFA">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="日期" Binding="{Binding WorkDate, StringFormat='{}{0:yyyy-MM-dd ddd}'}" Width="160" />
                        <DataGridTextColumn Header="技师" Binding="{Binding UserName}" Width="160" />
                        <DataGridTextColumn Header="开始" Binding="{Binding StartTime}" Width="90" />
                        <DataGridTextColumn Header="结束" Binding="{Binding EndTime}" Width="90" />
                        <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="*" />
                        <DataGridTemplateColumn Header="操作" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Margin="2" Padding="6,2" Content="删除" Background="#D9534F" Foreground="White" BorderThickness="0"
                                            Command="{Binding DataContext.DeleteScheduleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 请假审批 -->
        <Border Grid.Row="2" Background="White" CornerRadius="4" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock DockPanel.Dock="Left" Text="请假审批" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <CheckBox DockPanel.Dock="Right" Content="仅看待审批" IsChecked="{Binding OnlyPendingLeaves}" VerticalAlignment="Center" />
                </DockPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Leaves}" AutoGenerateColumns="False"
                          CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" AlternatingRowBackground="#FAFAFA">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="申请人" Binding="{Binding UserName}" Width="130" />
                        <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="80" />
                        <DataGridTextColumn Header="起" Binding="{Binding FromDate, StringFormat='{}{0:MM-dd}'}" Width="80" />
                        <DataGridTextColumn Header="止" Binding="{Binding ToDate, StringFormat='{}{0:MM-dd}'}" Width="80" />
                        <DataGridTextColumn Header="事由" Binding="{Binding Reason}" Width="200" />
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80" />
                        <DataGridTextColumn Header="审批人" Binding="{Binding ApproverName}" Width="110" />
                        <DataGridTemplateColumn Header="操作" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Margin="2" Padding="6,2" Content="批准" Background="#2D6A4F" Foreground="White" BorderThickness="0"
                                                Command="{Binding DataContext.ApproveLeaveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" />
                                        <Button Margin="2" Padding="6,2" Content="驳回" Background="#D9534F" Foreground="White" BorderThickness="0"
                                                Command="{Binding DataContext.RejectLeaveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
