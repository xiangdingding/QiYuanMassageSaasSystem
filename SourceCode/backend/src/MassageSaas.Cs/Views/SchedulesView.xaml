<UserControl x:Class="MassageSaas.Cs.Views.SchedulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="White" CornerRadius="4" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  顶部：刷新固定最右（LastChildFill=False 避免按钮被拉满）  -->
            <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                <Button DockPanel.Dock="Right"
                        Padding="16,0"
                        AutomationProperties.Name="刷新"
                        Command="{Binding ReloadCommand}"
                        Content="刷新"
                        Style="{StaticResource GhostBtn}" />
            </DockPanel>

            <!--  与 BS 一致：排班 / 请假审批 两个 Tab  -->
            <TabControl Grid.Row="1">
                <!--  排班  -->
                <TabItem Header="排班">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <!--  新增排班固定在最右侧  -->
                            <Button DockPanel.Dock="Right"
                                    Padding="16,0"
                                    AutomationProperties.Name="新增排班"
                                    Command="{Binding AddScheduleCommand}"
                                    Content="新增排班"
                                    Style="{StaticResource PrimaryBtn}" />
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Margin="0,0,6,0" VerticalAlignment="Center" Text="从" />
                                <DatePicker Width="150"
                                            AutomationProperties.Name="排班起始日期"
                                            PreviewMouseLeftButtonUp="DatePicker_PreviewMouseUp"
                                            SelectedDate="{Binding FromDate}"
                                            SelectedDateFormat="Short"
                                            Style="{StaticResource FilterDatePicker}" />
                                <TextBlock Margin="8,0,6,0" VerticalAlignment="Center" Text="到" />
                                <DatePicker Width="150"
                                            AutomationProperties.Name="排班结束日期"
                                            PreviewMouseLeftButtonUp="DatePicker_PreviewMouseUp"
                                            SelectedDate="{Binding ToDate}"
                                            SelectedDateFormat="Short"
                                            Style="{StaticResource FilterDatePicker}" />
                            </StackPanel>
                        </DockPanel>

                        <DataGrid Grid.Row="1"
                                  AlternatingRowBackground="#FAFAFA"
                                  AutoGenerateColumns="False"
                                  AutomationProperties.Name="排班列表"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding Schedules}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="120"
                                                    Binding="{Binding WorkDate, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                    Header="日期" />
                                <DataGridTextColumn Width="140" Binding="{Binding UserName}" Header="员工" />
                                <DataGridTemplateColumn Width="160" Header="班次">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center">
                                                <Run Text="{Binding StartTime, Mode=OneWay}" /><Run Text=" - " /><Run Text="{Binding EndTime, Mode=OneWay}" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Width="*" Binding="{Binding Remark}" Header="备注" />
                                <DataGridTemplateColumn Width="100" Header="操作">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button AutomationProperties.Name="删除班次"
                                                    Command="{Binding DataContext.DeleteScheduleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="删除"
                                                    Style="{StaticResource RowDanger}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!--  请假审批  -->
                <TabItem Header="请假审批">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  登记请假固定最右；左侧为请假过滤（员工/类型/状态/日期区间）  -->
                        <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
                            <Button DockPanel.Dock="Right"
                                    Padding="16,0"
                                    AutomationProperties.Name="登记请假"
                                    Command="{Binding RegisterLeaveCommand}"
                                    Content="登记请假"
                                    Style="{StaticResource PrimaryBtn}" />
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Margin="0,0,6,0" VerticalAlignment="Center" Text="员工" />
                                <ComboBox Width="140"
                                          Style="{StaticResource FilterCombo}"
                                          AutomationProperties.Name="按员工过滤请假"
                                          ItemsSource="{Binding LeaveStaffOptions}"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding LeaveUserFilter, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Margin="12,0,6,0" VerticalAlignment="Center" Text="类型" />
                                <ComboBox Width="120"
                                          Style="{StaticResource FilterCombo}"
                                          AutomationProperties.Name="按请假类型过滤"
                                          ItemsSource="{Binding LeaveTypeOptions}"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding LeaveTypeFilter, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Margin="12,0,6,0" VerticalAlignment="Center" Text="状态" />
                                <ComboBox Width="120"
                                          Style="{StaticResource FilterCombo}"
                                          AutomationProperties.Name="按审批状态过滤"
                                          ItemsSource="{Binding LeaveStatusOptions}"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding LeaveStatusFilter, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate><TextBlock Text="{Binding Label}" /></DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Margin="12,0,6,0" VerticalAlignment="Center" Text="从" />
                                <DatePicker Width="140"
                                            AutomationProperties.Name="请假日期起"
                                            PreviewMouseLeftButtonUp="DatePicker_PreviewMouseUp"
                                            SelectedDate="{Binding LeaveFromFilter}"
                                            SelectedDateFormat="Short"
                                            Style="{StaticResource FilterDatePicker}" />
                                <TextBlock Margin="8,0,6,0" VerticalAlignment="Center" Text="到" />
                                <DatePicker Width="140"
                                            AutomationProperties.Name="请假日期止"
                                            PreviewMouseLeftButtonUp="DatePicker_PreviewMouseUp"
                                            SelectedDate="{Binding LeaveToFilter}"
                                            SelectedDateFormat="Short"
                                            Style="{StaticResource FilterDatePicker}" />
                                <Button Margin="12,0,0,0"
                                        Padding="16,0"
                                        AutomationProperties.Name="重置请假过滤"
                                        Command="{Binding ResetLeaveFilterCommand}"
                                        Content="重置"
                                        Style="{StaticResource GhostBtn}" />
                            </WrapPanel>
                        </DockPanel>

                        <DataGrid Grid.Row="1"
                              AlternatingRowBackground="#FAFAFA"
                              AutoGenerateColumns="False"
                              AutomationProperties.Name="请假审批列表"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Leaves}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="130" Binding="{Binding UserName}" Header="员工" />
                            <DataGridTextColumn Width="90"
                                                Binding="{Binding Type, Converter={StaticResource LeaveLabel}}"
                                                Header="类型" />
                            <DataGridTemplateColumn Width="220" Header="日期">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="{Binding FromDate, StringFormat='{}{0:yyyy-MM-dd}', Mode=OneWay}" /><Run Text=" - " /><Run Text="{Binding ToDate, StringFormat='{}{0:yyyy-MM-dd}', Mode=OneWay}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Width="70" Binding="{Binding Days, StringFormat='{}{0:0.#} 天'}" Header="天数" />
                            <DataGridTextColumn Width="*" Binding="{Binding Reason}" Header="原因" />
                            <DataGridTextColumn Width="90"
                                                Binding="{Binding Status, Converter={StaticResource LeaveLabel}}"
                                                Header="状态" />
                            <DataGridTextColumn Width="110" Binding="{Binding ApproverName}" Header="审批人" />
                            <DataGridTemplateColumn Width="210" Header="操作">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button AutomationProperties.Name="查看请假详情"
                                                    Command="{Binding DataContext.ShowLeaveDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="详情"
                                                    Style="{StaticResource RowGhost}" />
                                            <Button AutomationProperties.Name="同意请假"
                                                    Command="{Binding DataContext.ApproveLeaveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="同意"
                                                    IsEnabled="{Binding Status, Converter={StaticResource StringEquals}, ConverterParameter=Pending}"
                                                    Style="{StaticResource RowPrimary}" />
                                            <Button AutomationProperties.Name="驳回请假"
                                                    Command="{Binding DataContext.RejectLeaveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="驳回"
                                                    IsEnabled="{Binding Status, Converter={StaticResource StringEquals}, ConverterParameter=Pending}"
                                                    Style="{StaticResource RowDanger}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
