<UserControl x:Class="MassageSaas.Cs.Controls.PaginationBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- 页码 / 上一页 / 下一页 / 省略号 通用按钮：浅灰底圆角，悬停字变蓝，禁用变灰（对齐 Element Plus 默认分页器） -->
        <Style x:Key="PagerButton" TargetType="Button">
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#606266" />
            <Setter Property="Background" Value="#F4F4F5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#2D6A4F" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#C0C4CC" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 当前页：蓝底白字 -->
        <Style x:Key="PagerActiveButton" TargetType="Button" BasedOn="{StaticResource PagerButton}">
            <Setter Property="Background" Value="#2D6A4F" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- 每页条数下拉：白底描边圆角小箭头 -->
        <Style x:Key="SizeCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Width" Value="92" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#606266" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="Toggle" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="White" BorderBrush="#DCDFE6"
                                                BorderThickness="1" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="22" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="9,0,0,0" VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="#A8ABB2" StrokeThickness="1.3"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide">
                                <Border Background="White" BorderBrush="#DCDFE6" BorderThickness="1" CornerRadius="4"
                                        Margin="0,4,0,0" SnapsToDevicePixels="True"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                    <ScrollViewer MaxHeight="220">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
        <TextBlock x:Name="TotalText" VerticalAlignment="Center" Foreground="#606266" FontSize="13"
                   Margin="0,0,12,0" AutomationProperties.Name="总条数" />
        <ComboBox x:Name="SizeCombo" Style="{StaticResource SizeCombo}" Margin="0,0,12,0"
                  SelectionChanged="SizeCombo_SelectionChanged"
                  AutomationProperties.Name="每页条数" />
        <!-- 上一页 / 页码 / 下一页 由后台动态构建 -->
        <StackPanel x:Name="PagerPanel" Orientation="Horizontal" VerticalAlignment="Center" />
        <TextBlock Text="前往" VerticalAlignment="Center" Foreground="#606266" FontSize="13" Margin="12,0,6,0" />
        <Border BorderBrush="#DCDFE6" BorderThickness="1" CornerRadius="4" Width="44" Height="30" Background="White">
            <TextBox x:Name="JumpBox" BorderThickness="0" Background="Transparent" FontSize="13"
                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                     KeyDown="JumpBox_KeyDown" AutomationProperties.Name="跳转到页码" />
        </Border>
        <TextBlock Text="页" VerticalAlignment="Center" Foreground="#606266" FontSize="13" Margin="6,0,0,0" />
    </StackPanel>
</UserControl>
