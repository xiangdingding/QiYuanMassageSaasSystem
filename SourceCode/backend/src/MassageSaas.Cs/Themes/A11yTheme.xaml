<!--
    无障碍模式主题（A11yTheme）

    与 BS shop-admin 的 [data-a11y='a11y'] CSS 思路对齐：
    - 字号 +2pt，按钮 / 输入框最小 44 高，满足触控/老花眼可读性
    - 焦点框加粗 + 高对比黄色，不依赖颜色识别活动元素
    - DataGrid 行高加大、行聚焦时背景高亮
    - 减少视觉装饰、聚焦语义

    所有样式都是"隐式样式"（带 TargetType 不带 x:Key），
    Application.Resources.MergedDictionaries.Add(this) 后自动覆盖全局默认。
    Unmerge 后样式立即回到正常模式。

    AutomationProperties 已经在各 view 单独挂；这里只管视觉。
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <SolidColorBrush x:Key="A11yFocusBrush" Color="#FFD04B" />
    <SolidColorBrush x:Key="A11yRowFocusBg" Color="#FFF8DF" />
    <sys:Double x:Key="A11yBaseFontSize">15</sys:Double>

    <!-- 焦点框：黄色虚线粗框 -->
    <Style x:Key="A11yFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle Margin="2"
                               Stroke="{StaticResource A11yFocusBrush}"
                               StrokeThickness="3"
                               StrokeDashArray="1 0"
                               SnapsToDevicePixels="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 隐式样式：作用于所有未显式 Style 的控件 -->
    <Style TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource A11yBaseFontSize}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="FontSize" Value="{StaticResource A11yBaseFontSize}" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource A11yFocusVisual}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontSize" Value="{StaticResource A11yBaseFontSize}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource A11yFocusVisual}" />
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontSize" Value="{StaticResource A11yBaseFontSize}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource A11yFocusVisual}" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FontSize" Value="{StaticResource A11yBaseFontSize}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource A11yFocusVisual}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="FontSize" Value="{StaticResource A11yBaseFontSize}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource A11yFocusVisual}" />
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="FontSize" Value="{StaticResource A11yBaseFontSize}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource A11yFocusVisual}" />
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="RowHeight" Value="38" />
        <Setter Property="ColumnHeaderHeight" Value="40" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource A11yFocusVisual}" />
    </Style>

    <Style TargetType="DataGridRow">
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="Background" Value="{StaticResource A11yRowFocusBg}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource A11yFocusVisual}" />
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="FontSize" Value="{StaticResource A11yBaseFontSize}" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

</ResourceDictionary>
