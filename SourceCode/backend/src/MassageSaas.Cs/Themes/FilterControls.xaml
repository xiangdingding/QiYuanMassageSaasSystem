<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:behaviors="clr-namespace:MassageSaas.Cs.Behaviors"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!--
        全系统统一的「下拉框」与「日期选择器」样式。
        - FilterCombo：取自预约管理状态下拉框（圆角描边、悬停/展开绿边、右侧灰箭头）。
        - FilterDatePicker：取自订单流水日期控件（圆角外框 + MaterialDesign 日历图标 + 聚焦绿色加粗边 + 放大日历弹窗 + 点击展开）。
        两者既给出带 Key 的样式（显式引用），又设为 ComboBox/DatePicker 的隐式默认，
        所以没有显式样式的下拉框/日期框会自动统一。基础设施下拉框（门店切换、分页每页条数）
        与可编辑下拉框都各有显式样式，不受隐式影响。
    -->

    <!--  ============ 下拉框：参考预约管理状态下拉框 ============  -->
    <Style x:Key="FilterCombo" TargetType="ComboBox">
        <Setter Property="Height" Value="34" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="#374151" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="Toggle" Focusable="False" ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="bd" Background="White" BorderBrush="#D1D5DB"
                                            BorderThickness="1" CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="26" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0" Margin="10,0,0,0" VerticalAlignment="Center"
                                                              Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                              ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                            <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="#9CA3AF" StrokeThickness="1.4"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True"
                               Focusable="False" PopupAnimation="Slide">
                            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6"
                                    Margin="0,4,0,0" SnapsToDevicePixels="True"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                <ScrollViewer MaxHeight="260">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ 日期选择器：参考订单流水日期控件 ============  -->
    <Style x:Key="FilterDatePicker" TargetType="DatePicker">
        <Setter Property="Height" Value="34" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="#374151" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="behaviors:DatePickerBehaviors.OpenOnClick" Value="True" />
        <!--  弹出的日历整体等比放大，星期/日期格/箭头都更大更易点  -->
        <Setter Property="CalendarStyle">
            <Setter.Value>
                <Style TargetType="Calendar">
                    <Setter Property="LayoutTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.35" ScaleY="1.35" />
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePicker">
                    <Border x:Name="bd"
                            Background="White"
                            BorderBrush="#BDBDBD"
                            BorderThickness="1"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>

                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               Margin="10,0,0,0"
                                               Padding="0"
                                               VerticalContentAlignment="Center"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Focusable="{TemplateBinding Focusable}" />

                            <!--  清除按钮（×）：仅在已选日期时显示，点击清空（逻辑在 DatePickerBehaviors 内统一处理）  -->
                            <Button x:Name="PART_ClearButton"
                                    Grid.Column="1"
                                    Width="22"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Focusable="False"
                                    AutomationProperties.Name="清除日期"
                                    ToolTip="清除日期">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <materialDesign:PackIcon x:Name="cico"
                                                                     Width="15"
                                                                     Height="15"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     Foreground="#9CA3AF"
                                                                     Kind="CloseCircle" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="cico" Property="Foreground" Value="#D9534F" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!--  MaterialDesign 官方日历图标按钮：打开日历弹窗  -->
                            <Button x:Name="PART_Button"
                                    Grid.Column="2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Focusable="False">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <materialDesign:PackIcon x:Name="ico"
                                                                     Width="20"
                                                                     Height="20"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     Foreground="#757575"
                                                                     Kind="CalendarBlankOutline" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ico" Property="Foreground" Value="#2D6A4F" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=bd}"
                                   StaysOpen="False" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!--  未选择日期时隐藏清除按钮  -->
                        <Trigger Property="SelectedDate" Value="{x:Null}">
                            <Setter TargetName="PART_ClearButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                            <Setter TargetName="bd" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="#F3F4F6" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="#E0E0E0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ 搜索框：圆角 + 占位提示（Tag 设置），聚焦绿边 ============  -->
    <Style x:Key="SearchBox" TargetType="TextBox">
        <Setter Property="Height" Value="34" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="BorderBrush" Value="#D1D5DB" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd" Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                            <TextBlock x:Name="ph" Text="{TemplateBinding Tag}" Foreground="#9CA3AF"
                                       Margin="11,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="ph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ 表单输入框：圆角描边，聚焦绿边（单行 / 多行） ============  -->
    <Style x:Key="FieldText" TargetType="TextBox">
        <Setter Property="Height" Value="34" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="BorderBrush" Value="#D1D5DB" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd" Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                            <TextBlock x:Name="ph" Text="{TemplateBinding Tag}" Foreground="#9CA3AF"
                                       Margin="11,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="ph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="#F3F4F6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FieldTextMultiline" TargetType="TextBox">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="BorderBrush" Value="#D1D5DB" />
        <Setter Property="AcceptsReturn" Value="True" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd" Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Top" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ 可编辑下拉框：圆角描边 + 可输入（与 FilterCombo 同观感） ============  -->
    <Style x:Key="FieldComboEditable" TargetType="ComboBox">
        <Setter Property="Height" Value="34" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="IsEditable" Value="True" />
        <Setter Property="Foreground" Value="#374151" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="bd" Background="White" BorderBrush="#D1D5DB"
                                BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="26" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PART_EditableTextBox" Grid.Column="0" Margin="8,0,0,0"
                                         VerticalContentAlignment="Center" Background="Transparent" BorderThickness="0"
                                         Foreground="{TemplateBinding Foreground}"
                                         IsReadOnly="{TemplateBinding IsReadOnly}" />
                                <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                              Background="Transparent" BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <Path Data="M0,0 L4,4 L8,0" Stroke="#9CA3AF" StrokeThickness="1.4"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Grid>
                        </Border>
                        <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                               AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6"
                                    Margin="0,4,0,0" SnapsToDevicePixels="True"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                <ScrollViewer MaxHeight="260">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ 开关式 ToggleButton：绿色滑块（替代布尔勾选框） ============  -->
    <Style x:Key="SwitchToggle" TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="#374151" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="track" Width="42" Height="22" CornerRadius="11"
                                Background="#CBD5E1" VerticalAlignment="Center" SnapsToDevicePixels="True">
                            <Border x:Name="thumb" Width="18" Height="18" CornerRadius="9" Background="White"
                                    HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="3" Opacity="0.3" ShadowDepth="0.5" />
                                </Border.Effect>
                            </Border>
                        </Border>
                        <ContentPresenter x:Name="cp" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="track" Property="Background" Value="#2D6A4F" />
                            <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="track" Property="Opacity" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="track" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ 按钮：主操作 / 次操作 / 行内（小号） ============  -->
    <!--  主操作（查询 / 新建）：绿底圆角  -->
    <Style x:Key="PrimaryBtn" TargetType="Button">
        <Setter Property="Height" Value="34" />
        <Setter Property="Background" Value="#2D6A4F" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#245A41" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="#9CC3B0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  次操作（刷新 / 重置）：白底描边圆角，悬停绿边  -->
    <Style x:Key="GhostBtn" TargetType="Button">
        <Setter Property="Height" Value="34" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Foreground" Value="#374151" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="#D1D5DB"
                            BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#F3F4F6" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  行内主操作（小号圆角，对齐 BS 列表按钮）  -->
    <Style x:Key="RowPrimary" TargetType="Button">
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Margin" Value="3,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="#2D6A4F" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#245A41" /></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter TargetName="bd" Property="Background" Value="#9CC3B0" /></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  行内次操作  -->
    <Style x:Key="RowGhost" TargetType="Button">
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Margin" Value="3,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="#374151" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="#D1D5DB"
                            BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#F3F4F6" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  行内危险操作（删除 / 取消）  -->
    <Style x:Key="RowDanger" TargetType="Button">
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Margin" Value="3,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="#D9534F" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#C9302C" /></Trigger>
                        <Trigger Property="IsEnabled" Value="False"><Setter TargetName="bd" Property="Background" Value="#E2A6A4" /></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ 分段单选按钮（对齐 BS el-radio-button）：拼接成一排，选中绿底白字 ============
          用法：每个 RadioButton 设 GroupName 相同，CommandParameter 存取值，Tag 存圆角（首/尾圆角、中间 0），
          首项 BorderThickness="1,1,1,1"，其余用默认 "0,1,1,1"（共享左边框，避免双线）。  -->
    <Style x:Key="SegRadio" TargetType="RadioButton">
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="#374151" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="#D1D5DB" />
        <Setter Property="BorderThickness" Value="0,1,1,1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding Tag}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                            <Setter Property="Foreground" Value="#2D6A4F" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#2D6A4F" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="#2D6A4F" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="Panel.ZIndex" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ============ 隐式默认：未显式设样式的下拉框/日期框自动统一 ============  -->
    <Style BasedOn="{StaticResource FilterCombo}" TargetType="ComboBox" />
    <Style BasedOn="{StaticResource FilterDatePicker}" TargetType="DatePicker" />

</ResourceDictionary>
