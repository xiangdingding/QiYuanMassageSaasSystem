<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS 托管配置（ASP.NET Core Module V2，进程内 in-process）。
  发布时 dotnet SDK 会自动把 %LAUNCHER_PATH% / %LAUNCHER_ARGS% 替换为实际可执行文件。
  http / https 两个绑定都由 IIS 站点层配置，应用本身不强制跳转 https（见 Program.cs）。
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <!-- 卸掉 IIS WebDAV：否则它会拦截 PUT/DELETE 请求并返回 405（业务咨询处理、各类更新接口都受影响） -->
      <modules>
        <remove name="WebDAVModule" />
      </modules>
      <handlers>
        <remove name="WebDAV" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="%LAUNCHER_PATH%"
                  arguments="%LAUNCHER_ARGS%"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
      <!-- 允许较大的上传（如导入/附件）；按需调整，单位字节，此处 100MB -->
      <security>
        <requestFiltering>
          <requestLimits maxAllowedContentLength="104857600" />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>
</configuration>
