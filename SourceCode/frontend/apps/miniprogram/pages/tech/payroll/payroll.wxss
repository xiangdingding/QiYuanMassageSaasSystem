.page { padding: 24rpx; }
.header { font-size: 40rpx; font-weight: 700; margin-bottom: 16rpx; }
.hint { font-size: 30rpx; color: #999; text-align: center; margin: 60rpx 0; }
.list { display: flex; flex-direction: column; gap: 20rpx; }
.card {
  background: #fff; border-radius: 16rpx; padding: 28rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}
.row { display: flex; gap: 20rpx; align-items: center; flex-wrap: wrap; }
.top { justify-content: space-between; margin-bottom: 16rpx; }
.net { font-size: 40rpx; font-weight: 700; color: #d9534f; }
.net-read { font-size: 26rpx; color: #2D6A4F; }
.breakdown { gap: 16rpx; margin-bottom: 12rpx; }
.cell { font-size: 28rpx; color: #333; padding: 6rpx 12rpx; background: #f5f7fa; border-radius: 6rpx; }
.cell.tip { background: #fff3cd; }
.adj-list { display: flex; flex-direction: column; gap: 6rpx; margin: 8rpx 0 12rpx; }
.adj-line { font-size: 26rpx; color: #555; line-height: 1.6; }
.meta { font-size: 26rpx; color: #888; gap: 24rpx; }
.remark { font-size: 26rpx; color: #888; margin-top: 8rpx; }
.a11y-btn.small {
  margin-top: 12rpx; padding: 12rpx 24rpx; font-size: 28rpx;
  background: #2D6A4F; color: #fff; border: none;
}
