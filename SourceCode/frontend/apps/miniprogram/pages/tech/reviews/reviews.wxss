.page { padding: 24rpx; }
.header { font-size: 40rpx; font-weight: 700; margin-bottom: 12rpx; }
.summary { font-size: 30rpx; color: #555; margin-bottom: 24rpx; }
.hint { font-size: 30rpx; color: #999; margin: 60rpx 0; text-align: center; }
.list { display: flex; flex-direction: column; gap: 16rpx; }
.card {
  background: #fff; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}
.row1 { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.customer { font-size: 32rpx; font-weight: 600; }
.stars { font-size: 32rpx; color: #f5a623; }
.tags { font-size: 28rpx; color: #2D6A4F; margin-bottom: 8rpx; }
.comment { font-size: 30rpx; line-height: 1.5; color: #333; margin-bottom: 8rpx; }
.time { font-size: 24rpx; color: #999; text-align: right; }
