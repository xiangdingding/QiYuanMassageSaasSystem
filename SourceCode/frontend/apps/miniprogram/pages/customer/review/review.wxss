.a11y-input {
  display: block;
  width: 100%;
  min-height: 88rpx;
  padding: 16rpx 20rpx;
  margin-top: 12rpx;
  border: 2rpx solid #888;
  border-radius: 8rpx;
  font-size: 36rpx;
  background: #fafafa;
  color: #000;
}

.a11y-textarea {
  display: block;
  width: 100%;
  min-height: 140rpx;
  padding: 16rpx 20rpx;
  margin-top: 12rpx;
  border: 2rpx solid #888;
  border-radius: 8rpx;
  font-size: 36rpx;
  background: #fafafa;
  color: #000;
  box-sizing: border-box;
}

.a11y-card {
  margin: 24rpx 0;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  overflow: hidden;
}

/* 满意度档位：整行大按钮，单列线性排列，已选填充蓝；选中态除颜色外，标签文字本身即语义 */
.opts {
  margin-top: 12rpx;
}

.opt {
  display: block;
  width: 100%;
  min-height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  margin-bottom: 12rpx;
  text-align: center;
  font-size: 38rpx;
  border: 2rpx solid #bbb;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.opt.on {
  color: #fff;
  background: #1677ff;
  border-color: #1677ff;
  font-weight: 600;
}

.opt.off {
  color: #333;
  background: #fff;
}

/* 常用标签：可换行的胶囊，点选高亮 */
.chips {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.chip {
  min-height: 72rpx;
  line-height: 72rpx;
  padding: 0 28rpx;
  margin: 0 16rpx 16rpx 0;
  font-size: 34rpx;
  border: 2rpx solid #bbb;
  border-radius: 36rpx;
}

.chip.on {
  color: #fff;
  background: #1677ff;
  border-color: #1677ff;
  font-weight: 600;
}

.chip.off {
  color: #333;
  background: #fff;
}
