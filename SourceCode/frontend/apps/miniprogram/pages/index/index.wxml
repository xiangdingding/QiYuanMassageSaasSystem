<!-- 首页：线性布局、大按钮、aria-label 明确 -->
<view class="container" role="main">
  <view class="a11y-section" aria-live="polite">
    <text class="a11y-value">欢迎，{{userName || '访客'}}</text>
  </view>

  <view class="a11y-section">
    <text class="a11y-label">当前门店</text>
    <text class="a11y-value">{{storeName || '未选择门店'}}</text>
  </view>

  <button
    class="a11y-btn"
    aria-label="跳转到我的班次"
    bindtap="goHome">
    我的班次
  </button>

  <button
    class="a11y-btn"
    aria-label="跳转到我的业绩查询"
    bindtap="goPerformance">
    我的业绩
  </button>

  <button
    class="a11y-btn"
    aria-label="登录或切换账号"
    bindtap="goLogin">
    登录 / 切换账号
  </button>
</view>
