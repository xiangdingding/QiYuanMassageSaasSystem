{
  "name": "shop-mobile",
  "private": true,
  "version": "0.1.0",
  "description": "按摩店端 移动版（Vue3 + Vant + Capacitor）— 与 BS 版逻辑同源，iOS / Android 双端运行",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "android": "npm run build && cap sync android && cap open android",
    "ios": "npm run build && cap sync ios && cap open ios"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/status-bar": "^6.0.2",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "echarts": "^6.1.0",
    "pinia": "^2.2.6",
    "vue-echarts": "^8.0.1",
    "vant": "^4.9.15",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vue-tsc": "^2.1.10"
  }
}
