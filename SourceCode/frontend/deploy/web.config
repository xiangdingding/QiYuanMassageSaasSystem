<?xml version="1.0" encoding="utf-8"?>
<!--
  前端 SPA（shop-admin / platform-admin）IIS 托管配置。
  两件事：
  1) /api 反向代理到后端 API 站点（前端 axios baseURL 是相对的 '/api'，与开发期代理一致）。
     需要在服务器装【URL Rewrite】+【Application Request Routing(ARR)】并在 IIS 服务器层
     开启代理：IIS 管理器 → 服务器节点 → Application Request Routing Cache →
     右侧 Server Proxy Settings → 勾选 Enable proxy。
     ★部署时把下面的 http://后端API地址:端口 改成真实 API 站点地址。
  2) HTML5 history 路由回退：非真实文件/目录、且非 /api 的请求，统一交给 index.html。
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- (1) /api 反代到后端 API（按服务器实际地址修改） -->
        <rule name="ApiProxy" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://后端API地址:端口/api/{R:1}" />
        </rule>
        <!-- (2) SPA 前端路由回退 -->
        <rule name="SpaFallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <add input="{REQUEST_URI}" pattern="^/api/" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>
    <staticContent>
      <!-- 补全常见 MIME，避免个别 IIS 缺失导致 404/类型错误 -->
      <remove fileExtension=".json" /><mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".woff" /><mimeMap fileExtension=".woff" mimeType="font/woff" />
      <remove fileExtension=".woff2" /><mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".svg" /><mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
    </staticContent>
    <!-- index.html 不缓存，保证发版后客户端立即拿到新版本（带 hash 的 assets 可长缓存） -->
    <httpProtocol>
      <customHeaders>
        <add name="Cache-Control" value="no-cache" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
